# Sitio (SEO: canonical, Open Graph, JSON-LD). En producción: https://pasochilehoy.com
# También podés usar `.env.production` al hacer `astro build` con esos valores.
PUBLIC_SITE_URL=https://pasochilehoy.com
PUBLIC_SITE_NAME=Paso Chile Hoy

# Firebase (web) — copiá este archivo a `.env` y completá los valores.
# En Astro solo las variables con prefijo PUBLIC_ llegan al cliente.
# https://firebase.google.com/docs/web/setup

PUBLIC_FIREBASE_API_KEY=
PUBLIC_FIREBASE_AUTH_DOMAIN=
PUBLIC_FIREBASE_PROJECT_ID=
PUBLIC_FIREBASE_STORAGE_BUCKET=
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
PUBLIC_FIREBASE_APP_ID=
PUBLIC_FIREBASE_MEASUREMENT_ID=

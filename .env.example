# Sitio (SEO: canonical, Open Graph, JSON-LD). En Vercel: definir en Project → Settings → Environment Variables.
PUBLIC_SITE_URL=https://pasochilehoy.com
PUBLIC_SITE_NAME=Paso Chile Hoy

# Opcional: POST /api/snapshot/:slug exige el header x-scrape-secret si está definido.
SCRAPE_SECRET=

# Logs de depuración por paso en SSR (terminal local / Vercel si se define allí).
DEBUG_PASS=true

# Copiá este archivo a `.env.local` y pegá los valores del dashboard Upstash o de Vercel.
# `.env.local` NO se sube a git (.gitignore).

# Obligatorias para /api/likes (REST) y para persistir snapshots de pasos en runtime en Vercel
# (POST "Actualizar" + lectura SSR/API leen la misma clave en Redis; sin esto, el refresh en producción falla).
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Secreto para /api/cron/twitter-refresh (Vercel Cron envía Authorization: Bearer <CRON_SECRET>)
CRON_SECRET=

# Snapshot de novedad X en producción: mismo Redis/KV (filesystem de Vercel es solo lectura en runtime).
# En local, sin KV, se usa solo public/snapshots/twitter-latest.json.

# Opcional: solo si usás lectura con otro cliente
# KV_REST_API_READ_ONLY_TOKEN=

# Opcional: conexión TCP/TLS (redis-cli, etc.); el sitio no las usa para el contador
# KV_URL=
# REDIS_URL=

# Opcional: número de seguidores de @PasoCRMza para la card de X en la home (solo UI; no hay API de X en el proyecto).
# PUBLIC_X_FOLLOWERS_COUNT=1234

# Opcional: URL del perfil de LinkedIn (por defecto el footer usa un enlace placeholder).
# PUBLIC_LINKEDIN_URL=https://www.linkedin.com/in/tu-usuario

# Opcional: Instagram público para el footer.
# PUBLIC_INSTAGRAM_URL=https://www.instagram.com/tu_usuario

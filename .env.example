# Copiá este archivo a `.env.local` y pegá los valores del dashboard Upstash o de Vercel.
# `.env.local` NO se sube a git (.gitignore).

# Obligatorias para /api/likes (REST)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Opcional: solo si usás lectura con otro cliente
# KV_REST_API_READ_ONLY_TOKEN=

# Opcional: conexión TCP/TLS (redis-cli, etc.); el sitio no las usa para el contador
# KV_URL=
# REDIS_URL=

# Opcional: API de X (Twitter) v2 — timeline @PasoCRMza en la home y en scrape (alternativa estable a Nitter)
# TWITTER_BEARER_TOKEN=
# (alias) X_BEARER_TOKEN=

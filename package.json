{
  "name": "paso-chile-hoy",
  "type": "module",
  "version": "2.5.9",
  "private": true,
  "description": "Web informativa del estado de pasos fronterizos Argentina–Chile (base frontend).",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "sync": "git pull --rebase origin main",
    "prescrape": "git pull --rebase origin main || true",
    "scrape": "tsx scripts/scrape.ts",
    "twitter:update": "tsx scripts/update-latest-tweet.ts",
    "debug:pass": "node scripts/debug-pass.mjs",
    "update:pass": "node scripts/update-pass.mjs",
    "update:all-passes": "node scripts/update-all-passes.mjs",
    "c": "bash scripts/c.sh",
    "commit": "cz",
    "c:feat": "git add . && git commit -m",
    "c:fix": "git add . && git commit -m",
    "c:chore": "git add . && git commit -m",
    "c:style": "git add . && git commit -m",
    "c:refactor": "git add . && git commit -m",
    "c:perf": "git add . && git commit -m",
    "c:docs": "git add . && git commit -m",
    "prepare": "husky"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "dependencies": {
    "@astrojs/tailwind": "^5.1.4",
    "@astrojs/vercel": "^7.8.2",
    "@iconify-json/lucide": "^1.2.101",
    "@iconify-json/wi": "^1.2.1",
    "@upstash/redis": "^1.37.0",
    "astro": "^4.16.18",
    "astro-icon": "^1.1.5",
    "node-html-parser": "^7.1.0",
    "tailwindcss": "^3.4.17"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.6",
    "@semantic-release/npm": "^12.0.2",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/node": "^20.19.0",
    "commitizen": "^4.3.1",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "semantic-release": "^24.2.9",
    "tsx": "^4.19.3",
    "typescript": "^5.7.2",
    "undici": "^5.28.4"
  },
  "engines": {
    "node": "20.x"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.14.0",
    "@rollup/rollup-linux-x64-musl": "^4.14.0"
  },
  "overrides": {
    "rollup": "^4.14.0"
  }
}

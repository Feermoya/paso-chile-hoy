---
export const prerender = false;

import HomeLatestTweetCard from "@/components/home/HomeLatestTweetCard.astro";
import HomeLatestTweetFallback from "@/components/home/HomeLatestTweetFallback.astro";
import PasoCard from "@/components/PasoCard.astro";
import StatusGuide from "@/components/StatusGuide.astro";
import SupportBlock from "@/components/SupportBlock.astro";
import { PASOS } from "@/data/pasos";
import MainLayout from "@/layouts/MainLayout.astro";
import { mapPersistedSnapshotToView } from "@/lib/mappers/passViewMapper";
import { getSnapshotForApi } from "@/lib/server/services/snapshotService";
import { buildHomeMeta, SITE_URL } from "@/utils/seo";
import type { PassDisplayStatus } from "@/utils/inferPassStatus";
import { inferPassStatus } from "@/utils/inferPassStatus";
import { readHomeLatestTweetFromSnapshot } from "@/lib/server/social/twitterSnapshotFile";

const latestTweet = readHomeLatestTweetFromSnapshot();

type CardEntry = {
  slug: string;
  status?: PassDisplayStatus;
  displayLabel?: string;
  closesInMinutes?: number;
  opensInMinutes?: number;
  weatherDesc?: string;
  weatherTempC?: number | null;
  vialidadEstado?: string;
  vialidadObservaciones?: string;
};

const cards: CardEntry[] = await Promise.all(
  PASOS.map(async (paso) => {
    if (!paso.active) {
      return { slug: paso.slug };
    }
    try {
      const raw = await getSnapshotForApi(paso.slug);
      const view = mapPersistedSnapshotToView(raw, paso);
      const n = view.weather?.now;
      const op = view.operationalInfo;
      const statusResult = inferPassStatus(view);
      return {
        slug: paso.slug,
        status: statusResult.status,
        displayLabel: statusResult.displayLabel,
        closesInMinutes: statusResult.closesInMinutes,
        opensInMinutes: statusResult.opensInMinutes,
        weatherDesc: n?.description?.trim(),
        weatherTempC: n?.temperatureC ?? null,
        vialidadEstado: op.vialidadEstado,
        vialidadObservaciones: op.vialidadObservaciones,
      };
    } catch {
      return { slug: paso.slug, status: "sin_datos" };
    }
  }),
);

const cardBySlug = new Map(cards.map((c) => [c.slug, c]));

const meta = buildHomeMeta();

const homeSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Pasos internacionales Argentina y Chile",
  description:
    "Lista de pasos internacionales entre Argentina y Chile (Mendoza, San Juan) con estado en tiempo real.",
  numberOfItems: PASOS.filter((p) => p.active).length,
  itemListElement: PASOS.filter((p) => p.active).map((paso, i) => ({
    "@type": "ListItem",
    position: i + 1,
    name: paso.name,
    url: `${SITE_URL}/${paso.slug}`,
  })),
};
---

<MainLayout {...meta} structuredData={homeSchema}>
  <div class="home-layout">
    <div class="home-hero">
      <div class="home-hero-brand">
        <div class="home-hero-logo-wrap">
          <img
            src="/logo.png"
            alt="Paso Chile Hoy"
            class="home-hero-logo"
            loading="eager"
            decoding="async"
          />
        </div>
        <div class="home-hero-text">
          <h1 class="home-hero-title">Está abierto el paso a Chile?</h1>
          <p class="home-hero-subtitle">
            Estado en tiempo real del Cristo Redentor, Pehuenche y Agua Negra: pasos entre Argentina y
            Chile. Antes de salir, revisá el horario, el clima y las condiciones de la ruta.
          </p>
        </div>
      </div>
    </div>

    <p class="cards-hint">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <circle cx="12" cy="12" r="10"></circle>
        <path d="M12 8v4m0 4h.01"></path>
      </svg>
      Tocá cualquier paso para ver el estado completo, clima y alertas
    </p>

    <StatusGuide />

    <div class="pasos-grid pcv2-cards-grid">
      {PASOS.map((paso) => {
        const c = cardBySlug.get(paso.slug);
        return (
          <PasoCard
            paso={paso}
            status={c?.status}
            displayLabel={c?.displayLabel}
            closesInMinutes={c?.closesInMinutes}
            opensInMinutes={c?.opensInMinutes}
            weatherDesc={c?.weatherDesc}
            weatherTempC={c?.weatherTempC}
            vialidadEstado={c?.vialidadEstado}
            vialidadObservaciones={c?.vialidadObservaciones}
          />
        );
      })}
    </div>

    <section class="home-twitter" aria-label="Últimas novedades">
      <p class="section-label">Últimas novedades de @PasoCRMza</p>
      {latestTweet ? <HomeLatestTweetCard tweet={latestTweet} /> : <HomeLatestTweetFallback />}
    </section>
  </div>

  <SupportBlock />

  <section class="seo-content seo-content--home" aria-label="Información sobre los pasos a Chile">
    <h2>Pasos internacionales entre Argentina y Chile</h2>
    <p>
      Paso Chile Hoy muestra el estado en tiempo real de pasos internacionales entre Argentina y Chile,
      incluyendo el <strong>Paso Sistema Cristo Redentor</strong> (también
      conocido como Paso Los Libertadores) entre Mendoza y la región de Valparaíso, el{" "}
      <strong>Paso Pehuenche</strong> conectando Malargüe con Talca, y el <strong>Paso Agua Negra</strong>{" "}
      entre San Juan y la región de Coquimbo.
    </p>
    <p>
      El estado del paso, su horario de funcionamiento, las condiciones climáticas y las alertas de
      Vialidad Nacional y Gendarmería Nacional se actualizan automáticamente desde la fuente oficial del
      Ministerio de Seguridad de la Nación Argentina.
    </p>
    <h3>¿Cuándo está abierto el Paso Cristo Redentor?</h3>
    <p>
      El horario habitual es de 09:00 a 21:00 h desde el lado argentino. Durante el verano puede operar
      las 24 horas. El paso puede cerrarse sin previo aviso por nevadas, vientos fuertes o condiciones
      meteorológicas adversas en la alta montaña.
    </p>
    <h3>Otros pasos</h3>
    <p>
      El <strong>Paso Pehuenche</strong> conecta Malargüe (Mendoza) con Talca y el{" "}
      <strong>Paso Agua Negra</strong> une Las Flores (San Juan) con Huanta. Los horarios y condiciones
      pueden variar según la temporada y el estado de la ruta.
    </p>
  </section>
</MainLayout>

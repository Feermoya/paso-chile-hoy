---
export const prerender = false;

import PasoCard from "@/components/PasoCard.astro";
import StatusGuide from "@/components/StatusGuide.astro";
import SupportBlock from "@/components/SupportBlock.astro";
import { PASOS } from "@/data/pasos";
import MainLayout from "@/layouts/MainLayout.astro";
import { mapPersistedSnapshotToView } from "@/lib/mappers/passViewMapper";
import { getSnapshotForApi } from "@/lib/server/services/snapshotService";
import { buildHomeMeta, SITE_URL } from "@/utils/seo";
import type { PassDisplayStatus } from "@/utils/inferPassStatus";
import HomeRouteSegmentsCard from "@/components/HomeRouteSegmentsCard.astro";
import TwitterTimeline from "@/components/TwitterTimeline.astro";
import LasLenasHomeBlock from "@/components/LasLenasHomeBlock.astro";
import { getLasLenasSnapshot } from "@/lib/server/las-lenas/getLasLenasSnapshot";
import { buildHomeRouteCardView } from "@/lib/mappers/homeRouteCardView";
import { HOME_ROUTE_CARD_ORDER, getRouteProfile } from "@/lib/server/route-segments/profiles";
import { readRouteSegments } from "@/lib/server/storage/routeSegmentsStorage";
import { inferPassStatus } from "@/utils/inferPassStatus";
import { formatRelativeTimeAgo } from "@/utils/formatRelativeTime";

type CardEntry = {
  slug: string;
  status?: PassDisplayStatus;
  displayLabel?: string;
  closesInMinutes?: number;
  opensInMinutes?: number;
  weatherDesc?: string;
  weatherTempC?: number | null;
  vialidadEstado?: string;
  vialidadObservaciones?: string;
  scrapedAt?: string;
};

function mostRecentScrapedAt(entries: CardEntry[]): string | undefined {
  let bestT = 0;
  let best: string | undefined;
  for (const e of entries) {
    const s = e.scrapedAt?.trim();
    if (!s) continue;
    const t = new Date(s).getTime();
    if (Number.isFinite(t) && t >= bestT) {
      bestT = t;
      best = s;
    }
  }
  return best;
}

const cards: CardEntry[] = await Promise.all(
  PASOS.map(async (paso) => {
    if (!paso.active) {
      return { slug: paso.slug };
    }
    try {
      const raw = await getSnapshotForApi(paso.slug);
      const view = mapPersistedSnapshotToView(raw, paso);
      const n = view.weather?.now;
      const op = view.operationalInfo;
      const statusResult = inferPassStatus(view);
      return {
        slug: paso.slug,
        status: statusResult.status,
        displayLabel: statusResult.displayLabel,
        closesInMinutes: statusResult.closesInMinutes,
        opensInMinutes: statusResult.opensInMinutes,
        weatherDesc: n?.description?.trim(),
        weatherTempC: n?.temperatureC ?? null,
        vialidadEstado: op.vialidadEstado,
        vialidadObservaciones: op.vialidadObservaciones,
        scrapedAt: raw.scrapedAt?.trim(),
      };
    } catch {
      return { slug: paso.slug, status: "sin_datos" };
    }
  }),
);

const cardBySlug = new Map(cards.map((c) => [c.slug, c]));

const homeLastUpdatedIso = mostRecentScrapedAt(cards);
const homeUpdatedRelative = homeLastUpdatedIso ? formatRelativeTimeAgo(homeLastUpdatedIso) : "";

const homeRouteCards: { view: ReturnType<typeof buildHomeRouteCardView> }[] = [];
for (const profileId of HOME_ROUTE_CARD_ORDER) {
  const cfg = getRouteProfile(profileId);
  if (!cfg) continue;
  const raw = await readRouteSegments(profileId);
  if (!raw) continue;
  homeRouteCards.push({ view: buildHomeRouteCardView(raw, cfg) });
}

const meta = buildHomeMeta();

const lasLenasSnapshot = await getLasLenasSnapshot();

const homeSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Pasos a Chile hoy — Paso Chile Hoy",
  description:
    "Cristo Redentor (Los Libertadores), Pehuenche y Agua Negra: estado del paso, horario y clima desde datos oficiales Argentina. English: main Argentina–Chile border passes.",
  numberOfItems: PASOS.filter((p) => p.active).length,
  itemListElement: PASOS.filter((p) => p.active).map((paso, i) => ({
    "@type": "ListItem",
    position: i + 1,
    name:
      paso.slug === "cristo-redentor"
        ? `${paso.name} — paso Cristo Redentor y Los Libertadores`
        : paso.slug === "pehuenche"
          ? `${paso.name} — Malargüe a Talca`
          : paso.slug === "agua-negra"
            ? `${paso.name} — San Juan a Chile`
            : paso.name,
    item: `${SITE_URL}/${paso.slug}`,
  })),
};
---

<MainLayout {...meta} structuredData={homeSchema}>
  <div class="home-layout">
    <div class="home-hero">
      <h1 class="home-hero-title">¿Está abierto el paso a Chile hoy?</h1>
      <p class="home-hero-subtitle">
        Paso Chile Hoy — Cristo Redentor, Pehuenche y Agua Negra. Consultá si el paso está abierto o
        cerrado, horario y clima en la cordillera.
        Datos desde la fuente pública del Ministerio de Seguridad de la Nación Argentina.
      </p>
      {
        homeLastUpdatedIso && homeUpdatedRelative ? (
          <p class="home-hero-updated">
            <svg
              class="home-hero-updated-icon"
              width="12"
              height="12"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M21 12a9 9 0 0 0-9-9 9.75 9.75 0 0 0-6.74 2.74L3 8" />
              <path d="M3 3v5h5" />
              <path d="M3 12a9 9 0 0 0 9 9 9.75 9.75 0 0 0 6.74-2.74L21 16" />
              <path d="M16 16h5v5" />
            </svg>
            <time class="home-hero-updated-time" datetime={homeLastUpdatedIso}>
              Actualizado {homeUpdatedRelative}
            </time>
          </p>
        ) : null
      }
    </div>

    <p class="cards-hint cards-hint--pill">
      <svg class="cards-hint-touch" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path
          d="M12 3.5c-1.1 0-2 .9-2 2v6.5c0 .3-.2.5-.5.5S9 12.3 9 12V8.5c0-.8-.7-1.5-1.5-1.5S6 7.7 6 8.5v7.8c0 .4-.5.6-.8.3l-1.1-1.1c-.6-.6-1.5-.6-2.1 0s-.6 1.5 0 2.1l4.2 4.2c.4.4.9.6 1.5.6h6.6c1.1 0 2-.9 2-2v-9c0-1.1-.9-2-2-2h-1z"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
        <path d="M15 3.5v4M13 5.5h4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
      </svg>
      <span class="cards-hint-text">Tocá un paso para ver el detalle completo</span>
    </p>

    <div class="home-guide-live-row">
      <StatusGuide />
      <div class="home-live-pill" aria-live="polite">
        <span class="home-live-dot" aria-hidden="true"></span>
        <span class="home-live-label">Datos oficiales</span>
      </div>
    </div>

    <div class="pasos-grid pcv2-cards-grid">
      {PASOS.map((paso) => {
        const c = cardBySlug.get(paso.slug);
        return (
          <PasoCard
            paso={paso}
            status={c?.status}
            displayLabel={c?.displayLabel}
            closesInMinutes={c?.closesInMinutes}
            opensInMinutes={c?.opensInMinutes}
            weatherDesc={c?.weatherDesc}
            weatherTempC={c?.weatherTempC}
            vialidadEstado={c?.vialidadEstado}
            vialidadObservaciones={c?.vialidadObservaciones}
          />
        );
      })}
    </div>

    {
      homeRouteCards.length > 0 ? (
        <section class="rutas-section" aria-labelledby="rutas-title">
          <div class="rutas-section-header">
            <div class="rutas-section-title-group">
              <h2 id="rutas-title" class="rutas-section-title">
                Estado de rutas
              </h2>
              <p class="rutas-section-sub">
                Información oficial de Vialidad Nacional; puede demorar en reflejar cambios en ruta.
              </p>
            </div>
            <div class="rutas-section-meta">
              <span class="rutas-source-dot" aria-hidden="true" />
              <span class="rutas-source-label">Fuente: Vialidad Nacional</span>
            </div>
          </div>
          <div class="rutas-grid">
            {homeRouteCards.map(({ view }) => (
              <HomeRouteSegmentsCard view={view} />
            ))}
          </div>
        </section>
      ) : null
    }

    {lasLenasSnapshot ? <LasLenasHomeBlock snapshot={lasLenasSnapshot} /> : null}

    <TwitterTimeline />
  </div>

  <SupportBlock />

  <section class="seo-content seo-content--home" aria-label="Información sobre los pasos a Chile">
    <h2>Paso Chile Hoy — pasos internacionales Mendoza y San Juan</h2>
    <p>
      Acá podés ver el <strong>estado del paso a Chile hoy</strong> para los tres cruces principales
      desde el oeste argentino: el <strong>Paso Cristo Redentor</strong> (Sistema Cristo Redentor, también
      llamado <strong>Paso Los Libertadores</strong>) entre Mendoza y la región de Valparaíso, el{" "}
      <strong>Paso Pehuenche</strong> entre Malargüe y Talca, y el <strong>Paso Agua Negra</strong> entre
      Las Flores (San Juan) y Huanta (Chile). Si buscás <em>paso a Chile Mendoza</em> o{" "}
      <em>pasos a Chile hoy</em>, esta es la página de referencia de la marca Paso Chile Hoy.
    </p>
    <p>
      El sitio resume horario, clima en alta montaña y alertas a partir del mismo tipo de información
      pública que publica el Ministerio de Seguridad de la Nación Argentina (Gendarmería, Vialidad
      Nacional, Servicio Meteorológico). No reemplaza la consulta directa con la fuente oficial antes de
      viajar. <span lang="en">Travelers searching in English: this site summarizes whether major
      Argentina–Chile border passes (Christ the Redeemer / Los Libertadores, Pehuenche, Agua Negra) are
      open or closed, with schedule and weather from official Argentine public data.</span>
    </p>
    <h3>Estado y horario del Paso Cristo Redentor (Los Libertadores)</h3>
    <p>
      El <strong>paso Cristo Redentor</strong> es el más usado entre Mendoza y Chile. El horario habitual
      desde Argentina suele ser de 09:00 a 21:00 h; en temporada alta a veces opera 24 horas. El cruce
      puede cerrar por nieve, viento o condiciones en ruta: conviene revisar el detalle del paso en esta
      web y confirmar en Gendarmería o en la página oficial del paso.
    </p>
    <h3>Paso Pehuenche y Paso Agua Negra</h3>
    <p>
      El <strong>Paso Pehuenche</strong> une Malargüe con Talca; el <strong>Paso Agua Negra</strong> une
      Las Flores (San Juan) con el lado chileno. Los horarios y el estado del paso dependen de la temporada
      y del estado de la ruta en la cordillera.
    </p>
  </section>
</MainLayout>

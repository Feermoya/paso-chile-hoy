---
import PasoCard from "@/components/PasoCard.astro";
import { PASOS } from "@/data/pasos";
import { mapPassRawToView } from "@/lib/mappers/passViewMapper";
import { getSnapshotForApi } from "@/lib/server/services/snapshotService";
import MainLayout from "@/layouts/MainLayout.astro";
import type { PassDisplayStatus } from "@/utils/inferPassStatus";
import { inferPassStatus } from "@/utils/inferPassStatus";

type CardEntry = {
  slug: string;
  status?: PassDisplayStatus;
};

const cards: CardEntry[] = await Promise.all(
  PASOS.map(async (paso) => {
    if (!paso.active) {
      return { slug: paso.slug };
    }
    try {
      const raw = await getSnapshotForApi(paso.slug);
      const view = mapPassRawToView(raw);
      return { slug: paso.slug, status: inferPassStatus(view).status };
    } catch {
      return { slug: paso.slug, status: "sin_datos" };
    }
  }),
);

const statusBySlug = new Map(cards.map((c) => [c.slug, c.status]));
---

<MainLayout
  title="Paso Chile Hoy — Estado de pasos internacionales"
  description="Estado inferido y clima de los pasos internacionales Mendoza–Chile. Datos públicos de Argentina.gob.ar."
  canonicalPath="/"
>
  <div class="home-layout">
    <div class="home-header">
      <h1 class="text-section-title">Pasos a Chile</h1>
      <p class="mt-1 text-sm text-[var(--color-text-muted)]">Mendoza · Pasos internacionales con Chile</p>
    </div>

    <div class="pasos-grid">
      {PASOS.map((paso) => (
        <PasoCard paso={paso} status={statusBySlug.get(paso.slug)} />
      ))}
    </div>
  </div>
</MainLayout>

---
import InfoCard from "@/components/ui/InfoCard.astro";
import SectionTitle from "@/components/ui/SectionTitle.astro";
import AlertList from "@/components/pass-status/AlertList.astro";
import RequirementsList from "@/components/pass-status/RequirementsList.astro";
import StatusHero from "@/components/pass-status/StatusHero.astro";
import { cristoRedentorSnapshot } from "@/data/mock-passes";
import MainLayout from "@/layouts/MainLayout.astro";
import { confidenceLabel } from "@/utils/pass-ui";

const snapshot = cristoRedentorSnapshot;
const { weather } = snapshot;
---

<MainLayout
  title="Inicio"
  description="Estado referencial del Paso Cristo Redentor / Los Libertadores, clima resumido, alertas y requisitos (datos mock)."
>
  <div class="flex flex-col gap-12 md:gap-16 lg:gap-20">
    <StatusHero snapshot={snapshot} />

    <section aria-labelledby="resumen-cards">
      <h2 id="resumen-cards" class="sr-only">Resumen rápido</h2>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 lg:gap-5">
        <InfoCard title="Clima en zona de paso" eyebrow="Ambiente">
          <p>
            <span class="font-medium text-ink">{weather.conditions}</span>
          </p>
          <dl class="mt-3 space-y-1 text-sm">
            <div class="flex justify-between gap-4">
              <dt>Temperatura</dt>
              <dd class="font-medium text-ink">{weather.temperatureC}°C</dd>
            </div>
            {weather.feelsLikeC != null && (
              <div class="flex justify-between gap-4">
                <dt>Sensación</dt>
                <dd class="font-medium text-ink">{weather.feelsLikeC}°C</dd>
              </div>
            )}
            {weather.windKmh != null && (
              <div class="flex justify-between gap-4">
                <dt>Viento</dt>
                <dd class="font-medium text-ink">{weather.windKmh} km/h</dd>
              </div>
            )}
            {weather.visibilityKm != null && (
              <div class="flex justify-between gap-4">
                <dt>Visibilidad</dt>
                <dd class="font-medium text-ink">{weather.visibilityKm} km</dd>
              </div>
            )}
          </dl>
        </InfoCard>

        <InfoCard title="Horario" eyebrow="Referencia">
          <p>{snapshot.scheduleSummary}</p>
        </InfoCard>

        <InfoCard title="Confianza del dato" eyebrow="Calidad" className="sm:col-span-2 lg:col-span-1">
          <p>
            Nivel <span class="font-medium text-ink">{confidenceLabel(snapshot.confidence)}</span>: información
            simulada para desarrollo. La versión final priorizará fuentes oficiales y timestamp verificable.
          </p>
        </InfoCard>
      </div>
    </section>

    <section aria-labelledby="alertas-titulo">
      <SectionTitle
        id="alertas-titulo"
        title="Alertas recientes"
        subtitle="Avisos orientativos basados en el mock actual. No sustituyen comunicados de autoridades."
      />
      <AlertList alerts={snapshot.alerts} />
    </section>

    <section aria-labelledby="requisitos-titulo">
      <SectionTitle
        id="requisitos-titulo"
        title="Requisitos para cruzar"
        subtitle="Lista general de referencia. Confirmá documentación y normativa vigente antes del viaje."
      />
      <RequirementsList requirements={snapshot.requirements} />
    </section>
  </div>
</MainLayout>

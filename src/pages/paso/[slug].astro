---
import AlertsBlock from "@/components/AlertsBlock.astro";
import PassDetails from "@/components/PassDetails.astro";
import StatusHero from "@/components/StatusHero.astro";
import WeatherForecast from "@/components/WeatherForecast.astro";
import WeatherNow from "@/components/WeatherNow.astro";
import { getActivePasos, getPasoBySlug } from "@/data/pasos";
import { mapPassRawToView } from "@/lib/mappers/passViewMapper";
import { getSnapshotForApi } from "@/lib/server/services/snapshotService";
import { logPassPipelineDebug } from "@/lib/server/utils/passDebugLog";
import MainLayout from "@/layouts/MainLayout.astro";
import type { PassView } from "@/types/pass-view";
import { formatRelativeTimeAgo } from "@/utils/formatRelativeTime";
import { inferPassStatus } from "@/utils/inferPassStatus";
import { weatherNowHasDisplayableContent } from "@/utils/passViewGuards";

export async function getStaticPaths() {
  return getActivePasos().map((p) => ({ params: { slug: p.slug } }));
}

const slug = Astro.params.slug ?? "";
const pasoConfig = getPasoBySlug(slug);

if (!pasoConfig || !pasoConfig.active) {
  return new Response(null, { status: 404, statusText: "Not Found" });
}

function heroSchedule(v: PassView): string {
  const o = v.operationalInfo;
  const raw = o.schedule?.trim();
  if (raw) return raw.replace(/^horario:\s*/i, "").trim();
  if (o.scheduleFrom && o.scheduleTo) return `${o.scheduleFrom}–${o.scheduleTo} h`;
  return "";
}

let view: PassView | null = null;
let loadError: string | null = null;

try {
  const raw = await getSnapshotForApi(slug);
  view = mapPassRawToView(raw);
  logPassPipelineDebug(`paso/${slug}`, { raw, view });
} catch (e) {
  loadError = e instanceof Error ? e.message : "Error al cargar el paso";
}

const w = view?.weather;
const now = w?.now;
const forecast = w?.forecast ?? [];
const showNow = Boolean(now && weatherNowHasDisplayableContent(now));
const showForecast = forecast.length > 0;

const displayStatus = view ? inferPassStatus(view) : null;
const scheduleText = view ? heroSchedule(view) : "";
const lastRel = view?.meta.scrapedAt ? formatRelativeTimeAgo(view.meta.scrapedAt) : "";
const officialUrl = view?.meta.sourceUrl;

const pageTitle = pasoConfig.shortName;
const pageDescription = `Estado inferido, clima y datos de ${pasoConfig.name} según Argentina.gob.ar. Verificá siempre la fuente oficial.`;
---

<MainLayout
  title={pageTitle}
  description={pageDescription}
  canonicalPath={`/paso/${slug}`}
  headerAltitudeM={pasoConfig.altitudeM}
>
  <div class="flex w-full min-w-0 flex-col gap-4 md:gap-6">
    {loadError && (
      <div class="container-main">
        <div
          class="rounded-[var(--radius-xl)] border border-[var(--color-border-default)] bg-surface-raised p-6 shadow-card sm:p-8"
          role="alert"
        >
          <p class="font-display text-lg font-semibold text-ink">No se pudieron cargar los datos del paso</p>
          <p class="mt-2 text-sm text-ink-muted">{loadError}</p>
          <p class="mt-4 text-sm leading-relaxed text-ink-muted">
            Generá datos con{" "}
            <code class="rounded-[var(--radius-sm)] bg-surface px-2 py-0.5 font-mono text-xs text-ink">
              npm run update:pass -- {slug}
            </code>
            .
          </p>
        </div>
      </div>
    )}

    {view && (
      <div class="page-layout">
        <div class="col-main flex min-w-0 flex-col gap-4 md:gap-6">
          {displayStatus && (
            <StatusHero
              class="anim-section anim-delay-1"
              status={displayStatus}
              passName={view.title}
              schedule={scheduleText}
              lastUpdatedRelative={lastRel}
              officialUrl={officialUrl}
            />
          )}

          {showNow && now && (
            <>
              <div class="section-divider anim-section anim-delay-2" aria-hidden="true"></div>
              <WeatherNow
                class="anim-section anim-delay-2"
                weather={now}
                updatedAt={now.providerNote}
                altitudeM={pasoConfig.altitudeM}
              />
            </>
          )}

          <AlertsBlock class="anim-section anim-delay-3" alerts={view.alerts} />
        </div>

        <div class="col-side flex min-w-0 flex-col gap-4 md:gap-6">
          {showForecast && (
            <section class="anim-section anim-delay-2 space-y-4" aria-labelledby="forecast-heading">
              <h2 id="forecast-heading" class="text-section-title">
                Próximas horas
              </h2>
              <WeatherForecast class="anim-section anim-delay-3" forecast={forecast} />
            </section>
          )}

          <PassDetails class="anim-section anim-delay-5" view={view} />
        </div>
      </div>
    )}
  </div>
</MainLayout>

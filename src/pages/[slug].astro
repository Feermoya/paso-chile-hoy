---
import AlertsBlock from "@/components/AlertsBlock.astro";
import DrivingConditions from "@/components/DrivingConditions.astro";
import LatestTweet from "@/components/LatestTweet.astro";
import StatusGuide from "@/components/StatusGuide.astro";
import VersionBadge from "@/components/VersionBadge.astro";
import PassDetails from "@/components/PassDetails.astro";
import StatusHero from "@/components/StatusHero.astro";
import SupportBlock from "@/components/SupportBlock.astro";
import TwitterAlerts from "@/components/TwitterAlerts.astro";
import WeatherForecast from "@/components/WeatherForecast.astro";
import WeatherNow from "@/components/WeatherNow.astro";
import { buildArgentinaPassSourceUrl, getPasoBySlug } from "@/data/pasos";
import { mapPersistedSnapshotToView } from "@/lib/mappers/passViewMapper";
import { getSnapshotForApi } from "@/lib/server/services/snapshotService";
import { logPassPipelineDebug } from "@/lib/server/utils/passDebugLog";
import MainLayout from "@/layouts/MainLayout.astro";
import type { PassView, WeatherNowView } from "@/types/pass-view";
import type { DrivingWeatherInput } from "@/utils/drivingConditions";
import { formatRelativeTimeAgo } from "@/utils/formatRelativeTime";
import { heroScheduleFromView } from "@/utils/heroScheduleFromView";
import { inferPassStatus } from "@/utils/inferPassStatus";
import { weatherNowHasDisplayableContent } from "@/utils/passViewGuards";
import {
  buildPassPageMeta,
  passAlternateNames,
  SITE_URL,
  type PassStatus,
} from "@/utils/seo";

export const prerender = false;

const slug = Astro.params.slug ?? "";
const pasoConfig = getPasoBySlug(slug);

if (!pasoConfig || !pasoConfig.active) {
  return new Response(null, { status: 404, statusText: "Not Found" });
}

let view: PassView | null = null;
let snapshotLoadFailed = false;

try {
  const raw = await getSnapshotForApi(slug);
  view = mapPersistedSnapshotToView(raw, pasoConfig);
  logPassPipelineDebug(`/${slug}`, { raw, view });
} catch (e) {
  console.error(`[page] Failed to load snapshot for ${slug}:`, e);
  snapshotLoadFailed = true;
}

const officialPassUrl = buildArgentinaPassSourceUrl(pasoConfig);

const w = view?.weather;
const now = w?.now;
const forecast = w?.forecast ?? [];
const showNow = Boolean(now && weatherNowHasDisplayableContent(now));
const showForecast = forecast.length > 0;

const scheduleText = view ? heroScheduleFromView(view) : "";
const statusResult = view ? inferPassStatus(view) : null;
const lastRel = view?.meta.scrapedAt ? formatRelativeTimeAgo(view.meta.scrapedAt) : "";
const officialUrl = view?.meta.sourceUrl;

if (import.meta.env.DEV && view && statusResult) {
  console.log("=== PASO STATUS DEBUG ===");
  console.log(
    "Hora Argentina actual:",
    new Date().toLocaleString("es-AR", { timeZone: "America/Argentina/Buenos_Aires" }),
  );
  console.log("Schedule (UI):", scheduleText);
  console.log("ScrapedAt:", view.meta.scrapedAt);
  console.log("Motivo / vialidad:", view.operationalInfo.motivo, view.operationalInfo.vialidadEstado);
  console.log("Status inferido:", statusResult.status);
  console.log("Razón:", statusResult.reason);
  console.log("Confidence:", statusResult.confidence);
  console.log("opensInMinutes:", statusResult.opensInMinutes);
  console.log("closesInMinutes:", statusResult.closesInMinutes);
  console.log("=========================");
}

const displayStatus = (statusResult?.status ?? "sin_datos") as PassStatus;

const scheduleForMeta = scheduleText
  ? scheduleText.replace(/\s+h\.?\s*$/i, "").trim() || null
  : null;

const tempC =
  now?.temperatureC != null && Number.isFinite(now.temperatureC) ? now.temperatureC : null;
const weatherDescMeta = now?.description?.trim() || null;

const freshnessLabel = lastRel || "cuando hay datos nuevos";

const regionLabelForMeta =
  pasoConfig.provinceAR === "San Juan" ? "San Juan, Argentina" : "Mendoza, Argentina";
const headerRegionLabel = pasoConfig.provinceAR === "San Juan" ? "San Juan · AR" : "Mendoza · AR";
const geoRegionCode = pasoConfig.provinceAR === "San Juan" ? "AR-J" : "AR-M";
const geoPlacename = regionLabelForMeta;
const geoPositionMeta = `${pasoConfig.lat};${pasoConfig.lng}`;

const meta = buildPassPageMeta({
  passName: pasoConfig.name,
  passSlug: pasoConfig.slug,
  status: displayStatus,
  schedule: scheduleForMeta,
  tempC,
  weatherDesc: weatherDescMeta,
  freshnessLabel,
  regionLabel: regionLabelForMeta,
});

function openingHoursSpecs(schedule: string): Array<Record<string, unknown>> {
  const s = schedule.trim();
  if (!s) return [];
  const cleaned = s.replace(/\s*h\.?\s*$/i, "").trim();
  const parts = cleaned.split(/[-–]/).map((p) => p.trim()).filter(Boolean);
  if (parts.length < 2 || !parts[0] || !parts[1]) return [];
  return [
    {
      "@type": "OpeningHoursSpecification",
      opens: parts[0],
      closes: parts[1],
      dayOfWeek: [
        "Monday",
        "Tuesday",
        "Wednesday",
        "Thursday",
        "Friday",
        "Saturday",
        "Sunday",
      ],
    },
  ];
}

function buildDrivingWeatherInput(now: WeatherNowView): DrivingWeatherInput {
  const visInput: number | string | null =
    typeof now.visibilityKm === "number"
      ? now.visibilityKm
      : now.visibilityText?.trim()
        ? now.visibilityText.trim()
        : null;
  return {
    temperatureC: now.temperatureC ?? null,
    wind: now.wind ?? null,
    visibilityKm: visInput,
    description: now.description ?? "",
  };
}

const passSchema: Record<string, unknown> = {
  "@context": "https://schema.org",
  "@type": "TouristAttraction",
  name: pasoConfig.name,
  alternateName: passAlternateNames(pasoConfig.slug, pasoConfig.shortName, pasoConfig.name),
  description: `Paso internacional entre ${pasoConfig.localityAR} (Argentina) y ${pasoConfig.localityCL} (Chile). Estado en tiempo real del cruce fronterizo.`,
  url: `${SITE_URL}/${pasoConfig.slug}`,
  image: `${SITE_URL}/og-image.png`,
  geo: {
    "@type": "GeoCoordinates",
    latitude: pasoConfig.lat,
    longitude: pasoConfig.lng,
    elevation: pasoConfig.altitudeM,
  },
  address: {
    "@type": "PostalAddress",
    addressLocality: pasoConfig.localityAR,
    addressRegion: pasoConfig.provinceAR,
    addressCountry: "AR",
  },
  openingHoursSpecification: openingHoursSpecs(scheduleText),
  ...(displayStatus !== "sin_datos" && {
    offers: {
      "@type": "Offer",
      name: `Estado actual: ${displayStatus}`,
      availability:
        displayStatus === "abierto"
          ? "https://schema.org/InStock"
          : "https://schema.org/OutOfStock",
    },
  }),
};
---

<MainLayout
  title={meta.title}
  description={meta.description}
  ogTitle={meta.ogTitle}
  ogDescription={meta.ogDescription}
  ogImage={meta.ogImage}
  canonical={meta.canonical}
  structuredData={passSchema}
  headerAltitudeM={pasoConfig.altitudeM}
  headerRegionLabel={headerRegionLabel}
  geoRegionCode={geoRegionCode}
  geoPlacename={geoPlacename}
  geoPosition={geoPositionMeta}
>
  <div class="flex w-full min-w-0 flex-col gap-4 md:gap-6">
    <div class="container-main flex justify-end sm:hidden">
      <VersionBadge compact />
    </div>
    {snapshotLoadFailed && (
      <div class="container-main">
        <div
          class="rounded-[var(--radius-xl)] border border-[var(--color-border-default)] bg-surface-raised p-6 shadow-card sm:p-8"
          role="alert"
        >
          <h2 class="font-display text-lg font-semibold text-ink">Datos temporalmente no disponibles</h2>
          <p class="mt-2 text-sm leading-relaxed text-ink-muted">
            No pudimos obtener la información del paso en este momento. Podés verificar el estado en la fuente
            oficial.
          </p>
          <p class="mt-4">
            <a
              href={officialPassUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="link-branded text-sm font-semibold"
            >
              Ver en la fuente oficial →
            </a>
          </p>
          {import.meta.env.DEV && (
            <p class="mt-4 text-xs leading-relaxed text-ink-muted">
              Desarrollo: generá snapshot con{" "}
              <code class="rounded-[var(--radius-sm)] bg-surface px-2 py-0.5 font-mono text-ink">
                npm run update:pass -- {slug}
              </code>
              .
            </p>
          )}
        </div>
      </div>
    )}

    {view && (
      <div class="paso-page-wrapper">
        <div class="paso-grid">
          <section class="paso-col" aria-label="Estado operativo">
            {statusResult && (
              <StatusHero
                class="anim-section anim-delay-1"
                slug={slug}
                status={statusResult.status}
                displayLabel={statusResult.displayLabel}
                passName={view.title}
                schedule={scheduleText}
                lastUpdatedRelative={lastRel}
                officialUrl={officialUrl}
                opensInMinutes={statusResult.opensInMinutes}
                closesInMinutes={statusResult.closesInMinutes}
              />
            )}

            <StatusGuide />

            <AlertsBlock
              class="anim-section anim-delay-2"
              motivo={view.operationalInfo.motivo ?? null}
              vialidadRuta={view.operationalInfo.vialidadRuta ?? ""}
              vialidadTramo={view.operationalInfo.vialidadTramo ?? ""}
              vialidadEstado={view.operationalInfo.vialidadEstado ?? "HABILITADA"}
              vialidadObservaciones={view.operationalInfo.vialidadObservaciones ?? ""}
            />

            <LatestTweet tweet={view.meta.latestTweet} />

            <TwitterAlerts passSlug={slug} />
          </section>

          <section class="paso-col paso-col--sticky" aria-label="Condiciones climáticas">
            {showNow && now && (
              <WeatherNow
                class="anim-section anim-delay-3"
                weather={now}
                forecast={forecast}
                updatedAt={now.providerNote}
                scrapedAt={view.meta.scrapedAt}
                includeDriving={false}
              />
            )}

            {showForecast && (
              <WeatherForecast class="anim-section anim-delay-2" forecast={forecast} />
            )}
          </section>
        </div>

        <div class="paso-fullwidth">
          {showNow && now && (
            <DrivingConditions
              class="anim-section anim-delay-3"
              weather={buildDrivingWeatherInput(now)}
              forecast={forecast}
            />
          )}

          <PassDetails class="anim-section anim-delay-5" view={view} />

          <SupportBlock />
        </div>
      </div>
    )}
  </div>

  <section class="seo-content seo-content--pass">
    <h2>Sobre el {pasoConfig.name}</h2>
    <p>
      El {pasoConfig.name} conecta {pasoConfig.localityAR} ({pasoConfig.provinceAR},
      Argentina) con {pasoConfig.localityCL} (Chile). Se encuentra a{" "}
      {pasoConfig.altitudeM.toLocaleString("es-AR")} metros sobre el nivel del mar en la Cordillera de
      los Andes.
    </p>
    <p>
      Esta página muestra el estado actual del paso según el mismo API público que usa el sitio oficial del
      Ministerio de Seguridad de la Nación Argentina. La información se actualiza automáticamente.
    </p>
  </section>
</MainLayout>

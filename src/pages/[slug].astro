---
import PasoPageLoadError from "@/components/pass-page/PasoPageLoadError.astro";
import PasoPageSeoBlock from "@/components/pass-page/PasoPageSeoBlock.astro";
import PasoPageShell from "@/components/pass-page/PasoPageShell.astro";
import PasoPageVersionRow from "@/components/pass-page/PasoPageVersionRow.astro";
import { buildArgentinaPassSourceUrl, getPasoBySlug } from "@/data/pasos";
import { buildPassRefreshPayload } from "@/lib/server/passRefreshPayload";
import { getSnapshotForApi } from "@/lib/server/services/snapshotService";
import { logPassPipelineDebug } from "@/lib/server/utils/passDebugLog";
import MainLayout from "@/layouts/MainLayout.astro";
import type { PassView } from "@/types/pass-view";
import { buildPassTouristAttractionSchema } from "@/utils/passPageSchema";
import type { PassStatusResult } from "@/utils/inferPassStatus";
import { buildPassPageMeta, type PassStatus } from "@/utils/seo";

export const prerender = false;

const slug = Astro.params.slug ?? "";
const pasoConfig = getPasoBySlug(slug);

if (!pasoConfig || !pasoConfig.active) {
  return new Response(null, { status: 404, statusText: "Not Found" });
}

let view: PassView | null = null;
let snapshotLoadFailed = false;
let scheduleText = "";
let statusResult: PassStatusResult | null = null;
let lastRel = "";
let officialUrl: string | undefined;
let showNow = false;
let showForecast = false;
let hideScheduleInDetails = false;

try {
  const raw = await getSnapshotForApi(slug);
  const payload = buildPassRefreshPayload(raw, pasoConfig);
  view = payload.view;
  scheduleText = payload.scheduleText;
  statusResult = payload.statusResult;
  lastRel = payload.lastUpdatedRelative;
  officialUrl = payload.officialUrl;
  showNow = payload.showNow;
  showForecast = payload.showForecast;
  hideScheduleInDetails = payload.hideScheduleInDetails;
  logPassPipelineDebug(`/${slug}`, { raw, view });
} catch (e) {
  console.error(`[page] Failed to load snapshot for ${slug}:`, e);
  snapshotLoadFailed = true;
}

const officialPassUrl = buildArgentinaPassSourceUrl(pasoConfig);

const w = view?.weather;
const now = w?.now;
const forecast = w?.forecast ?? [];

const debugPass =
  import.meta.env.DEV || (typeof process !== "undefined" && process.env.DEBUG_PASS === "true");

if (debugPass && view && statusResult) {
  console.log(`\n=== DEBUG ${slug.toUpperCase()} ===`);
  console.log("Snapshot scrapedAt:", view.meta?.scrapedAt ?? "N/A");
  console.log("rawStatus (del JSON):", view.operationalInfo?.rawStatus ?? "N/A");
  console.log("vialidadEstado:", view.operationalInfo?.vialidadEstado ?? "N/A");
  console.log("motivo:", view.operationalInfo?.motivo ?? "N/A");
  console.log("Status inferido:", statusResult.status);
  console.log("displayLabel:", statusResult.displayLabel ?? "N/A");
  console.log("Source:", statusResult.source ?? "N/A");
  console.log("Razón:", statusResult.reason);
  console.log("Confidence:", statusResult.confidence);
  console.log("opensInMinutes:", statusResult.opensInMinutes ?? "N/A");
  console.log("closesInMinutes:", statusResult.closesInMinutes ?? "N/A");
  console.log("===================\n");
}

const displayStatus = (statusResult?.status ?? "sin_datos") as PassStatus;

const scheduleForMeta = scheduleText
  ? scheduleText.replace(/\s+h\.?\s*$/i, "").trim() || null
  : null;

const tempC =
  now?.temperatureC != null && Number.isFinite(now.temperatureC) ? now.temperatureC : null;
const weatherDescMeta = now?.description?.trim() || null;

const freshnessLabel = lastRel || "cuando hay datos nuevos";

const regionLabelForMeta =
  pasoConfig.provinceAR === "San Juan" ? "San Juan, Argentina" : "Mendoza, Argentina";
const headerRegionLabel = pasoConfig.provinceAR === "San Juan" ? "San Juan · AR" : "Mendoza · AR";
const geoRegionCode = pasoConfig.provinceAR === "San Juan" ? "AR-J" : "AR-M";
const geoPlacename = regionLabelForMeta;
const geoPositionMeta = `${pasoConfig.lat};${pasoConfig.lng}`;

const meta = buildPassPageMeta({
  passName: pasoConfig.name,
  passSlug: pasoConfig.slug,
  status: displayStatus,
  schedule: scheduleForMeta,
  tempC,
  weatherDesc: weatherDescMeta,
  freshnessLabel,
  regionLabel: regionLabelForMeta,
  statusHeadline: statusResult?.displayLabel ?? null,
});

const passSchema = buildPassTouristAttractionSchema({
  paso: pasoConfig,
  scheduleText,
  displayStatus,
});
---

<MainLayout
  {...meta}
  structuredData={passSchema}
  headerAltitudeM={pasoConfig.altitudeM}
  headerRegionLabel={headerRegionLabel}
  geoRegionCode={geoRegionCode}
  geoPlacename={geoPlacename}
  geoPosition={geoPositionMeta}
>
  <div class="paso-page-root flex w-full min-w-0 flex-col gap-4 md:gap-6">
    <PasoPageVersionRow />

    {snapshotLoadFailed && <PasoPageLoadError officialPassUrl={officialPassUrl} slug={slug} />}

    {
      view && statusResult && (
        <PasoPageShell
          slug={slug}
          view={view}
          statusResult={statusResult}
          scheduleText={scheduleText}
          lastUpdatedRelative={lastRel}
          officialUrl={officialUrl}
          now={now}
          forecast={forecast}
          showNow={showNow}
          showForecast={showForecast}
          hideScheduleInDetails={hideScheduleInDetails}
        />
      )
    }
  </div>

  <PasoPageSeoBlock paso={pasoConfig} />
</MainLayout>

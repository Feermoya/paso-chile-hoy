---
import { readFileSync, existsSync } from "node:fs";
import { join } from "node:path";
import type { PassAlert } from "@/utils/twitterScraper";
import { toXComUrl } from "@/utils/twitterScraper";

interface Props {
  passSlug: string;
}

const { passSlug } = Astro.props;

const tweetsPath = join(process.cwd(), "public", "snapshots", "tweets.json");
let relevantAlerts: PassAlert[] = [];

if (existsSync(tweetsPath)) {
  try {
    const data = JSON.parse(readFileSync(tweetsPath, "utf-8")) as {
      tweets?: PassAlert[];
    };
    const tweets = data.tweets ?? [];
    relevantAlerts = tweets.filter((t) => t.passesmentioned.includes(passSlug)).slice(0, 2);
  } catch {
    /* fuente secundaria */
  }
}

if (relevantAlerts.length === 0) {
  return;
}

const alertColors: Record<
  PassAlert["alertType"],
  { border: string; bg: string; icon: string }
> = {
  cierre: {
    border: "var(--color-closed)",
    bg: "rgba(224,85,85,0.05)",
    icon: "🔴",
  },
  apertura: {
    border: "var(--color-open)",
    bg: "rgba(61,214,140,0.05)",
    icon: "✅",
  },
  condicion: {
    border: "var(--color-conditional)",
    bg: "rgba(240,168,48,0.05)",
    icon: "⚠️",
  },
  info: {
    border: "var(--color-border-default)",
    bg: "rgba(255,255,255,0.02)",
    icon: "ℹ️",
  },
};
---

<section class="twitter-alerts-section anim-section anim-delay-2" aria-label="Alertas de @PasoCRMza">
  <div class="twitter-alerts-header">
    <svg
      width="13"
      height="13"
      viewBox="0 0 24 24"
      fill="currentColor"
      aria-hidden="true"
      class="twitter-alerts-x-icon"
    >
      <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
    </svg>
    <span>Alertas de @PasoCRMza</span>
    <span class="twitter-alerts-disclaimer">Fuente complementaria — verificar en gob.ar</span>
  </div>

  {
    relevantAlerts.map((alert) => {
      const colors = alertColors[alert.alertType];
      const xUrl = toXComUrl(alert.url);
      const dateParsed = alert.date ? Date.parse(alert.date) : NaN;
      const dateLabel =
        Number.isFinite(dateParsed) && !Number.isNaN(dateParsed)
          ? new Date(dateParsed).toLocaleString("es-AR", {
              day: "numeric",
              month: "short",
              hour: "2-digit",
              minute: "2-digit",
            })
          : null;

      return (
        <div
          class="twitter-alert-card"
          style={`border-left-color: ${colors.border}; background: ${colors.bg}`}
        >
          <p class="twitter-alert-text">
            <span class="twitter-alert-type-icon" aria-hidden="true">
              {colors.icon}
            </span>
            {alert.text}
          </p>
          <div class="twitter-alert-meta">
            {dateLabel && <span class="twitter-alert-date">{dateLabel}</span>}
            {xUrl ? (
              <a href={xUrl} target="_blank" rel="noopener noreferrer" class="twitter-alert-link">
                Ver en X →
              </a>
            ) : null}
          </div>
        </div>
      );
    })
  }
</section>

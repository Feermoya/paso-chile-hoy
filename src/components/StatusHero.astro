---
import { Icon } from "astro-icon/components";
import type { PassDisplayStatus } from "@/utils/inferPassStatus";

export interface Props {
  status: PassDisplayStatus;
  passName: string;
  schedule: string;
  lastUpdatedRelative: string;
  /** URL de la página oficial (enlace “Ver fuente oficial” solo en desktop). */
  officialUrl?: string;
  /** Solo si cerrado por fuera de horario: minutos hasta la apertura. */
  opensInMinutes?: number;
  /** Nota breve sobre cómo se infirió el estado (honestidad / trazabilidad). */
  statusDetail?: string;
  class?: string;
}

const {
  status,
  passName,
  schedule,
  lastUpdatedRelative,
  officialUrl,
  opensInMinutes,
  statusDetail,
  class: className,
} = Astro.props;

const labels: Record<PassDisplayStatus, string> = {
  abierto: "ABIERTO",
  condicionado: "CONDICIONADO",
  cerrado: "CERRADO",
  sin_datos: "Estado no disponible",
};

const dotColors: Record<PassDisplayStatus, string> = {
  abierto: "var(--color-open)",
  condicionado: "var(--color-conditional)",
  cerrado: "var(--color-closed)",
  sin_datos: "var(--color-unknown)",
};

const titleColor =
  status === "sin_datos" ? "var(--color-text-secondary)" : dotColors[status];

const label = labels[status];
const dotPulse = status === "abierto" ? "status-dot--open" : "";
---

<section
  class:list={[
    "status-hero w-full min-h-[160px] px-0 py-0 md:min-h-[180px]",
    className,
  ]}
  data-pass-status={status}
  aria-labelledby="status-hero-label"
>
  <div class="status-hero-inner mx-auto w-full max-w-[900px]">
    <p class="status-eyebrow text-eyebrow text-[var(--color-text-muted)]">{passName}</p>

    <div class="status-main">
      <span
        class:list={["status-dot", dotPulse]}
        style={dotPulse ? undefined : { backgroundColor: dotColors[status] }}
        aria-hidden="true"
      />
      <span
        id="status-hero-label"
        class="text-status"
        style={{ color: titleColor }}
      >
        {label}
      </span>
    </div>

    <div class="status-secondary">
      {schedule && (
        <p class="status-horario">
          <span class="text-[var(--color-text-muted)]">Horario · </span>
          {schedule}
        </p>
      )}

      {status === "cerrado" && opensInMinutes != null && opensInMinutes > 0 && (
        <p class="status-opens-at text-meta mt-1 flex items-center gap-1.5 text-[var(--color-text-secondary)]">
          <Icon name="lucide:clock" class="h-3.5 w-3.5 shrink-0 opacity-90" aria-hidden="true" />
          <span>
            Abre en {Math.floor(opensInMinutes / 60)}h {opensInMinutes % 60}min
          </span>
        </p>
      )}

      {statusDetail && status !== "abierto" && (
        <p class="status-detail text-[11px] leading-snug text-[var(--color-text-muted)] mt-1.5 max-w-prose">
          {statusDetail}
        </p>
      )}

      {lastUpdatedRelative && (
        <p class="status-timestamp text-meta">
          <Icon name="lucide:clock-3" class="h-4 w-4 shrink-0 opacity-80" aria-hidden="true" />
          <span>Actualizado {lastUpdatedRelative}</span>
        </p>
      )}
    </div>

    <div class="hidden md:block md:mt-4 md:border-t md:border-[var(--color-border-subtle)] md:pt-4">
      <p class="m-0 text-[13px] leading-relaxed text-[var(--color-text-muted)]">
        El estado se determina a partir del horario oficial publicado por Gendarmería Nacional y las alertas
        activas de Vialidad Nacional. Verificá siempre en la fuente oficial antes de iniciar el viaje.
      </p>
      {officialUrl && (
        <a
          href={officialUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-3 inline-flex min-h-12 items-center gap-1.5 text-[13px] text-[var(--color-accent)] hover:underline"
        >
          <Icon name="lucide:external-link" class="h-3.5 w-3.5 shrink-0" aria-hidden="true" />
          Ver fuente oficial
        </a>
      )}
    </div>
  </div>
</section>

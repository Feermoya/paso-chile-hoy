---
import { Icon } from "astro-icon/components";
import type { PassDisplayStatus } from "@/utils/inferPassStatus";

export interface Props {
  slug: string;
  status: PassDisplayStatus;
  passName: string;
  schedule: string;
  lastUpdatedRelative: string;
  officialUrl?: string;
  opensInMinutes?: number;
  closesInMinutes?: number;
  class?: string;
}

const {
  slug,
  status,
  passName,
  schedule,
  lastUpdatedRelative,
  officialUrl,
  opensInMinutes,
  closesInMinutes,
  class: className,
} = Astro.props;

const labels: Record<PassDisplayStatus, string> = {
  abierto: "ABIERTO",
  condicionado: "CONDICIONADO",
  cerrado: "CERRADO",
  sin_datos: "Estado no disponible",
};

const dotColors: Record<PassDisplayStatus, string> = {
  abierto: "var(--color-open)",
  condicionado: "var(--color-conditional)",
  cerrado: "var(--color-closed)",
  sin_datos: "var(--color-unknown)",
};

const titleColor =
  status === "sin_datos" ? "var(--color-text-secondary)" : dotColors[status];

const label = labels[status];

const dotModifier =
  status === "abierto"
    ? "status-dot--open"
    : status === "condicionado"
      ? "status-dot--condicionado"
      : status === "cerrado"
        ? "status-dot--cerrado"
        : "status-dot--unknown";

const showOpenCountdown =
  status === "cerrado" && opensInMinutes != null && opensInMinutes > 0;

const showCloseCountdown =
  (status === "abierto" || status === "condicionado") &&
  closesInMinutes != null &&
  closesInMinutes > 0;

function formatMinutesShort(minutes: number): string {
  if (minutes < 60) return `${minutes} min`;
  const h = Math.floor(minutes / 60);
  const m = minutes % 60;
  return m > 0 ? `${h}h ${m}min` : `${h}h`;
}

const closeCountdownInitial =
  closesInMinutes != null && closesInMinutes > 0
    ? formatMinutesShort(closesInMinutes)
    : "";
---

<section
  class:list={[
    "status-hero w-full min-h-[160px] px-0 py-0 md:min-h-[180px]",
    className,
  ]}
  data-pass-status={status}
  data-status-hero-root
  data-hero-slug={slug}
  aria-labelledby="status-hero-label"
>
  <div class="status-hero-inner mx-auto w-full max-w-[900px]">
    <p class="status-eyebrow text-eyebrow">{passName}</p>

    <div class="status-main">
      <span
        class:list={["status-dot", dotModifier]}
        data-hero-dot
        aria-hidden="true"></span>
      <span
        id="status-hero-label"
        class="text-status"
        data-hero-label
        style={{ color: titleColor }}
      >
        {label}
      </span>
    </div>

    <div class="status-secondary">
      {schedule && (
        <p class="status-horario" data-hero-schedule-row>
          <span class="text-[var(--color-text-muted)]">Horario · </span>
          <span data-hero-schedule-text>{schedule}</span>
        </p>
      )}

      {
        showOpenCountdown && (
          <div
            class="status-countdown"
            data-status-countdown-root
            data-minutes={opensInMinutes}
            data-direction="opens"
          >
            <Icon
              name="lucide:clock"
              class="status-countdown-icon"
              style="color: var(--color-text-muted)"
              aria-hidden="true"
            />
            <span class="countdown-label">Abre en</span>
            <span class="countdown-value">
              {Math.floor(opensInMinutes! / 60)}h {opensInMinutes! % 60}min
            </span>
          </div>
        )
      }

      {
        showCloseCountdown && (
          <div
            class="status-countdown status-countdown--warning"
            data-status-countdown-root
            data-minutes={closesInMinutes}
            data-direction="closes"
          >
            <Icon
              name="lucide:clock"
              class="status-countdown-icon"
              style="color: var(--color-conditional)"
              aria-hidden="true"
            />
            <span class="countdown-label countdown-label--warning">Cierra en</span>
            <span class="countdown-value countdown-value--warning">
              {closeCountdownInitial}
            </span>
          </div>
        )
      }

      <div class="status-refresh-row">
        {lastUpdatedRelative && (
          <p class="status-timestamp text-meta" data-hero-timestamp-wrap>
            <Icon name="lucide:clock-3" class="h-4 w-4 shrink-0 opacity-80" aria-hidden="true" />
            <span id={`timestamp-label-${slug}`} data-hero-timestamp>
              Actualizado {lastUpdatedRelative}
            </span>
          </p>
        )}

        <button
          class="refresh-btn"
          type="button"
          data-refresh-btn
          data-slug={slug}
          aria-label="Actualizar datos del paso"
        >
          <svg
            class="refresh-icon"
            data-refresh-icon
            width="13"
            height="13"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M1 4v6h6"></path>
            <path d="M23 20v-6h-6"></path>
            <path d="M20.49 9A9 9 0 0 0 5.64 5.64L1 10M23 14l-4.64 4.36A9 9 0 0 1 3.51 15"></path>
          </svg>
          <span data-refresh-label>Actualizar</span>
        </button>
      </div>
    </div>

    <div class="hidden md:block md:mt-4 md:border-t md:border-[var(--color-border-subtle)] md:pt-4">
      <p class="m-0 text-[13px] leading-relaxed text-[var(--color-text-muted)]">
        El estado proviene del API público del Ministerio de Seguridad (mismo dato que la página oficial).
        Verificá siempre en la fuente oficial antes de iniciar el viaje.
      </p>
      {officialUrl && (
        <a
          href={officialUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-3 inline-flex min-h-12 items-center gap-1.5 text-[13px] text-[var(--color-accent)] hover:underline"
        >
          <Icon name="lucide:external-link" class="h-3.5 w-3.5 shrink-0" aria-hidden="true" />
          Ver fuente oficial
        </a>
      )}
    </div>
  </div>
</section>

<style>
  .status-countdown {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 14px;
    margin-top: 4px;
  }

  .status-countdown-icon {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }

  .countdown-label {
    color: var(--color-text-muted);
    font-size: 14px;
  }

  .countdown-label--warning {
    color: var(--color-conditional);
  }

  .countdown-value {
    font-family: var(--font-mono);
    font-size: 15px;
    font-weight: 600;
    color: var(--color-text-primary);
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.02em;
    min-width: 70px;
    animation: countdownAppear 0.4s ease-out both;
  }

  .countdown-value--warning {
    color: var(--color-conditional);
  }

  @keyframes countdownAppear {
    from {
      opacity: 0;
      transform: scale(0.95);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }
</style>

<script>
  function startCountdown(root: Element) {
    const found = root.querySelector(".countdown-value");
    if (!(found instanceof HTMLElement)) return;
    const countdownEl = found;

    const startMinutes = parseInt(root.getAttribute("data-minutes") ?? "0", 10);
    if (!Number.isFinite(startMinutes) || startMinutes <= 0) return;

    const targetMs = Date.now() + startMinutes * 60 * 1000;

    function update() {
      const diffMs = targetMs - Date.now();
      if (diffMs <= 0) {
        window.location.reload();
        return;
      }
      const totalSeconds = Math.floor(diffMs / 1000);
      const hours = Math.floor(totalSeconds / 3600);
      const minutes = Math.floor((totalSeconds % 3600) / 60);
      const seconds = totalSeconds % 60;

      if (hours > 0) {
        countdownEl.textContent = `${hours}h ${minutes.toString().padStart(2, "0")}m`;
      } else if (minutes > 0) {
        countdownEl.textContent = `${minutes}m ${seconds.toString().padStart(2, "0")}s`;
      } else {
        countdownEl.textContent = `${seconds}s`;
      }
    }

    update();
    const interval = window.setInterval(update, 1000);

    const clear = () => window.clearInterval(interval);
    document.addEventListener("astro:before-swap", clear, { once: true });
  }

  document.querySelectorAll("[data-status-countdown-root]").forEach(startCountdown);

  const DOT_CLASS: Record<string, string> = {
    abierto: "status-dot--open",
    condicionado: "status-dot--condicionado",
    cerrado: "status-dot--cerrado",
    sin_datos: "status-dot--unknown",
  };

  const LABEL_COLOR: Record<string, string> = {
    abierto: "var(--color-open)",
    condicionado: "var(--color-conditional)",
    cerrado: "var(--color-closed)",
    sin_datos: "var(--color-unknown)",
  };

  const ICON_SVG = {
    idle: `<path d="M1 4v6h6"></path><path d="M23 20v-6h-6"></path><path d="M20.49 9A9 9 0 0 0 5.64 5.64L1 10M23 14l-4.64 4.36A9 9 0 0 1 3.51 15"></path>`,
    success: `<polyline points="20 6 9 17 4 12"></polyline>`,
    error: `<line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line>`,
  };

  function wireRefresh(section: Element) {
    const btn = section.querySelector("[data-refresh-btn]");
    const labelEl = section.querySelector("[data-hero-label]");
    const dot = section.querySelector("[data-hero-dot]");
    const ts = section.querySelector("[data-hero-timestamp]");
    const scheduleRow = section.querySelector("[data-hero-schedule-row]");
    const scheduleText = section.querySelector("[data-hero-schedule-text]");
    const icon = section.querySelector("[data-refresh-icon]");
    const refreshLabel = section.querySelector("[data-refresh-label]");

    if (
      !(btn instanceof HTMLButtonElement) ||
      !labelEl ||
      !dot ||
      !(icon instanceof SVGElement) ||
      !(refreshLabel instanceof HTMLElement)
    ) {
      return;
    }

    const slug = btn.getAttribute("data-slug");
    if (!slug) return;

    if (btn.dataset.refreshWired === "1") return;
    btn.dataset.refreshWired = "1";

    const refreshBtn = btn;
    const refreshIcon = icon;
    const refreshLabelEl = refreshLabel;

    function setIcon(kind: keyof typeof ICON_SVG) {
      refreshIcon.innerHTML = ICON_SVG[kind];
    }

    function setState(
      state: "idle" | "loading" | "success" | "error",
      text: string,
    ) {
      refreshBtn.dataset.state = state;
      refreshBtn.disabled = state === "loading";
      refreshLabelEl.textContent = text;
      if (state === "loading") {
        setIcon("idle");
        refreshIcon.classList.add("refresh-icon--spinning");
      } else {
        refreshIcon.classList.remove("refresh-icon--spinning");
        if (state === "success") setIcon("success");
        else if (state === "error") setIcon("error");
        else setIcon("idle");
      }
    }

    refreshBtn.addEventListener("click", async () => {
      setState("loading", "Actualizando…");

      try {
        const res = await fetch(`/api/snapshot/${slug}`, {
          method: "POST",
          cache: "no-store",
          headers: { "Cache-Control": "no-cache", Pragma: "no-cache" },
        });

        if (!res.ok) throw new Error(String(res.status));

        const data = (await res.json()) as {
          status?: string;
          statusLabel?: string;
          lastUpdatedRelative?: string;
          schedule?: string;
        };

        if (data.statusLabel && labelEl instanceof HTMLElement) {
          labelEl.textContent = data.statusLabel;
        }
        if (data.status) {
          section.setAttribute("data-pass-status", data.status);
          const dc = DOT_CLASS[data.status] ?? "status-dot--unknown";
          dot.className = `status-dot ${dc}`;
          const col = LABEL_COLOR[data.status] ?? "var(--color-text-secondary)";
          if (data.status === "sin_datos") {
            (labelEl as HTMLElement).style.color = "var(--color-text-secondary)";
          } else {
            (labelEl as HTMLElement).style.color = col;
          }
        }

        if (data.schedule != null && scheduleRow && scheduleText) {
          if (data.schedule) {
            (scheduleRow as HTMLElement).style.display = "";
            scheduleText.textContent = data.schedule;
          } else {
            (scheduleRow as HTMLElement).style.display = "none";
          }
        }

        if (data.lastUpdatedRelative && ts) {
          ts.textContent = `Actualizado ${data.lastUpdatedRelative}`;
        }

        window.dispatchEvent(
          new CustomEvent("paso-data-refreshed", {
            detail: { slug, data },
          }),
        );

        setState("success", "¡Listo!");
        setTimeout(() => setState("idle", "Actualizar"), 2500);
      } catch {
        setState("error", "Error");
        setTimeout(() => setState("idle", "Actualizar"), 3000);
      }
    });
  }

  document.querySelectorAll("[data-status-hero-root]").forEach(wireRefresh);
  document.addEventListener("astro:page-load", () => {
    document.querySelectorAll("[data-status-hero-root]").forEach(wireRefresh);
  });
</script>

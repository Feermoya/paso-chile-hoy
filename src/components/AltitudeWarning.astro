---
import { Icon } from "astro-icon/components";

export interface Props {
  altitudeM: number;
}

const { altitudeM } = Astro.props;

const level = altitudeM >= 3500 ? "high" : altitudeM >= 2500 ? "moderate" : "low";
const messages = {
  high: "Altitud extrema. Riesgo de soroche. Hidratate y ascendé despacio.",
  moderate: "Altitud considerable. Posibles síntomas de altura en personas sensibles.",
  low: "Altitud moderada. Sin riesgo significativo para la mayoría.",
};
const colors = {
  high: "var(--color-closed)",
  moderate: "var(--color-conditional)",
  low: "var(--color-text-muted)",
};
---

<div class="altitude-warning" style={`--aw-color: ${colors[level]}`}>
  <div class="altitude-warning-header">
    <Icon name="lucide:triangle-alert" class="aw-icon" aria-hidden="true" />
    <span class="aw-title">{altitudeM.toLocaleString("es-AR")} m s.n.m.</span>
  </div>
  <p class="aw-message">{messages[level]}</p>
</div>

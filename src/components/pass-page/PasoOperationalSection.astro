---
import AlertsBlock from "@/components/AlertsBlock.astro";
import LatestTweet from "@/components/LatestTweet.astro";
import CristoRiskCard from "@/components/pass/CristoRiskCard.astro";
import PanoramaExtendido from "@/components/pass/PanoramaExtendido.astro";
import StatusGuide from "@/components/StatusGuide.astro";
import StatusHero from "@/components/StatusHero.astro";
import TwitterAlerts from "@/components/TwitterAlerts.astro";
import type { ExtendedForecastSignal } from "@/lib/external/mendozaExtendedForecast";
import type { CristoRedentorRiskV1 } from "@/types/cristo-redentor-risk-v1";
import type { PassView } from "@/types/pass-view";
import type { PassStatusResult } from "@/utils/inferPassStatus";

export interface Props {
  slug: string;
  view: PassView;
  statusResult: PassStatusResult;
  scheduleText: string;
  lastUpdatedRelative: string;
  officialUrl?: string;
  lastKnownGoodRelative?: string;
  /** Solo Cristo Redentor. */
  cristoRisk?: CristoRedentorRiskV1;
  /** Solo Cristo — boletín extendido por día (Panorama extendido + señal al motor). */
  extendedForecastSignal?: ExtendedForecastSignal;
  class?: string;
}

const {
  slug,
  view,
  statusResult,
  scheduleText,
  lastUpdatedRelative,
  officialUrl,
  lastKnownGoodRelative,
  cristoRisk,
  extendedForecastSignal,
  class: className,
} = Astro.props;

const op = view.operationalInfo;
const latestTweet = view.meta?.latestTweet;
const showLatestTweet = Boolean(latestTweet?.text && latestTweet.text.trim().length >= 10);
---

<section
  class:list={["paso-page-operational paso-col", className]}
  aria-label="Estado operativo"
>
  <StatusHero
    class="anim-section anim-delay-1"
    slug={slug}
    status={statusResult.status}
    displayLabel={statusResult.displayLabel}
    passName={view.title}
    schedule={scheduleText}
    lastUpdatedRelative={lastUpdatedRelative}
    officialUrl={officialUrl}
    opensInMinutes={statusResult.opensInMinutes}
    closesInMinutes={statusResult.closesInMinutes}
    rawStatus={op.rawStatus}
    scrapeError={view.meta.scrapeError}
    operationalStale={view.meta.operationalStale}
    lastKnownGoodRelative={lastKnownGoodRelative}
  />

  <details class="paso-extra-details home-collapse" aria-label="Alertas y complementos del paso">
    <summary class="paso-extra-details__summary">
      <span class="paso-extra-details__title">Alertas, guía y redes</span>
      <span class="paso-extra-details__hint">Tocá para ver el detalle completo (oficial y complementario)</span>
    </summary>
    <div class="paso-extra-details__body">
      {
        slug === "cristo-redentor" && cristoRisk && (
          <CristoRiskCard class="anim-section anim-delay-2" risk={cristoRisk} />
        )
      }

      {
        slug === "cristo-redentor" && extendedForecastSignal && (
          <PanoramaExtendido class="anim-delay-3" signal={extendedForecastSignal} />
        )
      }

      <StatusGuide />

      <AlertsBlock
        class="anim-section anim-delay-2"
        motivo={op.motivo ?? null}
        motivoInfo={op.motivoInfo ?? null}
        htmlAlerts={op.htmlAlerts}
        vialidadRuta={op.vialidadRuta ?? ""}
        vialidadTramo={op.vialidadTramo ?? ""}
        vialidadEstado={op.vialidadEstado ?? "HABILITADA"}
        vialidadObservaciones={op.vialidadObservaciones ?? ""}
      />

      {showLatestTweet && <LatestTweet tweet={latestTweet} />}

      <TwitterAlerts passSlug={slug} />
    </div>
  </details>
</section>

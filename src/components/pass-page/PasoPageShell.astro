---
import PasoFullwidthSection from "@/components/pass-page/PasoFullwidthSection.astro";
import PasoOperationalSection from "@/components/pass-page/PasoOperationalSection.astro";
import PasoWeatherSection from "@/components/pass-page/PasoWeatherSection.astro";
import type { ExtendedForecastSignal } from "@/lib/external/mendozaExtendedForecast";
import type { CristoRedentorRiskV1 } from "@/types/cristo-redentor-risk-v1";
import type { ForecastItemView, PassView, WeatherNowView } from "@/types/pass-view";
import type { PassStatusResult } from "@/utils/inferPassStatus";

export interface Props {
  slug: string;
  view: PassView;
  statusResult: PassStatusResult;
  scheduleText: string;
  lastUpdatedRelative: string;
  officialUrl?: string;
  lastKnownGoodRelative?: string;
  now?: WeatherNowView;
  forecast: ForecastItemView[];
  showNow: boolean;
  showForecast: boolean;
  hideScheduleInDetails: boolean;
  /** Solo Cristo Redentor — motor v1 de riesgo informativo. */
  cristoRisk?: CristoRedentorRiskV1;
  /** Solo Cristo — señal boletín extendido (Prensa Mendoza). */
  extendedForecastSignal?: ExtendedForecastSignal;
  class?: string;
}

const {
  slug,
  view,
  statusResult,
  scheduleText,
  lastUpdatedRelative,
  officialUrl,
  lastKnownGoodRelative,
  now,
  forecast,
  showNow,
  showForecast,
  hideScheduleInDetails,
  cristoRisk,
  extendedForecastSignal,
  class: className,
} = Astro.props;
---

<div
  class:list={["paso-page-shell paso-page-wrapper", className]}
  data-paso-page-shell
  data-shell-slug={slug}
>
  <div
    id={`paso-stale-banner-${slug}`}
    class="paso-stale-banner mb-3 hidden rounded-lg border border-[var(--color-border-subtle)] bg-[var(--color-surface-muted)] px-3 py-2 text-[13px] leading-snug text-[var(--color-text-secondary)]"
    role="status"
    aria-live="polite"
  />
  <div class="paso-page-grid paso-grid">
    <PasoOperationalSection
      slug={slug}
      view={view}
      statusResult={statusResult}
      scheduleText={scheduleText}
      lastUpdatedRelative={lastUpdatedRelative}
      officialUrl={officialUrl}
      lastKnownGoodRelative={lastKnownGoodRelative}
      cristoRisk={cristoRisk}
      extendedForecastSignal={extendedForecastSignal}
    />

    <PasoWeatherSection
      slug={slug}
      passName={view.title}
      sourceUrl={view.meta.sourceUrl}
      now={now}
      forecast={forecast}
      scrapedAt={view.meta.scrapedAt}
      showNow={showNow}
      showForecast={showForecast}
      cristoRisk={cristoRisk}
    />
  </div>

  <PasoFullwidthSection view={view} hideScheduleInDetails={hideScheduleInDetails} />
</div>

<script is:inline define:vars={{ slug }}>
  function showStaleRefreshBanner() {
    const key = `pch:pass-stale-banner:${slug}`;
    const msg = sessionStorage.getItem(key);
    if (!msg) return;
    sessionStorage.removeItem(key);
    const el = document.getElementById(`paso-stale-banner-${slug}`);
    if (!el) return;
    el.textContent = msg;
    el.classList.remove("hidden");
  }

  showStaleRefreshBanner();
  document.addEventListener("astro:page-load", showStaleRefreshBanner);
</script>

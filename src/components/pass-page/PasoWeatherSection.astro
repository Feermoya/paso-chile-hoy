---
import DrivingConditions from "@/components/DrivingConditions.astro";
import WeatherForecast from "@/components/WeatherForecast.astro";
import WeatherNow from "@/components/WeatherNow.astro";
import ForecastShareButton from "@/components/share/ForecastShareButton.astro";
import ForecastShareModal from "@/components/share/ForecastShareModal.astro";
import { mapForecastToShareData } from "@/lib/mappers/forecastShareMapper";
import type { CristoRedentorRiskV1 } from "@/types/cristo-redentor-risk-v1";
import type { ForecastItemView, WeatherNowView } from "@/types/pass-view";
import { weatherNowToDrivingInput } from "@/utils/drivingConditions";

export interface Props {
  slug: string;
  passName: string;
  sourceUrl?: string;
  now?: WeatherNowView;
  forecast: ForecastItemView[];
  scrapedAt?: string;
  showNow: boolean;
  showForecast: boolean;
  cristoRisk?: CristoRedentorRiskV1;
  class?: string;
}

const {
  slug,
  passName,
  sourceUrl,
  now,
  forecast,
  scrapedAt,
  showNow,
  showForecast,
  cristoRisk,
  class: className,
} = Astro.props;
const shareData = mapForecastToShareData({
  slug,
  passName,
  forecast,
  sourceUrl,
  nowIso: scrapedAt,
  maxDays: 5,
  cristoRisk,
});
const shareModalId = `forecast-share-modal-${slug}`;
const shareCardId = `forecast-share-card-${slug}`;
const hasWeatherBlock = (showNow && now) || (showForecast && forecast.length > 0);
---

<section
  class:list={["paso-page-weather paso-col paso-col--sticky", className]}
  aria-label="Condiciones climáticas"
  data-paso-weather-section
  data-weather-slug={slug}
>
  {
    !hasWeatherBlock && (
      <div class="paso-panel">
        <p class="m-0 px-4 py-5 text-[13px] text-[var(--color-text-secondary)]" data-paso-weather-unavailable>
          Clima no disponible en este momento.
        </p>
      </div>
    )
  }

  {
    hasWeatherBlock && (
      <div class="paso-panel paso-weather-panel">
        <header class="paso-weather-panel__head">
          <div class="paso-weather-panel__title-row">
            <span class="paso-weather-panel__live" aria-hidden="true" />
            <h2 class="paso-weather-panel__title">Clima en el paso</h2>
          </div>
          <span class="paso-weather-panel__source">SMN · datos públicos</span>
        </header>
        <div class="paso-panel__body paso-weather-panel__body">
          {
            showNow && now && (
              <WeatherNow
                class="anim-section anim-delay-3"
                weather={now}
                forecast={forecast}
                updatedAt={now.providerNote}
                scrapedAt={scrapedAt}
                includeDriving={false}
                hideDataTimestamp
                embedded
              />
            )
          }

          {showForecast && forecast.length > 0 && (
            <div class="paso-weather-forecast-block">
              <h3 class="paso-weather-subhead">Próximos días</h3>
              <WeatherForecast class="anim-section anim-delay-2" forecast={forecast} />
              <div class="anim-section anim-delay-2 mt-3">
                <ForecastShareButton targetModalId={shareModalId} />
              </div>
              <ForecastShareModal modalId={shareModalId} cardId={shareCardId} data={shareData} />
            </div>
          )}

          {
            showNow && now && (
              <div class="paso-weather-driving">
                <h3 class="paso-weather-subhead">Conducción</h3>
                <DrivingConditions
                  class="anim-section anim-delay-3"
                  weather={weatherNowToDrivingInput(now)}
                  forecast={forecast}
                  compact
                />
              </div>
            )
          }
        </div>
      </div>
    )
  }
</section>


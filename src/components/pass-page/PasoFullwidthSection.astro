---
import PassDetails from "@/components/PassDetails.astro";
import SupportBlock from "@/components/SupportBlock.astro";
import type { PassView } from "@/types/pass-view";

export interface Props {
  view: PassView;
  hideScheduleInDetails: boolean;
  class?: string;
}

const { view, hideScheduleInDetails, class: className } = Astro.props;
---

<div class:list={["paso-page-fullwidth paso-fullwidth", className]}>
  <details class="paso-bottom-details home-collapse" aria-label="Datos ampliados del paso">
    <summary class="paso-bottom-details__summary">
      <span class="paso-bottom-details__title">Datos ampliados del paso</span>
      <span class="paso-bottom-details__hint">Horario, contacto, mapa, enlaces y fuentes del cruce</span>
    </summary>
    <div class="paso-bottom-details__body">
      <PassDetails
        class="anim-section anim-delay-5"
        view={view}
        hideScheduleInDetails={hideScheduleInDetails}
      />
    </div>
  </details>

  <div class="paso-fullwidth-support">
    <SupportBlock />
  </div>
</div>

---
import { PASOS } from "@/data/pasos";
import type { PasoConfig } from "@/data/pasos";
import { passEnglishDiscoveryLine } from "@/utils/seo";

export interface Props {
  paso: PasoConfig;
  class?: string;
}

const { paso, class: className } = Astro.props;
const enLine = passEnglishDiscoveryLine(paso.slug);
const otros = PASOS.filter((p) => p.active && p.slug !== paso.slug);

const slugIntro: Record<string, { lead: string; context: string }> = {
  "cristo-redentor": {
    lead:
      "Cruce Mendoza–Valparaíso por la ruta 7: el más transitado del oeste argentino. Acá ves estado, horario y clima en altura según la publicación oficial.",
    context:
      "Antes de salir desde el Gran Mendoza, cruzá esta pantalla con rutas y pronóstico: en ciudad puede estar despejado y en el túnel haber restricciones.",
  },
  pehuenche: {
    lead:
      "Malargüe hacia Talca (Maule). Corredor alternativo a Los Libertadores; el horario y el estado dependen de la temporada y del mantenimiento en cordillera.",
    context:
      "Útil si evitás el tránsito del Cristo o salís del sur mendocino; confirmá siempre en la fuente oficial antes de largar.",
  },
  "agua-negra": {
    lead:
      "Las Flores (San Juan) con Huanta (Chile), por encima de los 4.700 m. Paso exigente: nevadas y viento pueden cambiar el estado en pocas horas.",
    context:
      "El clima en el valle no anticipa el de la cumbre; revisá alertas y horario publicado si subís desde San Juan.",
  },
};

const block = slugIntro[paso.slug] ?? {
  lead: `${paso.name}: ${paso.localityAR} — ${paso.localityCL}.`,
  context: "Usá el panel superior para el estado actual y la fuente oficial.",
};
---

<section
  class:list={["paso-page-seo seo-content seo-content--pass", className]}
  aria-label={`Contexto — ${paso.name}`}
>
  <p class="paso-page-seo-lead paso-page-seo-lead--visible">{block.lead}</p>
  <p class="paso-page-seo-note paso-page-seo-note--visible">{block.context}</p>

  <details class="paso-page-seo-details home-collapse">
    <summary class="paso-page-seo-details__summary">
      <span class="paso-page-seo-details__title">Más contexto y enlaces</span>
      <span class="paso-page-seo-details__hint">Checklist, otros pasos, aviso legal, inglés</span>
    </summary>
    <div class="paso-page-seo-details__body">
      <h2 class="paso-page-seo-title sr-only">Información complementaria — {paso.shortName}</h2>

      <h3 class="paso-page-seo-sub">Antes de viajar</h3>
      <ul class="paso-page-seo-list">
        <li>Estado y horario en el panel superior (datos públicos Argentina).</li>
        <li>Clima en cordillera; puede diferir del valle.</li>
        <li>Documentación de ingreso a Chile (no gestionada por este sitio).</li>
        <li>
          Fuente oficial:{" "}
          <a href="https://www.argentina.gob.ar/seguridad/pasosinternacionales" target="_blank" rel="noopener"
            >pasos internacionales</a
          >.
        </li>
      </ul>

      <h3 class="paso-page-seo-sub">Otros pasos</h3>
      <p class="paso-page-seo-note">
        {
          otros.flatMap((o, i) => [
            i > 0 ? " · " : null,
            <a href={`/${o.slug}`}>{o.shortName}</a>,
          ])
        }
        {" "}
        · <a href="/">Inicio</a>
        {" "}
        · <a href="/legal">Aviso legal</a>
      </p>
      <p class="paso-page-seo-note" lang="en">
        <strong>English:</strong> {enLine}
      </p>
    </div>
  </details>
</section>

<style>
  .paso-page-seo-lead--visible,
  .paso-page-seo-note--visible {
    margin: 0 0 10px;
    max-width: 62ch;
  }

  .paso-page-seo-lead--visible {
    font-size: 15px;
    line-height: 1.55;
    color: var(--color-text-secondary);
  }

  .paso-page-seo-note--visible {
    font-size: 14px;
    line-height: 1.5;
    color: var(--color-text-muted);
  }

  .paso-page-seo-sub {
    font-family: var(--font-display);
    font-size: 14px;
    font-weight: 700;
    color: var(--color-text-secondary);
    margin: 18px 0 8px;
  }

  .paso-page-seo-list {
    margin: 0 0 8px;
    padding-left: 1.2rem;
    font-size: 14px;
    color: var(--color-text-muted);
    line-height: 1.65;
  }

  .paso-page-seo-list a {
    color: var(--color-accent);
    text-decoration: none;
  }

  .paso-page-seo-list a:hover {
    text-decoration: underline;
  }
</style>

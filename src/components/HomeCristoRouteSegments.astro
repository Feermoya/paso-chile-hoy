---
import { Icon } from "astro-icon/components";
import Hrr7SegmentName from "@/components/Hrr7SegmentName.astro";
import Hrr7SegmentMetaLine from "@/components/Hrr7SegmentMetaLine.astro";
import type {
  HomeCristoRouteView,
  HomeCristoDisplayItem,
  HomeCristoRouteTimelineRow,
  TimelineVisualMark,
} from "@/lib/mappers/homeCristoRouteView";

export interface Props {
  view: HomeCristoRouteView;
}

const { view } = Astro.props;

const markIcon = (m: TimelineVisualMark): { name: string } => {
  switch (m) {
    case "check":
    case "check-dim":
      return { name: "lucide:check" };
    case "stop":
      return { name: "lucide:x" };
    case "warn":
      return { name: "lucide:alert-triangle" };
    default:
      return { name: "lucide:minus" };
  }
};

const carStop = (row: HomeCristoRouteTimelineRow): "0" | "1" =>
  row.status === "OPEN" || row.status === "CAUTION" ? "1" : "0";

/** Valores para data-tramo-estado (animación y conectores). */
const tramoEstado = (row: HomeCristoRouteTimelineRow): string => {
  switch (row.status) {
    case "OPEN":
      return "HABILITADA";
    case "CAUTION":
    case "PARTIAL":
      return "PRECAUCION";
    case "CLOSED":
      return "CORTE_TOTAL";
    default:
      return "DESCONOCIDO";
  }
};
---

<section class="home-route-rn7" aria-labelledby="home-route-rn7-title" data-home-route-rn7>
  <div class="hrr7-panel">
    <header class="hrr7-header">
      <svg
        class="hrr7-mountain"
        viewBox="0 0 120 80"
        fill="none"
        aria-hidden="true"
      >
        <polygon points="60,5 10,75 110,75" fill="currentColor"></polygon>
        <polygon points="90,20 55,75 125,75" fill="currentColor"></polygon>
        <polygon points="30,35 5,75 60,75" fill="currentColor"></polygon>
      </svg>
      <div class="hrr7-header-inner">
        <h2 id="home-route-rn7-title" class="hrr7-title">
          {view.title}
        </h2>
        <p class="hrr7-meta">
          <span
            class:list={[
              "hrr7-fresh-dot",
              view.freshnessDot === "green" && "hrr7-fresh-dot--green",
              view.freshnessDot === "amber" && "hrr7-fresh-dot--amber",
              view.freshnessDot === "red" && "hrr7-fresh-dot--red",
            ]}
            aria-hidden="true"
          />
          <span class="hrr7-meta-sep" aria-hidden="true">·</span>
          <span>{view.freshnessLabel}</span>
          <span class="hrr7-meta-sep" aria-hidden="true">·</span>
          <span>{view.enabledSummary}</span>
        </p>
      </div>
    </header>

    {
      view.showAlertBanner && view.alertBannerText ? (
        <div class="hrr7-alert-banner" role="alert">
          <p class="hrr7-alert-banner-text">{view.alertBannerText}</p>
        </div>
      ) : null
    }

    <div class="hrr7-track">
      <div class="hrr7-car-wrap" aria-hidden="true">
        <div class="hrr7-car-y route-car-host">
          <svg
            class="hrr7-car route-car"
            width="18"
            height="26"
            viewBox="0 0 18 26"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
            aria-hidden="true"
          >
            <rect x="2" y="7" width="14" height="13" rx="3" fill="currentColor" opacity="0.9" />
            <rect x="4" y="4" width="10" height="7" rx="2" fill="currentColor" opacity="0.7" />
            <rect x="5" y="5" width="4" height="3" rx="0.5" fill="white" opacity="0.5" />
            <rect x="9" y="5" width="4" height="3" rx="0.5" fill="white" opacity="0.5" />
            <rect x="0" y="8" width="4" height="5" rx="2" fill="currentColor" opacity="0.6" />
            <rect x="14" y="8" width="4" height="5" rx="2" fill="currentColor" opacity="0.6" />
            <rect x="0" y="15" width="4" height="5" rx="2" fill="currentColor" opacity="0.6" />
            <rect x="14" y="15" width="4" height="5" rx="2" fill="currentColor" opacity="0.6" />
            <rect x="3" y="19" width="4" height="2" rx="1" fill="white" opacity="0.8" />
            <rect x="11" y="19" width="4" height="2" rx="1" fill="white" opacity="0.8" />
          </svg>
        </div>
      </div>

      <ul class="hrr7-steps hrr7-steps--desktop" aria-label="Tramos RN 7">
        {
          view.timeline.map((row, index) => (
            <li
              class:list={[
                "hrr7-step",
                "tramo-row",
                row.status === "CLOSED" && "hrr7-step--corte",
                row.isAfterBlocking && "hrr7-step--past",
                row.isCriticalFinal && "hrr7-step--critical",
              ]}
              data-tramo-estado={tramoEstado(row)}
              data-hrr7-timeline-index={index}
              data-hrr7-car-stop={carStop(row)}
            >
              <div class="hrr7-line-col tramo-line-col">
                <span
                  class:list={["hrr7-step-icon", "line-dot", `hrr7-step-icon--${row.visualMark}`]}
                  aria-hidden="true"
                >
                  <Icon name={markIcon(row.visualMark).name} width={13} height={13} aria-hidden="true" />
                </span>
                <div class="hrr7-connector" aria-hidden="true" />
              </div>
              <div class="hrr7-step-main">
                {row.isCriticalFinal ? (
                  <div class:list={["tramo-content-inner", "hrr7-step-card", "hrr7-step-card--critical"]}>
                    <div class="hrr7-row">
                      <div>
                        <Hrr7SegmentName origin={row.nameOrigin} dest={row.nameDest} />
                      </div>
                      <span class:list={["hrr7-pill", `hrr7-pill--${row.status.toLowerCase()}`]}>
                        <span class="hrr7-pill-full">{row.badgeLabelStrong}</span>
                        <span class="hrr7-pill-abbr">{row.badgeLabelMobile}</span>
                      </span>
                    </div>
                    <Hrr7SegmentMetaLine
                      surfaceLine={row.surfaceLine}
                      toll={row.flags.toll}
                      international={row.flags.international}
                    />
                    {row.notes?.trim() ? <p class="hrr7-notes">{row.notes.trim()}</p> : null}
                  </div>
                ) : (
                  <div class:list={["tramo-content-inner", "hrr7-step-card"]}>
                    <div class="hrr7-row">
                      <Hrr7SegmentName origin={row.nameOrigin} dest={row.nameDest} />
                      <span class:list={["hrr7-pill", `hrr7-pill--${row.status.toLowerCase()}`]}>
                        <span class="hrr7-pill-full">{row.badgeLabel}</span>
                        <span class="hrr7-pill-abbr">{row.badgeLabelMobile}</span>
                      </span>
                    </div>
                    <Hrr7SegmentMetaLine
                      surfaceLine={row.surfaceLine}
                      toll={row.flags.toll}
                      international={row.flags.international}
                    />
                    {row.notes?.trim() ? <p class="hrr7-name-extra">{row.notes.trim()}</p> : null}
                  </div>
                )}
              </div>
            </li>
          ))
        }
      </ul>

      <ul class="hrr7-steps hrr7-steps--mobile" aria-label="Tramos RN 7 (vista compacta)">
        {
          view.mobileTimeline.map((item: HomeCristoDisplayItem, mi: number) =>
            item.kind === "collapsed" ? (
              <li
                class="hrr7-step hrr7-step--accordion tramo-row"
                data-tramo-estado="HABILITADA"
                data-hrr7-car-stop="0"
              >
                <div class="hrr7-line-col tramo-line-col hrr7-line-col--accordion">
                  <span class="hrr7-step-icon hrr7-step-icon--check-dim line-dot" aria-hidden="true">
                    <Icon name="lucide:check" width={12} height={12} aria-hidden="true" />
                  </span>
                  <div class="hrr7-connector" aria-hidden="true" />
                </div>
                <div class="hrr7-accordion-cell">
                  <button
                    type="button"
                    class="hrr7-expand-btn"
                    aria-expanded="false"
                    aria-controls={`hrr7-collapsed-${mi}-${item.rows[0]?.id ?? "mid"}`}
                  >
                    <span class="hrr7-expand-icon" aria-hidden="true">
                      +
                    </span>
                    <span
                      class="hrr7-expand-label"
                      data-text-collapsed={`Ver ${item.count} tramos habilitados intermedios`}
                      data-text-expanded="Ocultar tramos intermedios"
                    >
                      {`Ver ${item.count} tramos habilitados intermedios`}
                    </span>
                  </button>
                  <div
                    class="hrr7-tramos-collapsed tramos-collapsed"
                    id={`hrr7-collapsed-${mi}-${item.rows[0]?.id ?? "mid"}`}
                  >
                    <ul class="hrr7-nested-steps" role="list">
                      {item.rows.map((row) => (
                        <li
                          class:list={[
                            "hrr7-step",
                            "hrr7-step--nested",
                            "tramo-row",
                            row.status === "CLOSED" && "hrr7-step--corte",
                            row.isAfterBlocking && "hrr7-step--past",
                            row.isCriticalFinal && "hrr7-step--critical",
                          ]}
                          data-tramo-estado={tramoEstado(row)}
                          data-hrr7-car-stop={carStop(row)}
                        >
                          <div class="hrr7-line-col tramo-line-col">
                            <span
                              class:list={[
                                "hrr7-step-icon",
                                "line-dot",
                                `hrr7-step-icon--${row.visualMark}`,
                              ]}
                              aria-hidden="true"
                            >
                              <Icon
                                name={markIcon(row.visualMark).name}
                                width={12}
                                height={12}
                                aria-hidden="true"
                              />
                            </span>
                            <div class="hrr7-connector" aria-hidden="true" />
                          </div>
                          <div class="hrr7-step-main">
                            {row.isCriticalFinal ? (
                              <div
                                class:list={[
                                  "tramo-content-inner",
                                  "hrr7-step-card",
                                  "hrr7-step-card--critical",
                                ]}
                              >
                                <div class="hrr7-row">
                                  <div>
                                    <Hrr7SegmentName origin={row.nameOrigin} dest={row.nameDest} />
                                  </div>
                                  <span
                                    class:list={["hrr7-pill", `hrr7-pill--${row.status.toLowerCase()}`]}
                                  >
                                    <span class="hrr7-pill-full">{row.badgeLabelStrong}</span>
                                    <span class="hrr7-pill-abbr">{row.badgeLabelMobile}</span>
                                  </span>
                                </div>
                                <Hrr7SegmentMetaLine
                                  surfaceLine={row.surfaceLine}
                                  toll={row.flags.toll}
                                  international={row.flags.international}
                                />
                                {row.notes?.trim() ? (
                                  <p class="hrr7-notes">{row.notes.trim()}</p>
                                ) : null}
                              </div>
                            ) : (
                              <div class:list={["tramo-content-inner", "hrr7-step-card"]}>
                                <div class="hrr7-row">
                                  <Hrr7SegmentName origin={row.nameOrigin} dest={row.nameDest} />
                                  <span
                                    class:list={["hrr7-pill", `hrr7-pill--${row.status.toLowerCase()}`]}
                                  >
                                    <span class="hrr7-pill-full">{row.badgeLabel}</span>
                                    <span class="hrr7-pill-abbr">{row.badgeLabelMobile}</span>
                                  </span>
                                </div>
                                <Hrr7SegmentMetaLine
                                  surfaceLine={row.surfaceLine}
                                  toll={row.flags.toll}
                                  international={row.flags.international}
                                />
                                {row.notes?.trim() ? (
                                  <p class="hrr7-name-extra">{row.notes.trim()}</p>
                                ) : null}
                              </div>
                            )}
                          </div>
                        </li>
                      ))}
                    </ul>
                  </div>
                </div>
              </li>
            ) : (
              <li
                class:list={[
                  "hrr7-step",
                  "tramo-row",
                  item.row.status === "CLOSED" && "hrr7-step--corte",
                  item.row.isAfterBlocking && "hrr7-step--past",
                  item.row.isCriticalFinal && "hrr7-step--critical",
                ]}
                data-tramo-estado={tramoEstado(item.row)}
                data-hrr7-car-stop={carStop(item.row)}
              >
                <div class="hrr7-line-col tramo-line-col">
                  <span
                    class:list={[
                      "hrr7-step-icon",
                      "line-dot",
                      `hrr7-step-icon--${item.row.visualMark}`,
                    ]}
                    aria-hidden="true"
                  >
                    <Icon
                      name={markIcon(item.row.visualMark).name}
                      width={12}
                      height={12}
                      aria-hidden="true"
                    />
                  </span>
                  <div class="hrr7-connector" aria-hidden="true" />
                </div>
                <div class="hrr7-step-main">
                  {item.row.isCriticalFinal ? (
                    <div class:list={["tramo-content-inner", "hrr7-step-card", "hrr7-step-card--critical"]}>
                      <div class="hrr7-row">
                        <div>
                          <Hrr7SegmentName origin={item.row.nameOrigin} dest={item.row.nameDest} />
                        </div>
                        <span class:list={["hrr7-pill", `hrr7-pill--${item.row.status.toLowerCase()}`]}>
                          <span class="hrr7-pill-full">{item.row.badgeLabelStrong}</span>
                          <span class="hrr7-pill-abbr">{item.row.badgeLabelMobile}</span>
                        </span>
                      </div>
                      <Hrr7SegmentMetaLine
                        surfaceLine={item.row.surfaceLine}
                        toll={item.row.flags.toll}
                        international={item.row.flags.international}
                      />
                      {item.row.notes?.trim() ? (
                        <p class="hrr7-notes">{item.row.notes.trim()}</p>
                      ) : null}
                    </div>
                  ) : (
                    <div class:list={["tramo-content-inner", "hrr7-step-card"]}>
                      <div class="hrr7-row">
                        <Hrr7SegmentName origin={item.row.nameOrigin} dest={item.row.nameDest} />
                        <span class:list={["hrr7-pill", `hrr7-pill--${item.row.status.toLowerCase()}`]}>
                          <span class="hrr7-pill-full">{item.row.badgeLabel}</span>
                          <span class="hrr7-pill-abbr">{item.row.badgeLabelMobile}</span>
                        </span>
                      </div>
                      <Hrr7SegmentMetaLine
                        surfaceLine={item.row.surfaceLine}
                        toll={item.row.flags.toll}
                        international={item.row.flags.international}
                      />
                      {item.row.notes?.trim() ? (
                        <p class="hrr7-name-extra">{item.row.notes.trim()}</p>
                      ) : null}
                    </div>
                  )}
                </div>
              </li>
            ),
          )
        }
      </ul>
    </div>

    <div class="hrr7-reach-compact reach-card">
      <div class="hrr7-reach-compact-head reach-header">
        <span class="reach-header-title">¿Hasta dónde podés llegar?</span>
      </div>
      <div
        class:list={[
          "hrr7-reach-compact-body",
          "reach-body",
          !view.reachCompact.showNo && "hrr7-reach-compact-body--solo-yes",
        ]}
      >
        <div
          class:list={[
            "reach-item",
            "reach-item--yes",
            "hrr7-reach-item-yes",
            view.reachCard.yesZoneVariant === "neutral" && "reach-item--yes-neutral",
          ]}
        >
          <div class="reach-checkpoint" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true">
              <circle cx="14" cy="14" r="13" fill="#EAF3DE" stroke="#639922" stroke-width="1.5" />
              <path
                d="M8 14l4 4 8-8"
                stroke="#3B6D11"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
            </svg>
          </div>
          <div class="reach-info">
            <div class="reach-label">Llegás hasta</div>
            <div class="reach-place">{view.reachCompact.yesPlace}</div>
            {view.reachCompact.yesDetail ? (
              <div class="reach-detail">{view.reachCompact.yesDetail}</div>
            ) : null}
          </div>
        </div>
        {
          view.reachCompact.showNo ? (
            <>
              <div class="reach-separator hrr7-reach-separator" aria-hidden="true" />
              <div class="reach-item reach-item--no hrr7-reach-item-no">
                <div class="reach-checkpoint" aria-hidden="true">
                  <svg width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true">
                    <circle cx="14" cy="14" r="13" fill="#FCEBEB" stroke="#E24B4A" stroke-width="1.5" />
                    <path
                      d="M9.5 9.5l9 9M18.5 9.5l-9 9"
                      stroke="#A32D2D"
                      stroke-width="2.5"
                      stroke-linecap="round"
                    />
                  </svg>
                </div>
                <div class="reach-info">
                  <div class="reach-label">No cruzás por</div>
                  <div class="reach-place reach-place--no">{view.reachCompact.noPlace}</div>
                  {view.reachCompact.noDetail ? (
                    <div class="reach-detail reach-detail--no">{view.reachCompact.noDetail}</div>
                  ) : null}
                </div>
              </div>
            </>
          ) : null
        }
      </div>
    </div>

    <footer class="hrr7-foot">
      <span class="hrr7-source">Fuente: Vialidad Nacional</span>
      <a href="/cristo-redentor" class="hrr7-link-full">
        Ver detalle completo →
      </a>
    </footer>
  </div>
</section>

<script>
  import { mountHomeCristoRoute } from "@/scripts/homeCristoRoute.client.ts";

  mountHomeCristoRoute();
  document.addEventListener("astro:page-load", mountHomeCristoRoute);
</script>

---
const PROFILE_URL = "https://x.com/PasoCRMza";
---

<div class="tweet-card tweet-card--fallback anim-section">
  <div class="tweet-card-header">
    <svg
      width="13"
      height="13"
      viewBox="0 0 24 24"
      fill="currentColor"
      aria-hidden="true"
      style="color: var(--color-accent)"
    >
      <path
        d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"
      />
    </svg>
    <span class="tweet-handle">@PasoCRMza</span>
  </div>
  <p class="tweet-text">No hay novedad reciente cargada.</p>
  <div class="tweet-footer">
    <span class="tweet-disclaimer">Fuente complementaria · verificar en gob.ar</span>
    <a href={PROFILE_URL} target="_blank" rel="noopener noreferrer" class="tweet-cta tweet-cta--link">
      Ver perfil en X →
    </a>
  </div>
</div>

<style>
  .tweet-cta--link {
    text-decoration: none;
    color: inherit;
    font-weight: 600;
  }
  .tweet-cta--link:hover {
    text-decoration: underline;
  }
</style>

---
const MP_LINK = "https://link.mercadopago.com.ar/pasochilehoy";
/** Base mostrada la primera vez en este navegador (podés subirlo cuando quieras). */
const baseLikes = 47;
---

<section class="support-block-section" aria-label="Apoyo al proyecto">
  <div class="support-block" id="support-block" data-base-likes={baseLikes}>
    <div class="support-main">
      <div class="support-text">
        <p class="support-title">¿Te fue útil?</p>
        <p class="support-subtitle">
          Hecho por un mendocino, gratis y sin publicidad.
        </p>
      </div>

      <div class="support-actions">
        <button
          class="support-like-btn"
          id="support-like-btn"
          type="button"
          aria-label="Marcar como útil"
        >
          <svg
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3H14z" />
            <path d="M7 22H4a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h3" />
          </svg>
          <span id="support-like-count" class="support-like-count">···</span>
        </button>

        <a
          href={MP_LINK}
          target="_blank"
          rel="noopener noreferrer"
          class="support-donate-btn"
        >
          Apoyar →
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  (function () {
    const LIKES_KEY = "paso-chile-hoy-likes";
    const USER_LIKED_KEY = "paso-chile-hoy-user-liked";

    function init() {
      const btn = document.getElementById("support-like-btn");
      const countEl = document.getElementById("support-like-count");
      const block = document.getElementById("support-block");
      if (!btn || !countEl || !block || !(btn instanceof HTMLButtonElement)) return;

      const base = parseInt(block.getAttribute("data-base-likes") ?? "0", 10) || 0;

      function readCount() {
        const v = localStorage.getItem(LIKES_KEY);
        if (v != null) {
          const n = parseInt(v, 10);
          if (!Number.isNaN(n)) return n;
        }
        return base;
      }

      function writeCount(n: number) {
        localStorage.setItem(LIKES_KEY, String(n));
      }

      function hasUserLiked(): boolean {
        return localStorage.getItem(USER_LIKED_KEY) === "true";
      }

      function setUserLiked() {
        localStorage.setItem(USER_LIKED_KEY, "true");
      }

      const current = readCount();
      countEl.textContent = String(current);

      if (hasUserLiked()) {
        btn.classList.add("support-like-btn--active");
        btn.setAttribute("aria-label", "Ya marcaste esto como útil");
        btn.disabled = true;
      }

      btn.addEventListener("click", () => {
        if (hasUserLiked()) return;

        const newCount = readCount() + 1;
        writeCount(newCount);
        setUserLiked();

        countEl.textContent = String(newCount);
        btn.classList.add("support-like-btn--active");
        btn.setAttribute("aria-label", "Ya marcaste esto como útil");
        btn.disabled = true;

        btn.style.transform = "scale(1.12)";
        setTimeout(() => {
          btn.style.transform = "";
        }, 200);
      });
    }

    init();
    document.addEventListener("astro:page-load", init);
  })();
</script>

---
import { Icon } from "astro-icon/components";

const MP_LINK = "https://link.mercadopago.com.ar/pasochilehoy";
---

<section class="support-block-section" aria-label="Apoyo al proyecto">
  <div class="support-block" id="support-block">
    <div class="support-main support-main--split">
      <div class="support-text">
        <p class="support-line-strong">Este sitio lo hago solo, desde Mendoza.</p>
        <p class="support-line-muted">
          Gratis, sin publicidad y en tiempo real. Si te fue útil, apoyalo con un like o una colaboración.
        </p>
      </div>

      <div class="support-actions support-actions--stack">
        <button
          class="support-like-btn"
          id="support-like-btn"
          type="button"
          aria-label="Me sirvió"
        >
          <Icon name="lucide:thumbs-up" class="support-like-thumb" width="18" height="18" aria-hidden="true" />
          <span id="support-like-count" class="support-like-count">···</span>
          <span class="like-burst" id="like-burst" aria-hidden="true"></span>
        </button>

        <a
          href={MP_LINK}
          target="_blank"
          rel="noopener noreferrer"
          class="support-donate-btn"
        >
          <Icon name="lucide:heart" class="support-donate-heart" width="18" height="18" aria-hidden="true" />
          Apoyar
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  (function () {
    const USER_LIKED_KEY = "pch-liked";

    function hasVoted(): boolean {
      const v = localStorage.getItem(USER_LIKED_KEY);
      return v === "1" || v === "true";
    }

    function parseCountStrict(text: string): number | null {
      const t = text.trim();
      if (!/^\d+$/.test(t)) return null;
      const n = parseInt(t, 10);
      return Number.isFinite(n) ? n : null;
    }

    function createBurst(btn: HTMLButtonElement) {
      const burst = btn.querySelector(".like-burst");
      if (!(burst instanceof HTMLElement)) return;

      const colors = ["#5BAEFF", "#3DD68C", "#F0A830", "#E05555", "#C87941"];
      const count = 12;

      for (let i = 0; i < count; i++) {
        const particle = document.createElement("span");
        particle.className = "like-particle";

        const angle = (i / count) * 360;
        const distance = 30 + Math.random() * 20;
        const tx = Math.cos((angle * Math.PI) / 180) * distance;
        const ty = Math.sin((angle * Math.PI) / 180) * distance;

        particle.style.setProperty("--tx", `${tx}px`);
        particle.style.setProperty("--ty", `${ty}px`);
        particle.style.background = colors[i % colors.length] ?? "#5BAEFF";
        particle.style.animationDelay = `${Math.random() * 0.1}s`;

        burst.appendChild(particle);
        setTimeout(() => particle.remove(), 700);
      }
    }

    function flashPlusOne(btn: HTMLButtonElement) {
      const el = document.createElement("span");
      el.className = "support-plusone-float";
      el.textContent = "+1";
      btn.appendChild(el);
      requestAnimationFrame(() => {
        el.classList.add("support-plusone-float--visible");
      });
      setTimeout(() => {
        el.remove();
      }, 450);
    }

    function popThumb(btn: HTMLButtonElement) {
      const thumb = btn.querySelector(".support-like-thumb");
      if (!thumb) return;
      thumb.classList.remove("support-like-thumb--pop");
      void (thumb as HTMLElement).offsetWidth;
      thumb.classList.add("support-like-thumb--pop");
      setTimeout(() => thumb.classList.remove("support-like-thumb--pop"), 320);
    }

    async function init() {
      const btn = document.getElementById("support-like-btn");
      const countEl = document.getElementById("support-like-count");
      if (!btn || !countEl || !(btn instanceof HTMLButtonElement)) return;

      async function loadCount(el: HTMLElement): Promise<number> {
        try {
          const res = await fetch("/api/likes", { cache: "no-store" });
          const data = (await res.json()) as { likes?: number };
          const n = typeof data.likes === "number" ? data.likes : 0;
          el.textContent = String(n);
          return n;
        } catch {
          el.textContent = "···";
          return NaN;
        }
      }

      await loadCount(countEl);

      if (hasVoted()) {
        btn.classList.add("support-like-btn--active");
        btn.setAttribute("aria-label", "Ya marcaste que te sirvió");
        btn.disabled = true;
      } else {
        btn.classList.remove("support-like-btn--active");
        btn.setAttribute("aria-label", "Me sirvió");
        btn.disabled = false;
      }

      if (btn.dataset.pchLikesBound === "1") return;
      btn.dataset.pchLikesBound = "1";

      btn.addEventListener("click", async () => {
        if (hasVoted()) return;

        const prevText = countEl.textContent ?? "";
        const prevParsed = parseCountStrict(prevText);

        popThumb(btn);
        flashPlusOne(btn);
        createBurst(btn);

        if (prevParsed !== null) {
          countEl.textContent = String(prevParsed + 1);
        }
        btn.disabled = true;
        btn.classList.add("support-like-btn--active");

        try {
          const res = await fetch("/api/likes", { method: "POST" });
          const data = (await res.json()) as { likes?: number };
          if (typeof data.likes === "number") {
            countEl.textContent = String(data.likes);
          }
          localStorage.setItem(USER_LIKED_KEY, "1");
          btn.setAttribute("aria-label", "Ya marcaste que te sirvió");
        } catch {
          countEl.textContent = prevParsed !== null ? String(prevParsed) : prevText;
          btn.disabled = false;
          btn.classList.remove("support-like-btn--active");
        }
      });
    }

    void init();
    document.addEventListener("astro:page-load", () => void init());
  })();
</script>

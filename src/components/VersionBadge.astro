---
import { readFileSync, existsSync } from "node:fs";
import { join } from "node:path";

export interface Props {
  /** Badge más chico, sin borde fuerte — para móvil arriba a la derecha del título */
  compact?: boolean;
}

const { compact = false } = Astro.props;

let version = "0.1.0";
let releasedAt = "";

try {
  const versionPath = join(process.cwd(), "public", "version.json");
  if (existsSync(versionPath)) {
    const data = JSON.parse(readFileSync(versionPath, "utf-8")) as {
      version?: string;
      releasedAt?: string;
    };
    version = data.version ?? "0.1.0";
    releasedAt = data.releasedAt ?? "";
  }
} catch {
  // fallback silencioso
}

let releaseDateLabel = "";
if (releasedAt) {
  const d = new Date(releasedAt);
  releaseDateLabel = d.toLocaleDateString("es-AR", {
    day: "numeric",
    month: "short",
    year: "numeric",
  });
}
---

<span
  class:list={["version-badge", compact && "version-badge--compact"]}
  title={releasedAt ? `Publicado el ${releaseDateLabel}` : "Versión actual"}
  aria-label={`Versión ${version}`}
>
  <span class="version-dot" aria-hidden="true"></span>
  <span class="version-label">v{version}</span>
</span>

---
import { Icon } from "astro-icon/components";
import AltitudeWarning from "@/components/AltitudeWarning.astro";
import type { WeatherNowView } from "@/types/pass-view";
import { getWeatherIcon, getWeatherIconColor } from "@/utils/weatherIcon";
import {
  interpretTemperature,
  interpretVisibility,
  interpretWind,
  levelToColor,
} from "@/utils/weatherInterpretation";

export interface Props {
  weather: WeatherNowView;
  /** Texto pie (p. ej. datetime SMN en bruto). */
  updatedAt?: string;
  class?: string;
}

const MONTHS_SHORT = [
  "ene",
  "feb",
  "mar",
  "abr",
  "may",
  "jun",
  "jul",
  "ago",
  "sep",
  "oct",
  "nov",
  "dic",
] as const;

function formatDatosAl(note: string | undefined): string | null {
  if (!note?.trim()) return null;
  const s = note.trim();
  const m = s.match(/^(\d{1,2})\/(\d{1,2})\/(\d{4})\s*[-–]\s*(\d{1,2}):(\d{2})/);
  if (m) {
    const d = parseInt(m[1], 10);
    const mo = parseInt(m[2], 10);
    const month = MONTHS_SHORT[mo - 1] ?? m[2];
    return `Datos al ${d} ${month} · ${m[4]}:${m[5]} h`;
  }
  return `Datos al ${s}`;
}

function formatSunriseDisplay(sunrise: string | undefined): string {
  if (!sunrise?.trim()) return "—";
  let s = sunrise.trim();
  s = s.replace(/\s*h\s*h+\s*$/i, " h");
  if (/^\d{1,2}:\d{2}$/.test(s)) return `${s} h`;
  return s;
}

const { weather: w, updatedAt, class: className } = Astro.props;
const iconName = getWeatherIcon(w.description);
const iconColor = getWeatherIconColor(w.description);

const visInput: number | string | null =
  typeof w.visibilityKm === "number"
    ? w.visibilityKm
    : w.visibilityText?.trim()
      ? w.visibilityText.trim()
      : null;
const visData = interpretVisibility(visInput);
const windData = interpretWind(w.wind ?? null);
const tempData = interpretTemperature(w.temperatureC ?? null);

const sunriseDisplay = formatSunriseDisplay(w.sunrise);

const datosAlLine = formatDatosAl(updatedAt);

const tempBg = `color-mix(in srgb, ${levelToColor(tempData.level)} 10%, transparent)`;
---

<article
  class:list={[
    "w-full rounded-[var(--radius-xl)] border border-[var(--color-border-subtle)] bg-[var(--color-surface)] p-5 shadow-[var(--shadow-card)] min-[375px]:p-6 md:p-8",
    className,
  ]}
  aria-labelledby="weather-now-heading"
>
  <p class="text-eyebrow text-[var(--color-text-muted)]">Clima en el paso</p>
  <h2 id="weather-now-heading" class="text-section-title mt-2">Ahora</h2>

  {w.description && (
    <div class="weather-icon-block mt-4">
      <div class="weather-icon-wrapper">
        <Icon
          name={iconName}
          style={`color: ${iconColor}`}
          class="weather-icon-main"
          aria-hidden="true"
        />
      </div>
      <span class="text-weather-desc min-w-0">{w.description}</span>
    </div>
  )}

  {w.temperatureC != null && (
    <>
      <p class="mt-4 flex flex-wrap items-start gap-x-1 gap-y-0">
        <span class="temperature-display text-temperature text-[var(--color-text-primary)] tabular-nums">
          {w.temperatureC}
        </span>
        <span class="mt-2 font-display text-lg font-medium text-[var(--color-text-secondary)] md:text-2xl">
          °C
        </span>
      </p>
      {tempData.meaning && (
        <p class="temp-warning md:hidden">
          <Icon
            name="lucide:triangle-alert"
            class="temp-warning-icon h-3 w-3 shrink-0"
            style={`color: ${levelToColor(tempData.level)}`}
            aria-hidden="true"
          />
          <span style={`color: ${levelToColor(tempData.level)}`}>{tempData.meaning}</span>
        </p>
      )}
    </>
  )}

  <!-- Mobile: grilla compacta 3 cols -->
  <div class="weather-stats-grid md:hidden">
    <div class="weather-stat">
      <Icon name="lucide:wind" class="stat-icon" aria-hidden="true" />
      <span class="stat-label">Viento</span>
      <span class="stat-value" style={`color: ${levelToColor(windData.level)}`}>{windData.label}</span>
    </div>
    <div class="weather-stat">
      <Icon name="lucide:eye" class="stat-icon" aria-hidden="true" />
      <span class="stat-label">Visib.</span>
      <span class="stat-value" style={`color: ${levelToColor(visData.level)}`}>{visData.label}</span>
    </div>
    <div class="weather-stat">
      <Icon name="lucide:sunrise" class="stat-icon" aria-hidden="true" />
      <span class="stat-label">Amanecer</span>
      <span class="stat-value">{sunriseDisplay}</span>
    </div>
  </div>

  <!-- Desktop: stats expandidos -->
  <div class="weather-desktop-expanded hidden md:block">
    <div class="desktop-stats">
      <div class="desktop-stat-block">
        <div class="desktop-stat-header">
          <Icon
            name="lucide:wind"
            class="h-5 w-5 shrink-0"
            style={`color: ${levelToColor(windData.level)}`}
            aria-hidden="true"
          />
          <span class="desktop-stat-label">Viento</span>
        </div>
        <span class="desktop-stat-value">{windData.label}</span>
        {windData.meaning && <p class="desktop-stat-meaning">{windData.meaning}</p>}
      </div>
      <div class="desktop-stat-divider" aria-hidden="true"></div>
      <div class="desktop-stat-block">
        <div class="desktop-stat-header">
          <Icon
            name="lucide:eye"
            class="h-5 w-5 shrink-0"
            style={`color: ${levelToColor(visData.level)}`}
            aria-hidden="true"
          />
          <span class="desktop-stat-label">Visibilidad</span>
        </div>
        <span class="desktop-stat-value">{visData.label}</span>
        {visData.meaning && <p class="desktop-stat-meaning">{visData.meaning}</p>}
      </div>
      <div class="desktop-stat-divider" aria-hidden="true"></div>
      <div class="desktop-stat-block">
        <div class="desktop-stat-header">
          <Icon name="lucide:sunrise" class="h-5 w-5 shrink-0 text-[var(--color-text-muted)]" aria-hidden="true" />
          <span class="desktop-stat-label">Amanecer</span>
        </div>
        <span class="desktop-stat-value">{sunriseDisplay}</span>
        <p class="desktop-stat-meaning">Primera luz en la cordillera</p>
      </div>
    </div>

    {tempData.meaning && (
      <div
        class="desktop-temp-warning"
        style={`border-color: ${levelToColor(tempData.level)}; background: ${tempBg}; border-left-color: ${levelToColor(tempData.level)}`}
      >
        <Icon
          name="lucide:thermometer-snowflake"
          class="h-4 w-4 shrink-0"
          style={`color: ${levelToColor(tempData.level)}`}
          aria-hidden="true"
        />
        <p class="m-0 text-sm leading-snug" style={`color: ${levelToColor(tempData.level)}`}>
          {tempData.meaning}
        </p>
      </div>
    )}
  </div>

  <AltitudeWarning altitudeM={3200} />

  {datosAlLine && <p class="text-meta mt-5">{datosAlLine}</p>}
</article>

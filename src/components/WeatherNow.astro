---
import { Icon } from "astro-icon/components";
import DrivingConditions from "@/components/DrivingConditions.astro";
import type { ForecastItemView, WeatherNowView } from "@/types/pass-view";
import { getWeatherIcon, getWeatherIconColor } from "@/utils/weatherIcon";
import {
  interpretTemperature,
  interpretVisibility,
  interpretWind,
  levelToColor,
} from "@/utils/weatherInterpretation";
import { assessSnapshotFreshness } from "@/utils/snapshotFreshness";

export interface Props {
  weather: WeatherNowView;
  /** Pronóstico para anticipar nieve/lluvia aunque ahora esté despejado. */
  forecast?: ForecastItemView[];
  /** Texto pie (p. ej. datetime SMN en bruto). */
  updatedAt?: string;
  /** Momento del snapshot (JSON); para advertir si los datos son viejos. */
  scrapedAt?: string;
  /** Si es false, no incluye DrivingConditions (p. ej. se muestra a ancho completo en la página del paso). */
  includeDriving?: boolean;
  class?: string;
}

const MONTHS_SHORT = [
  "ene",
  "feb",
  "mar",
  "abr",
  "may",
  "jun",
  "jul",
  "ago",
  "sep",
  "oct",
  "nov",
  "dic",
] as const;

function formatDatosAl(note: string | undefined): string | null {
  if (!note?.trim()) return null;
  const s = note.trim();
  const iso = Date.parse(s);
  if (!Number.isNaN(iso)) {
    const d = new Date(iso);
    const parts = new Intl.DateTimeFormat("es-AR", {
      timeZone: "America/Argentina/Buenos_Aires",
      day: "numeric",
      month: "short",
      hour: "2-digit",
      minute: "2-digit",
      hour12: false,
    }).formatToParts(d);
    const day = parts.find((p) => p.type === "day")?.value ?? "";
    const month = parts.find((p) => p.type === "month")?.value ?? "";
    const hour = parts.find((p) => p.type === "hour")?.value ?? "";
    const minute = parts.find((p) => p.type === "minute")?.value ?? "";
    const mo = month.replace(/\.$/, "").toLowerCase();
    return `Datos al ${day} ${mo} · ${hour}:${minute} h`;
  }
  const m = s.match(/^(\d{1,2})\/(\d{1,2})\/(\d{4})\s*[-–]\s*(\d{1,2}):(\d{2})/);
  if (m) {
    const day = parseInt(m[1], 10);
    const mo = parseInt(m[2], 10);
    const month = MONTHS_SHORT[mo - 1] ?? m[2];
    return `Datos al ${day} ${month} · ${m[4]}:${m[5]} h`;
  }
  return `Datos al ${s}`;
}

/** Prioriza “hace X min” si el snapshot es reciente. */
function formatWeatherDataLine(note: string | undefined, scrapedAt: string | undefined): string | null {
  if (scrapedAt?.trim()) {
    const t = Date.parse(scrapedAt.trim());
    if (!Number.isNaN(t)) {
      const diffMin = Math.floor((Date.now() - t) / 60000);
      if (diffMin >= 0 && diffMin < 60) {
        return `Datos de hace ${diffMin} min`;
      }
    }
  }
  return formatDatosAl(note);
}

function formatSunriseDisplay(sunrise: string | undefined): string {
  if (!sunrise?.trim()) return "—";
  let s = sunrise.trim();
  s = s.replace(/\s*h\s*h+\s*$/i, " h");
  if (/^\d{1,2}:\d{2}$/.test(s)) return `${s} h`;
  return s;
}

const {
  weather: w,
  forecast = [],
  updatedAt,
  scrapedAt,
  includeDriving = true,
  class: className,
} = Astro.props;
const iconName = getWeatherIcon(w.description);
const iconColor = getWeatherIconColor(w.description);

const visInput: number | string | null =
  typeof w.visibilityKm === "number"
    ? w.visibilityKm
    : w.visibilityText?.trim()
      ? w.visibilityText.trim()
      : null;
const visData = interpretVisibility(visInput);
const windData = interpretWind(w.wind ?? null);
const tempData = interpretTemperature(w.temperatureC ?? null);

const sunriseDisplay = formatSunriseDisplay(w.sunrise);

const datosAlLine = formatWeatherDataLine(updatedAt, scrapedAt);

const tempBg = `color-mix(in srgb, ${levelToColor(tempData.level)} 10%, transparent)`;

const drivingWeather = {
  temperatureC: w.temperatureC ?? null,
  wind: w.wind ?? null,
  visibilityKm: visInput,
  description: w.description ?? "",
};

const freshness = assessSnapshotFreshness(scrapedAt);
---

<article
  class:list={[
    "weather-now-card w-full rounded-[var(--radius-xl)] border border-[var(--color-border-subtle)] bg-[var(--color-surface)] p-5 shadow-[var(--shadow-card)] min-[375px]:p-6",
    className,
  ]}
  aria-labelledby="weather-now-heading"
>
  <p class="text-eyebrow weather-eyebrow">Clima en el paso</p>
  <h2 id="weather-now-heading" class="text-section-title mt-2">Ahora</h2>

  {w.description && (
    <div class="weather-icon-block mt-4">
      <div class="weather-icon-wrapper">
        <Icon
          name={iconName}
          style={`color: ${iconColor}`}
          class="weather-icon-main"
          aria-hidden="true"
        />
      </div>
      <span class="text-weather-desc min-w-0">{w.description}</span>
    </div>
  )}

  {w.temperatureC != null && (
    <>
      <p class="mt-4 flex flex-wrap items-start gap-x-1 gap-y-0">
        <span class="temperature-display text-temperature text-[var(--color-text-primary)] tabular-nums">
          {w.temperatureC}
        </span>
        <span class="mt-2 font-display text-lg font-medium text-[var(--color-text-secondary)] md:text-2xl">
          °C
        </span>
      </p>
      {tempData.meaning && (
        <p class="temp-warning md:hidden">
          <Icon
            name="lucide:triangle-alert"
            class="temp-warning-icon h-3 w-3 shrink-0"
            style={`color: ${levelToColor(tempData.level)}`}
            aria-hidden="true"
          />
          <span style={`color: ${levelToColor(tempData.level)}`}>{tempData.meaning}</span>
        </p>
      )}
    </>
  )}

  <!-- Mobile: grilla compacta 3 cols -->
  <div class="weather-stats-grid md:hidden">
    <div class="weather-stat">
      <Icon name="lucide:wind" class="stat-icon" aria-hidden="true" />
      <span class="stat-label weather-label">Viento</span>
      <span
        class="stat-value weather-value weather-meta-value"
        style={`color: ${levelToColor(windData.level)}`}
      >
        {windData.label}
      </span>
    </div>
    <div class="weather-stat">
      <Icon name="lucide:eye" class="stat-icon" aria-hidden="true" />
      <span class="stat-label weather-label">Visib.</span>
      <span
        class="stat-value weather-value weather-meta-value"
        style={`color: ${levelToColor(visData.level)}`}
      >
        {visData.label}
      </span>
    </div>
    <div class="weather-stat">
      <Icon name="wi:sunrise" class="stat-icon stat-icon-sunrise" aria-hidden="true" />
      <span class="stat-label weather-label">Amanecer</span>
      <span class="stat-value weather-value weather-meta-value">{sunriseDisplay}</span>
    </div>
  </div>

  <!-- Desktop: stats expandidos -->
  <div class="weather-desktop-expanded hidden md:block">
    <div class="desktop-stats">
      <div class="desktop-stat-block">
        <div class="desktop-stat-header">
          <Icon
            name="lucide:wind"
            class="h-5 w-5 shrink-0"
            style={`color: ${levelToColor(windData.level)}`}
            aria-hidden="true"
          />
          <span class="desktop-stat-label weather-label">Viento</span>
        </div>
        <span class="desktop-stat-value weather-meta-value">{windData.label}</span>
        {windData.meaning && <p class="desktop-stat-meaning">{windData.meaning}</p>}
      </div>
      <div class="desktop-stat-divider" aria-hidden="true"></div>
      <div class="desktop-stat-block">
        <div class="desktop-stat-header">
          <Icon
            name="lucide:eye"
            class="h-5 w-5 shrink-0"
            style={`color: ${levelToColor(visData.level)}`}
            aria-hidden="true"
          />
          <span class="desktop-stat-label weather-label">Visibilidad</span>
        </div>
        <span class="desktop-stat-value weather-meta-value">{visData.label}</span>
        {visData.meaning && <p class="desktop-stat-meaning">{visData.meaning}</p>}
      </div>
      <div class="desktop-stat-divider" aria-hidden="true"></div>
      <div class="desktop-stat-block">
        <div class="desktop-stat-header">
          <Icon name="wi:sunrise" class="desktop-sunrise-icon h-6 w-6 shrink-0" aria-hidden="true" />
          <span class="desktop-stat-label weather-label">Amanecer</span>
        </div>
        <span class="desktop-stat-value weather-meta-value">{sunriseDisplay}</span>
        <p class="desktop-stat-meaning">Primera luz en la cordillera</p>
      </div>
    </div>

    {tempData.meaning && (
      <div
        class="desktop-temp-warning"
        style={`border-color: ${levelToColor(tempData.level)}; background: ${tempBg}; border-left-color: ${levelToColor(tempData.level)}`}
      >
        <Icon
          name="lucide:thermometer-snowflake"
          class="h-4 w-4 shrink-0"
          style={`color: ${levelToColor(tempData.level)}`}
          aria-hidden="true"
        />
        <p class="m-0 text-sm leading-snug" style={`color: ${levelToColor(tempData.level)}`}>
          {tempData.meaning}
        </p>
      </div>
    )}
  </div>

  {includeDriving && <DrivingConditions weather={drivingWeather} forecast={forecast} />}

  {datosAlLine && <p class="text-meta mt-5">{datosAlLine}</p>}

  {
    freshness.warningMessage && (
      <div class="staleness-warning" data-level={freshness.level}>
        <Icon name="lucide:clock-alert" class="staleness-warning-icon" aria-hidden="true" />
        <span>{freshness.warningMessage}</span>
      </div>
    )
  }
</article>

<style>
  .staleness-warning {
    display: flex;
    align-items: flex-start;
    gap: 6px;
    padding: 8px 12px;
    border-radius: var(--radius-sm);
    font-size: 11px;
    line-height: 1.4;
    margin-top: 8px;
  }

  .staleness-warning-icon {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
    margin-top: 1px;
  }

  .staleness-warning[data-level="stale"] {
    background: rgba(240, 168, 48, 0.08);
    border: 1px solid rgba(240, 168, 48, 0.2);
    color: var(--color-conditional);
  }

  .staleness-warning[data-level="very_stale"] {
    background: rgba(224, 85, 85, 0.08);
    border: 1px solid rgba(224, 85, 85, 0.2);
    color: var(--color-closed);
  }

  .staleness-warning[data-level="unknown"] {
    background: rgba(168, 180, 204, 0.06);
    border: 1px solid rgba(168, 180, 204, 0.15);
    color: var(--color-text-muted);
  }
</style>

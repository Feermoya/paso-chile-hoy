---
import { Icon } from "astro-icon/components";
import type { AlertView } from "@/types/pass-view";

export interface Props {
  alerts: AlertView[];
  class?: string;
}

const { alerts, class: className } = Astro.props;
---

{
  alerts.length > 0 && (
    <section
      class:list={[
        "rounded-[var(--radius-xl)] border border-[var(--color-border-subtle)] border-l-[3px] border-l-[var(--color-copper)] bg-[var(--color-copper-subtle)] p-5 md:p-6",
        className,
      ]}
      aria-labelledby="alerts-heading"
    >
      <div class="flex gap-3">
        <Icon
          name="lucide:triangle-alert"
          class="mt-0.5 h-5 w-5 shrink-0 text-[var(--color-copper-soft)]"
          aria-hidden="true"
        />
        <div class="min-w-0 flex-1">
          <h2 id="alerts-heading" class="font-display text-lg font-semibold text-[var(--color-copper-soft)]">
            Alertas publicadas
          </h2>
          <ul class="mt-4 space-y-5" role="list">
            {alerts.map((a) => (
              <li>
                <h3 class="font-medium text-[var(--color-copper-soft)]">{a.title ?? "Atención"}</h3>
                {a.source && <p class="mt-1 text-sm text-[var(--color-text-secondary)]">Fuente: {a.source}</p>}
                {a.description && (
                  <p class="mt-2 text-sm text-[var(--color-text-secondary)] md:text-[15px]">{a.description}</p>
                )}
                {a.detail && <p class="mt-2 text-sm text-[var(--color-text-muted)] md:text-[15px]">{a.detail}</p>}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>
  )
}

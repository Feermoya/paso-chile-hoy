---
import { shouldSuppressMotivoAlert } from "@/utils/motivoFilters";
import { dedupeHtmlAlertsAgainstJson } from "@/utils/dedupeHtmlAlerts";

export interface Props {
  motivo: string | null;
  motivoInfo?: string | null;
  htmlAlerts?: string[];
  vialidadRuta: string;
  vialidadTramo: string;
  vialidadEstado: string;
  vialidadObservaciones: string;
  class?: string;
}

const {
  motivo,
  motivoInfo,
  htmlAlerts,
  vialidadRuta,
  vialidadTramo,
  vialidadEstado,
  vialidadObservaciones,
  class: className,
} = Astro.props;

function buildVialidadTitle(estado: string, ruta: string, tramo: string): string {
  const parts: string[] = [];
  const e = estado.trim();
  if (e && e.toUpperCase() !== "HABILITADA") {
    parts.push(
      e
        .split(/\s+/)
        .map((w) => w.charAt(0).toUpperCase() + w.slice(1).toLowerCase())
        .join(" "),
    );
  }
  const rn = ruta.trim();
  if (rn) parts.push(`RN ${rn}`);
  const tr = tramo.trim();
  if (tr) parts.push(`Tramo: ${tr}`);
  return parts.join(", ");
}

const estU = (vialidadEstado ?? "").trim().toUpperCase();
const showVialidad = Boolean(estU && estU !== "HABILITADA");

const vialidadTitle = buildVialidadTitle(
  vialidadEstado ?? "",
  vialidadRuta ?? "",
  vialidadTramo ?? "",
);

const obs = (vialidadObservaciones ?? "").trim();
const showObs =
  Boolean(obs) &&
  obs.toLowerCase() !== "transitable" &&
  obs.length > 3;

const m = motivo?.trim() ?? "";
const showMotivo = Boolean(m) && !shouldSuppressMotivoAlert(m);

const info = motivoInfo?.trim() ?? "";
const showMotivoInfo = Boolean(info);

const htmlExtra = dedupeHtmlAlertsAgainstJson(htmlAlerts, {
  motivo: m || null,
  motivoInfo: info || null,
  vialidadObservaciones: obs || null,
});

const isCorteTotal = estU === "CORTE TOTAL" || estU.includes("CORTE TOTAL");

const hasContent =
  showVialidad || showMotivo || showMotivoInfo || htmlExtra.length > 0;

if (!hasContent) {
  return;
}
---

<div class:list={["alerts-section", className]} role="region" aria-label="Información operativa">
  {
    showVialidad && (
      <div
        class:list={[
          "alert-card",
          isCorteTotal ? "alert-card--danger" : "alert-card--warning",
        ]}
      >
        <p class="alert-card-eyebrow">
          <svg class="alert-card-eyebrow-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
          Atención
        </p>
        <p class="alert-card-title">{vialidadTitle}</p>
        {showObs && <p class="alert-card-detail">{obs}</p>}
      </div>
    )
  }
  {
    showMotivoInfo && (
      <div class="alert-card alert-card--warning">
        <p class="alert-card-eyebrow">
          <svg class="alert-card-eyebrow-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
          Atención
        </p>
        <p class="alert-card-title">{info}</p>
      </div>
    )
  }
  {
    showMotivo && (
      <div class="alert-card alert-card--warning">
        <p class="alert-card-eyebrow">
          <svg class="alert-card-eyebrow-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
          Atención
        </p>
        <p class="alert-card-title">{m}</p>
      </div>
    )
  }
  {
    htmlExtra.map((text) => (
      <div class="alert-card alert-card--warning alert-card--html-source">
        <p class="alert-card-eyebrow">
          <svg class="alert-card-eyebrow-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
          Atención
        </p>
        <p class="alert-card-title">{text}</p>
      </div>
    ))
  }
</div>

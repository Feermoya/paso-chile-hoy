---
import {
  buildOperationalNotices,
  type OperationalNoticeTone,
} from "@/utils/operationalNotices";

export interface Props {
  motivo: string | null;
  motivoInfo?: string | null;
  htmlAlerts?: string[];
  vialidadRuta: string;
  vialidadTramo: string;
  vialidadEstado: string;
  vialidadObservaciones: string;
  /** Evita repetir el badge del hero (ABIERTO / CERRADO / …). */
  statusDisplayLabel?: string;
  class?: string;
}

const {
  motivo,
  motivoInfo,
  htmlAlerts,
  vialidadRuta,
  vialidadTramo,
  vialidadEstado,
  vialidadObservaciones,
  statusDisplayLabel,
  class: className,
} = Astro.props;

const notices = buildOperationalNotices({
  motivo,
  motivoInfo,
  htmlAlerts,
  vialidadRuta,
  vialidadTramo,
  vialidadEstado,
  vialidadObservaciones,
  statusDisplayLabel,
});

if (notices.length === 0) {
  return;
}

const toneClass: Record<OperationalNoticeTone, string> = {
  danger: "operational-notice--danger",
  warning: "operational-notice--warning",
  info: "operational-notice--info",
};
---

<div class:list={["operational-notices alerts-section", className]} role="region" aria-label="Avisos operativos">
  {
    notices.map((n) => (
      <article class:list={["operational-notice", toneClass[n.tone]]}>
        <p class="operational-notice__label">{n.label}</p>
        <p class="operational-notice__text">{n.text}</p>
      </article>
    ))
  }
</div>

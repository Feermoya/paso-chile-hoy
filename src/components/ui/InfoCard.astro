---
export interface Props {
  title: string;
  eyebrow?: string;
  className?: string;
}

const { title, eyebrow, className = "" } = Astro.props;
---

<article
  class:list={[
    "rounded-2xl border border-line/80 bg-white/70 p-5 shadow-card backdrop-blur-sm md:p-6",
    className,
  ]}
>
  {eyebrow && (
    <p class="mb-2 text-xs font-medium uppercase tracking-[0.12em] text-ink-muted">{eyebrow}</p>
  )}
  <h3 class="text-base font-semibold text-ink md:text-lg">{title}</h3>
  <div class="mt-3 text-[15px] text-ink-muted md:text-base">
    <slot />
  </div>
</article>

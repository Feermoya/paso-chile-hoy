---
export interface Props {
  title: string;
  subtitle?: string;
  id?: string;
}

const { title, subtitle, id } = Astro.props;
---

<div class="mb-6 md:mb-8">
  <h2 class="text-balance" {...(id ? { id } : {})}>
    {title}
  </h2>
  {subtitle && (
    <p class="mt-2 max-w-2xl text-[15px] text-ink-muted md:text-base">{subtitle}</p>
  )}
</div>

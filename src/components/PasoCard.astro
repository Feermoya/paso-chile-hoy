---
import type { PasoConfig } from "@/data/pasos";
import { isVialidadCorteTotal, type PassDisplayStatus } from "@/utils/inferPassStatus";

export interface Props {
  paso: PasoConfig;
  status?: PassDisplayStatus;
  displayLabel?: string;
  closesInMinutes?: number;
  opensInMinutes?: number;
  weatherDesc?: string;
  weatherTempC?: number | null;
  vialidadEstado?: string;
  vialidadObservaciones?: string;
}

const {
  paso,
  status = "sin_datos",
  displayLabel,
  closesInMinutes,
  opensInMinutes,
  weatherDesc,
  weatherTempC,
  vialidadEstado,
  vialidadObservaciones,
} = Astro.props;

function formatCountdown(minutes: number): string {
  if (minutes <= 0) return "";
  if (minutes < 60) return `${minutes} min`;
  const h = Math.floor(minutes / 60);
  const m = minutes % 60;
  return m > 0 ? `${h}h ${m}min` : `${h}h`;
}

const showCorteVial = isVialidadCorteTotal(vialidadEstado);

const isOpen =
  status === "abierto" ||
  (status === "condicionado" && displayLabel?.trim().toUpperCase() === "ABIERTO");
const isClosed = status === "cerrado";
const showClosesIn = isOpen && closesInMinutes != null && closesInMinutes > 0;
const showOpensIn = isClosed && opensInMinutes != null && opensInMinutes > 0;
const closingSoon = showClosesIn && closesInMinutes! <= 60;

const badgeLabel = displayLabel?.trim() || status.toUpperCase();
const href = paso.active ? `/${paso.slug}` : undefined;
---

{
  href ? (
    <a
      href={href}
      class:list={["paso-card-v2", `paso-card-v2--${status}`]}
      aria-label={`Ver estado de ${paso.shortName}`}
    >
      <div class="pcv2-status-row">
        <span class:list={["pcv2-badge", `pcv2-badge--${status}`]}>{badgeLabel}</span>
        {showClosesIn && (
          <span
            class:list={[
              "pcv2-countdown",
              closingSoon && "pcv2-countdown--urgent",
            ]}
          >
            Cierra en {formatCountdown(closesInMinutes!)}
          </span>
        )}
        {showOpensIn && (
          <span class="pcv2-countdown pcv2-countdown--opens">
            Abre en {formatCountdown(opensInMinutes!)}
          </span>
        )}
      </div>

      <h3 class="pcv2-name">{paso.shortName}</h3>

      {(weatherTempC != null || weatherDesc?.trim()) && (
        <div class="pcv2-temp-row">
          {weatherTempC != null && <span class="pcv2-temp">{weatherTempC}°</span>}
          {weatherDesc?.trim() && (
            <span class="pcv2-weather-desc">{weatherDesc.trim()}</span>
          )}
        </div>
      )}

      {showCorteVial && (
        <div class="pcv2-alert">
          ⚠ {vialidadObservaciones?.trim() || "Corte vial"}
        </div>
      )}

      <div class="pcv2-footer">
        <span class="pcv2-locality">
          {paso.localityAR} → {paso.localityCL}
        </span>
        <span class="pcv2-more">Ver más →</span>
      </div>
    </a>
  ) : (
    <div class="paso-card-v2 paso-card-v2--disabled" aria-disabled="true">
      <div class="pcv2-status-row">
        <span class="pcv2-badge pcv2-badge--sin_datos">PRÓXIMAMENTE</span>
      </div>
      <h3 class="pcv2-name">{paso.shortName}</h3>
      <div class="pcv2-footer">
        <span class="pcv2-locality">
          {paso.localityAR} → {paso.localityCL}
        </span>
      </div>
    </div>
  )
}

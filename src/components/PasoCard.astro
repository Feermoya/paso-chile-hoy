---
import { Icon } from "astro-icon/components";
import type { PasoConfig } from "@/data/pasos";
import { isVialidadCorteTotal, type PassDisplayStatus } from "@/utils/inferPassStatus";
import { getWeatherIcon, getWeatherIconColor } from "@/utils/weatherIcon";

export interface Props {
  paso: PasoConfig;
  status?: PassDisplayStatus;
  displayLabel?: string;
  closesInMinutes?: number;
  opensInMinutes?: number;
  weatherDesc?: string;
  weatherTempC?: number | null;
  vialidadEstado?: string;
  vialidadObservaciones?: string;
}

const {
  paso,
  status = "sin_datos",
  displayLabel,
  closesInMinutes,
  opensInMinutes,
  weatherDesc,
  weatherTempC,
  vialidadEstado,
  vialidadObservaciones,
} = Astro.props;

function fmtMinutes(min: number): string {
  if (min < 60) return `${min} min`;
  const h = Math.floor(min / 60);
  const m = min % 60;
  return m > 0 ? `${h}h ${m}min` : `${h}h`;
}

const isOpen =
  status === "abierto" ||
  (status === "condicionado" && displayLabel?.trim().toUpperCase() === "ABIERTO");
const isClosed = status === "cerrado";
const showClosesIn = isOpen && closesInMinutes != null && closesInMinutes > 0;
const showOpensIn = isClosed && opensInMinutes != null && opensInMinutes > 0;
const closingSoon = showClosesIn && closesInMinutes! <= 60;

const estU = (vialidadEstado ?? "").trim().toUpperCase();
const hasVialidad =
  Boolean(estU && !estU.includes("HABILITADA")) &&
  (isVialidadCorteTotal(vialidadEstado) ||
    estU.includes("RESTRINGIDA") ||
    estU.includes("CORTE"));

const defaultBadgeLabel: Record<PassDisplayStatus, string> = {
  abierto: "ABIERTO",
  cerrado: "CERRADO",
  condicionado: "CONDICIONADO",
  sin_datos: "SIN DATOS",
};
/** CONDICIONADO siempre en badge naranja; no reutilizar "ABIERTO" de Gendarmería cuando el estado inferido es condicionado. */
const label =
  status === "condicionado" ? "CONDICIONADO" : (displayLabel?.trim() || defaultBadgeLabel[status]);
const href = paso.active ? `/${paso.slug}` : undefined;
const desc = weatherDesc?.trim() ?? "";
const routeLabel = `${paso.localityAR} — ${paso.localityCL}`;
const weatherIconName = desc ? getWeatherIcon(desc) : null;
const weatherIconColor = desc ? getWeatherIconColor(desc) : undefined;
const tempStr = weatherTempC != null ? String(weatherTempC) : null;
---

{
  href ? (
    <a
      href={href}
      class:list={["paso-card-v2", `paso-card-v2--${status}`]}
      aria-label={`Ver estado de ${paso.shortName}`}
    >
      <div class="pcv2-top">
        <h3 class="pcv2-name">{paso.shortName}</h3>
        <span class:list={["pcv2-badge", `pcv2-badge--${status}`]}>
          <span class:list={["pcv2-badge-dot", status !== "sin_datos" && "pcv2-badge-dot--pulse"]} aria-hidden="true" />
          <span class="pcv2-badge-label">{label}</span>
        </span>
      </div>

      <div class="pcv2-metric">
        <div class="pcv2-temp-line">
          {tempStr != null ? (
            <>
              <span class="pcv2-temp-value">{tempStr}</span>
              <sup class="pcv2-temp-unit">°</sup>
            </>
          ) : (
            <>
              <span class="pcv2-temp-value pcv2-temp-value--na">—</span>
              <sup class="pcv2-temp-unit pcv2-temp-unit--na">°</sup>
            </>
          )}
        </div>
        {desc && weatherIconName ? (
          <div class="pcv2-weather-line">
            <Icon
              name={weatherIconName}
              class="pcv2-weather-icon"
              width="20"
              height="20"
              style={weatherIconColor ? `color: ${weatherIconColor}` : undefined}
              aria-hidden="true"
            />
            <span class="pcv2-weather-text">{desc}</span>
          </div>
        ) : desc ? (
          <div class="pcv2-weather-line">
            <span class="pcv2-weather-text">{desc}</span>
          </div>
        ) : null}
      </div>

      {(showClosesIn || showOpensIn) && (
        <div class="pcv2-chips">
          {showClosesIn && (
            <span class:list={["pcv2-chip", closingSoon && "pcv2-chip--urgent"]}>
              Cierra en {fmtMinutes(closesInMinutes!)}
            </span>
          )}
          {showOpensIn && (
            <span class="pcv2-chip pcv2-chip--muted">Abre en {fmtMinutes(opensInMinutes!)}</span>
          )}
        </div>
      )}

      {hasVialidad && (
        <div class="pcv2-alert-banner" role="alert">
          <span class="pcv2-alert-dot" aria-hidden="true" />
          <Icon name="lucide:triangle-alert" class="pcv2-alert-icon" width="18" height="18" aria-hidden="true" />
          <span class="pcv2-alert-text">{vialidadObservaciones?.trim() || "Alerta vial activa"}</span>
        </div>
      )}

      <div class="pcv2-footer">
        <div class="pcv2-route-wrap">
          <Icon name="lucide:route" class="pcv2-route-icon" width="15" height="15" aria-hidden="true" />
          <span class="pcv2-route">{routeLabel}</span>
        </div>
        <Icon
          name="lucide:chevron-right"
          class:list={["pcv2-footer-chevron", `pcv2-footer-chevron--${status}`]}
          width="18"
          height="18"
          aria-hidden="true"
        />
      </div>
    </a>
  ) : (
    <div class="paso-card-v2 paso-card-v2--disabled paso-card-v2--sin_datos" aria-disabled="true">
      <div class="pcv2-top">
        <h3 class="pcv2-name">{paso.shortName}</h3>
        <span class="pcv2-badge pcv2-badge--sin_datos">
          <span class="pcv2-badge-dot" aria-hidden="true" />
          <span class="pcv2-badge-label">Próximamente</span>
        </span>
      </div>
      <div class="pcv2-metric">
        <div class="pcv2-temp-line">
          <span class="pcv2-temp-value pcv2-temp-value--na">—</span>
          <sup class="pcv2-temp-unit pcv2-temp-unit--na">°</sup>
        </div>
      </div>
      <div class="pcv2-footer">
        <div class="pcv2-route-wrap">
          <Icon name="lucide:route" class="pcv2-route-icon" width="15" height="15" aria-hidden="true" />
          <span class="pcv2-route">{routeLabel}</span>
        </div>
      </div>
    </div>
  )
}

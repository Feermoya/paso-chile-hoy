---
import { Icon } from "astro-icon/components";
import type { PasoConfig } from "@/data/pasos";
import type { ForecastItemView } from "@/types/pass-view";
import { isVialidadCorteTotal, type PassDisplayStatus } from "@/utils/inferPassStatus";
import {
  getWeatherIconHtml,
  getWeatherPreviewAlert,
  getWeatherVariant,
  type PassCardWeatherVariant,
} from "@/utils/passCardWeather";

const STATUS_ARIA: Record<PassDisplayStatus, string> = {
  abierto: "abierto",
  cerrado: "cerrado",
  condicionado: "condicionado",
  sin_datos: "sin datos",
};

/** Etiqueta corta para lectura rápida en home (sin MAYÚSCULAS de badge). */
const SHORT_STATUS_LABEL: Record<PassDisplayStatus, string> = {
  abierto: "Abierto",
  cerrado: "Cerrado",
  condicionado: "Condicionado",
  sin_datos: "Sin datos",
};

export interface Props {
  paso: PasoConfig;
  /** Home minimal: franja de estado (punto + Abierto/Cerrado) sin badge pill. */
  statusDotsOnly?: boolean;
  status?: PassDisplayStatus;
  displayLabel?: string;
  closesInMinutes?: number;
  opensInMinutes?: number;
  weatherDesc?: string;
  weatherTempC?: number | null;
  weatherWind?: string;
  vialidadEstado?: string;
  vialidadObservaciones?: string;
  vialidadRuta?: string;
  vialidadTramo?: string;
  htmlAlerts?: string[];
  forecast?: ForecastItemView[];
  rawStatus?: string;
  motivo?: string;
  motivoInfo?: string | null;
}

const {
  paso,
  statusDotsOnly = false,
  status = "sin_datos",
  displayLabel,
  closesInMinutes,
  opensInMinutes,
  weatherDesc,
  weatherTempC,
  weatherWind,
  vialidadEstado,
  vialidadObservaciones,
  vialidadRuta,
  vialidadTramo,
  htmlAlerts,
  forecast,
  rawStatus,
  motivo,
  motivoInfo,
} = Astro.props;

function fmtMinutes(min: number): string {
  if (min < 60) return `${min} min`;
  const h = Math.floor(min / 60);
  const m = min % 60;
  return m > 0 ? `${h}h ${m}min` : `${h}h`;
}

const hasVialidad = isVialidadCorteTotal(vialidadEstado);

/** No mostrar la card como “abierta” si hay corte total de RN/túnel aunque el badge diga ABIERTO (API desfasado). */
const isOpen =
  status === "abierto" ||
  (status === "condicionado" &&
    displayLabel?.trim().toUpperCase() === "ABIERTO" &&
    !hasVialidad);
const isClosed = status === "cerrado";
const showClosesIn = isOpen && closesInMinutes != null && closesInMinutes > 0;
const showOpensIn = isClosed && opensInMinutes != null && opensInMinutes > 0;
const closingSoon = showClosesIn && closesInMinutes! <= 60;

const defaultBadgeLabel: Record<PassDisplayStatus, string> = {
  abierto: "ABIERTO",
  cerrado: "CERRADO",
  condicionado: "CONDICIONADO",
  sin_datos: "SIN DATOS",
};

const displayTrim = displayLabel?.trim() ?? "";
const displayUpper = displayTrim.toUpperCase();
const label = displayTrim || defaultBadgeLabel[status];

const uiStatus: PassDisplayStatus =
  status === "condicionado" && displayUpper === "ABIERTO" && !hasVialidad ? "abierto" : status;

const statusDataAttr =
  uiStatus === "abierto"
    ? "ABIERTO"
    : uiStatus === "cerrado"
      ? "CERRADO"
      : uiStatus === "condicionado"
        ? "CONDICIONADO"
        : "SIN_DATOS";

const href = paso.active ? `/${paso.slug}` : undefined;
const desc = weatherDesc?.trim() ?? "";
const routeLabel = `${paso.localityAR} — ${paso.localityCL}`;
const tempStr = weatherTempC != null ? String(weatherTempC) : null;

const weatherVariant: PassCardWeatherVariant = desc
  ? getWeatherVariant(desc, weatherWind)
  : "sunny";
const weatherIconHtml = getWeatherIconHtml(weatherVariant);
const quickStatusLabel = SHORT_STATUS_LABEL[uiStatus];

const weatherPreview = getWeatherPreviewAlert({
  htmlAlerts,
  forecast,
  vialidadObservaciones,
  vialidadEstado,
  vialidadRuta,
  vialidadTramo,
  rawStatus,
  motivo,
  motivoInfo,
  displayStatus: uiStatus,
  displayLabel: label,
});
---

{
  href ? (
    <a
      href={href}
      class:list={["paso-card-v2", "pass-card", `paso-card-v2--${uiStatus}`]}
      data-weather={weatherVariant}
      data-slug={paso.slug}
      aria-label={`${paso.shortName}, ${STATUS_ARIA[uiStatus]}`}
      title={`${paso.shortName} — ${STATUS_ARIA[uiStatus]}`}
    >
      <div class="pass-card-weather-icon" set:html={weatherIconHtml} aria-hidden="true" />

      <div class:list={["pass-card-header", statusDotsOnly && "pass-card-header--minimal"]}>
        <h3 class="pass-card-name">{paso.shortName}</h3>
        {
          !statusDotsOnly && (
            <div class="pass-card-status-badge" data-status={statusDataAttr}>
              <span class:list={["status-dot", uiStatus !== "sin_datos" && "status-dot--pulse"]} aria-hidden="true" />
              <span>{label}</span>
            </div>
          )
        }
      </div>

      {
        statusDotsOnly && (
          <p
            class:list={["pass-card-status-strip", `pass-card-status-strip--${uiStatus}`]}
            role="status"
          >
            <span
              class:list={[
                "pass-card-status-strip__dot",
                uiStatus !== "sin_datos" && "pass-card-status-strip__dot--pulse",
              ]}
              aria-hidden="true"
            />
            <span class="pass-card-status-strip__label">{quickStatusLabel}</span>
          </p>
        )
      }

      <div class="pass-card-temp">
        {tempStr != null ? (
          <>
            <span class="temp-main">{tempStr}</span>
            <span class="temp-deg">°</span>
          </>
        ) : (
          <>
            <span class="temp-main temp-main--na">—</span>
            <span class="temp-deg temp-deg--na">°</span>
          </>
        )}
      </div>

      {
        desc ? (
          <div class="pass-card-condition">{desc}</div>
        ) : (
          <div class="pass-card-condition pass-card-condition--muted">Sin datos de clima</div>
        )
      }

      {
        weatherPreview ? (
          <div
            class:list={["pass-card-alert-preview", weatherPreview.critical && "critical"]}
            aria-live="polite"
          >
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path
                d="M12 9v4M12 17h.01M10.3 3.6L1.8 18a1 1 0 00.9 1.5h18.6a1 1 0 00.9-1.5L13.7 3.6a1 1 0 00-1.8 0z"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
            </svg>
            <span>{weatherPreview.text}</span>
          </div>
        ) : null
      }

      {
        hasVialidad && (
          <div class="pcv2-alert-banner" role="alert">
            <span class="pcv2-alert-dot" aria-hidden="true" />
            <Icon name="lucide:triangle-alert" class="pcv2-alert-icon" width="18" height="18" aria-hidden="true" />
            <span class="pcv2-alert-text">{vialidadObservaciones?.trim() || "Alerta vial activa"}</span>
          </div>
        )
      }

      {
        (showClosesIn || showOpensIn) && (
          <div class:list={["pass-card-closes", closingSoon && "pass-card-closes--urgent"]}>
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="2" />
              <path d="M12 7v6l4 2" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
            </svg>
            {showClosesIn && <span>Cierra en {fmtMinutes(closesInMinutes!)}</span>}
            {showOpensIn && <span>Abre en {fmtMinutes(opensInMinutes!)}</span>}
          </div>
        )
      }

      <div class="pass-card-route">
        <Icon name="lucide:route" width="15" height="15" aria-hidden="true" />
        <span>{routeLabel}</span>
        <Icon
          name="lucide:chevron-right"
          class:list={["pass-card-arrow", `pass-card-arrow--${uiStatus}`]}
          width="18"
          height="18"
          aria-hidden="true"
        />
      </div>
    </a>
  ) : (
    <div
      class:list={["paso-card-v2", "pass-card", "paso-card-v2--disabled", "paso-card-v2--sin_datos"]}
      data-weather="cloudy"
      data-slug={paso.slug}
      aria-disabled="true"
    >
      <div class="pass-card-weather-icon" set:html={getWeatherIconHtml("cloudy")} aria-hidden="true" />

      <div class="pass-card-header">
        <h3 class="pass-card-name">{paso.shortName}</h3>
        <div class="pass-card-status-badge" data-status="SIN_DATOS">
          <span class="status-dot" aria-hidden="true" />
          <span>Próximamente</span>
        </div>
      </div>

      <div class="pass-card-temp">
        <span class="temp-main temp-main--na">—</span>
        <span class="temp-deg temp-deg--na">°</span>
      </div>
      <div class="pass-card-condition pass-card-condition--muted">Sin datos de clima</div>

      <div class="pass-card-route">
        <Icon name="lucide:route" width="15" height="15" aria-hidden="true" />
        <span>{routeLabel}</span>
      </div>
    </div>
  )
}

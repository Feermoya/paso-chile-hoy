---
import type { PasoConfig } from "@/data/pasos";
import { isVialidadCorteTotal, type PassDisplayStatus } from "@/utils/inferPassStatus";

export interface Props {
  paso: PasoConfig;
  status?: PassDisplayStatus;
  displayLabel?: string;
  closesInMinutes?: number;
  opensInMinutes?: number;
  weatherDesc?: string;
  weatherTempC?: number | null;
  vialidadEstado?: string;
  vialidadObservaciones?: string;
}

const {
  paso,
  status = "sin_datos",
  displayLabel,
  closesInMinutes,
  opensInMinutes,
  weatherDesc,
  weatherTempC,
  vialidadEstado,
  vialidadObservaciones,
} = Astro.props;

function fmtMinutes(min: number): string {
  if (min < 60) return `${min} min`;
  const h = Math.floor(min / 60);
  const m = min % 60;
  return m > 0 ? `${h}h ${m}min` : `${h}h`;
}

const isOpen =
  status === "abierto" ||
  (status === "condicionado" && displayLabel?.trim().toUpperCase() === "ABIERTO");
const isClosed = status === "cerrado";
const showClosesIn = isOpen && closesInMinutes != null && closesInMinutes > 0;
const showOpensIn = isClosed && opensInMinutes != null && opensInMinutes > 0;
const closingSoon = showClosesIn && closesInMinutes! <= 60;

const estU = (vialidadEstado ?? "").trim().toUpperCase();
const hasVialidad =
  Boolean(estU && !estU.includes("HABILITADA")) &&
  (isVialidadCorteTotal(vialidadEstado) ||
    estU.includes("RESTRINGIDA") ||
    estU.includes("CORTE"));

const label = displayLabel?.trim() || status.toUpperCase();
const href = paso.active ? `/${paso.slug}` : undefined;
const desc = weatherDesc?.trim() ?? "";
const routeLabel = `${paso.localityAR} — ${paso.localityCL}`;
---

{
  href ? (
    <a
      href={href}
      class:list={["paso-card-v2", `paso-card-v2--${status}`]}
      aria-label={`Ver estado de ${paso.shortName}`}
    >
      <div class="pcv2-top">
        <h3 class="pcv2-name">{paso.shortName}</h3>
        <span class:list={["pcv2-badge", `pcv2-badge--${status}`]}>
          <span class="pcv2-badge-dot" aria-hidden="true" />
          <span class="pcv2-badge-label">{label}</span>
        </span>
      </div>

      <div class="pcv2-metric">
        {weatherTempC != null ? (
          <span class="pcv2-temp">{weatherTempC}°</span>
        ) : (
          <span class="pcv2-temp pcv2-temp--na">—°</span>
        )}
        {desc ? <p class="pcv2-weather-desc">{desc}</p> : null}
      </div>

      {(showClosesIn || showOpensIn) && (
        <div class="pcv2-chips">
          {showClosesIn && (
            <span class:list={["pcv2-chip", closingSoon && "pcv2-chip--urgent"]}>
              Cierra en {fmtMinutes(closesInMinutes!)}
            </span>
          )}
          {showOpensIn && (
            <span class="pcv2-chip pcv2-chip--muted">Abre en {fmtMinutes(opensInMinutes!)}</span>
          )}
        </div>
      )}

      {hasVialidad && (
        <p class="pcv2-notice">
          <span class="pcv2-notice-mark" aria-hidden="true">!</span>
          {vialidadObservaciones?.trim() || "Alerta vial activa"}
        </p>
      )}

      <div class="pcv2-footer">
        <span class="pcv2-route">{routeLabel}</span>
        <span class="pcv2-disclosure" aria-hidden="true" />
      </div>
    </a>
  ) : (
    <div class="paso-card-v2 paso-card-v2--disabled paso-card-v2--sin_datos" aria-disabled="true">
      <div class="pcv2-top">
        <h3 class="pcv2-name">{paso.shortName}</h3>
        <span class="pcv2-badge pcv2-badge--sin_datos">
          <span class="pcv2-badge-dot" aria-hidden="true" />
          <span class="pcv2-badge-label">Próximamente</span>
        </span>
      </div>
      <div class="pcv2-metric">
        <span class="pcv2-temp pcv2-temp--na">—°</span>
      </div>
      <div class="pcv2-footer">
        <span class="pcv2-route">{routeLabel}</span>
      </div>
    </div>
  )
}

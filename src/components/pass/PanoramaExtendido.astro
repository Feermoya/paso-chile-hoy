---
import {
  stripBulletinHtml,
  type ExtendedDayRiskLevel,
  type ExtendedForecastSignal,
} from "@/lib/external/mendozaExtendedForecast";

export interface Props {
  signal: ExtendedForecastSignal;
  class?: string;
}

const { signal, class: className } = Astro.props;
const days = signal.relevantDays ?? [];

function ringClass(level: ExtendedDayRiskLevel): string {
  switch (level) {
    case "high":
      return "panorama-ext-card--high";
    case "moderate":
      return "panorama-ext-card--moderate";
    default:
      return "panorama-ext-card--low";
  }
}

function levelLabel(level: ExtendedDayRiskLevel): string {
  switch (level) {
    case "high":
      return "Enfoque alto";
    case "moderate":
      return "Enfoque moderado";
    default:
      return "Enfoque bajo";
  }
}
---

{
  days.length > 0 && (
    <section
      class:list={["anim-section anim-delay-3 mt-4", className]}
      aria-labelledby="panorama-ext-heading"
    >
      <h2
        id="panorama-ext-heading"
        class="mb-1 text-[1.05rem] font-semibold tracking-tight text-[var(--color-text-primary)]"
      >
        Panorama extendido
      </h2>
      <p class="mb-3 max-w-prose text-[0.72rem] leading-relaxed text-[var(--color-text-muted)]">
        Complemento al pronóstico por horas: boletín provincial (Alta Montaña), por día.
      </p>
      <ul class="panorama-ext-list m-0 list-none space-y-3 p-0" role="list">
        {days.map((d) => {
          const summary = stripBulletinHtml(d.summary);
          const detail = stripBulletinHtml(d.detail);
          return (
          <li>
            <article
              class:list={[
                "panorama-ext-article rounded-xl border border-[var(--color-border-subtle)] p-4 shadow-sm",
                ringClass(d.riskLevel),
              ]}
            >
              <div class="mb-3 flex flex-wrap items-start justify-between gap-2">
                <h3 class="m-0 text-[0.95rem] font-semibold leading-tight text-[var(--color-text-primary)]">
                  {d.dayLabel}
                </h3>
                <span
                  class="shrink-0 rounded-full border border-[var(--color-border-subtle)] bg-[var(--color-surface-raised)] px-2.5 py-1 text-[0.62rem] font-semibold uppercase tracking-wide text-[var(--color-text-secondary)]"
                  data-panorama-risk={d.riskLevel}
                >
                  {levelLabel(d.riskLevel)}
                </span>
              </div>
              <p class="mb-2 text-[0.84rem] font-medium leading-snug text-[var(--color-text-primary)]">
                {summary}
              </p>
              <p class="mb-0 text-[0.78rem] leading-relaxed text-[var(--color-text-secondary)]">
                {detail}
              </p>
              {d.keywords.length > 0 && (
                <p class="mt-3 text-[0.68rem] leading-snug text-[var(--color-text-muted)] [overflow-wrap:anywhere]">
                  <span class="font-semibold text-[var(--color-text-secondary)]">Señales:</span>{" "}
                  {d.keywords.join(", ")}
                </p>
              )}
            </article>
          </li>
          );
        })}
      </ul>
    </section>
  )
}

<style>
  .panorama-ext-card--low {
    border-left: 4px solid rgb(34 197 94);
    background: rgba(34 197 94 / 0.06);
  }
  .panorama-ext-card--moderate {
    border-left: 4px solid rgb(234 179 8);
    background: rgba(234 179 8 / 0.08);
  }
  .panorama-ext-card--high {
    border-left: 4px solid rgb(249 115 22);
    background: rgba(249 115 22 / 0.09);
  }
</style>

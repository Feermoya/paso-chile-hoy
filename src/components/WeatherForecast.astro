---
import { Icon } from "astro-icon/components";
import type { ForecastItemView } from "@/types/pass-view";
import { getWeatherIcon, getWeatherIconColor } from "@/utils/weatherIcon";
import {
  levelClass,
  translateConditionLevel,
  translateForecastVisibilityLabel,
  translateWindWithDir,
} from "@/utils/weatherTranslate";

export interface Props {
  forecast: ForecastItemView[];
  class?: string;
}

const { forecast, class: className } = Astro.props;

function getForecastDate(period: string): string {
  const p = period.toLowerCase();
  const base = p.includes("mañana") ? new Date(Date.now() + 86400000) : new Date();
  return base.toLocaleDateString("es-AR", {
    weekday: "short",
    day: "numeric",
    month: "short",
  });
}

/** Fecha bajo el título: `period.date` si parsea; si no, heurística por nombre del período. */
function formatForecastDateLine(period: ForecastItemView): string {
  const raw = period.date?.trim();
  if (raw) {
    const t = Date.parse(raw);
    if (!Number.isNaN(t)) {
      return new Date(t).toLocaleDateString("es-AR", {
        weekday: "short",
        day: "numeric",
        month: "short",
      });
    }
    return raw;
  }
  return getForecastDate(period.period ?? "");
}

/** Fondo suave (#RRGGBB + alpha en hex); color en `<Icon>` (astro-icon / `<use>` no hereda currentColor del wrapper). */
function fcardIconWrapStyle(weatherColor: string): string {
  const c = weatherColor.trim();
  if (/^#[0-9a-fA-F]{6}$/.test(c)) {
    return `background-color: ${c}20;`;
  }
  return `background-color: color-mix(in srgb, ${c} 12%, transparent);`;
}

function fcardTempModifier(temp: number | null | undefined): string {
  if (temp == null || Number.isNaN(temp)) return "";
  if (temp < 0) return "fcard-temp--cold";
  if (temp >= 20) return "fcard-temp--warm";
  return "";
}
---

<section
  class:list={["forecast-section", className]}
  aria-labelledby="forecast-heading"
  data-forecast-section
>
  <h2 id="forecast-heading" class="text-section-title section-label section-label--live">
    <span class="live-pulse-dot live-pulse-dot--sky" aria-hidden="true"></span>
    Próximas horas
  </h2>
  <div class="forecast-grid">
    {
      forecast.map((period, i) => {
        const descRaw = period.description?.trim() || "Despejado";
        const iconColor = getWeatherIconColor(descRaw);
        const dateLine = formatForecastDateLine(period);
        const condLevel = translateConditionLevel(period.description);
        const windTranslated = translateWindWithDir(period.wind ?? null);
        const visTranslated = translateForecastVisibilityLabel(period.visibility ?? null);
        const condSymbol = condLevel === "good" ? "✓" : condLevel === "bad" ? "!" : "~";
        const hasDetails = Boolean(period.wind || (period.visibility && visTranslated));
        const showWarning = condLevel === "bad";
        const temp = period.temperatureC;
        const tempClass = fcardTempModifier(temp);
        return (
          <details class="fcard" open={i === 0}>
            <summary class="fcard-summary fcard-header">
              <span class="fcard-icon-wrap" aria-hidden="true" style={fcardIconWrapStyle(iconColor)}>
                <Icon
                  name={getWeatherIcon(descRaw)}
                  width="22"
                  height="22"
                  style={`color: ${iconColor}; display: block;`}
                  aria-hidden="true"
                />
              </span>
              <div class="fcard-meta fcard-header-text">
                <span class="fcard-period">{period.period ?? "—"}</span>
                <span class="fcard-date">{dateLine}</span>
                <span class="fcard-desc fcard-desc--summary">{descRaw}</span>
              </div>
              <span class:list={["fcard-temp", tempClass]}>
                {temp != null && !Number.isNaN(temp) ? `${temp} °C` : "—"}
              </span>
              <span class:list={["fcard-cond-badge", `fcard-cond-badge--${condLevel}`]} aria-hidden="true">
                {condSymbol}
              </span>
            </summary>
            {(hasDetails || showWarning) && (
              <div class="fcard-body">
                {hasDetails && (
                  <div class="fcard-details">
                    {period.wind && (
                      <div class="fcard-row">
                        <span class="fcard-label">Viento</span>
                        <span class:list={["fcard-value-badge", levelClass(windTranslated.level)]}>
                          {windTranslated.label}
                        </span>
                      </div>
                    )}
                    {period.visibility && visTranslated && (
                      <div class="fcard-row">
                        <span class="fcard-label">Visibilidad</span>
                        <span class:list={["fcard-value-badge", levelClass(visTranslated.level)]}>
                          {visTranslated.label}
                        </span>
                      </div>
                    )}
                  </div>
                )}
                {showWarning && (
                  <div class:list={["fcard-warning", !hasDetails && "fcard-warning--standalone"]}>
                    <svg
                      width="11"
                      height="11"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" />
                      <line x1="12" y1="9" x2="12" y2="13" />
                      <line x1="12" y1="17" x2="12.01" y2="17" />
                    </svg>
                    Condiciones adversas en esta franja
                  </div>
                )}
              </div>
            )}
          </details>
        );
      })
    }
  </div>
</section>

<script>
  const FORECAST_MQ = "(min-width: 768px)";

  function syncForecastDetailsOpen() {
    const mq = window.matchMedia(FORECAST_MQ);
    const cards = document.querySelectorAll(".forecast-section details.fcard");
    cards.forEach((el, i) => {
      if (el instanceof HTMLDetailsElement) {
        el.open = mq.matches || i === 0;
      }
    });
  }

  syncForecastDetailsOpen();
  window.matchMedia(FORECAST_MQ).addEventListener("change", syncForecastDetailsOpen);
  document.addEventListener("astro:page-load", syncForecastDetailsOpen);
</script>

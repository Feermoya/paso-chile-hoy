---
import VersionBadge from "@/components/VersionBadge.astro";
import { Icon } from "astro-icon/components";

const year = new Date().getFullYear();
const official = "https://www.argentina.gob.ar/seguridad/pasosinternacionales";
const mail = "fmoya97.fm@gmail.com";
const mailto = `mailto:${mail}`;
const suggestionsHref = `mailto:${mail}?subject=${encodeURIComponent("Sugerencia — Paso Chile Hoy")}`;
const xUrl = "https://x.com/PasoCRMza";

const linkedinUrl =
  import.meta.env.PUBLIC_LINKEDIN_URL?.trim() || "https://www.linkedin.com/in/fernando-moya-1997-/";
const portfolioUrl =
  import.meta.env.PUBLIC_PORTFOLIO_URL?.trim() || "https://fernandomoya-dev.vercel.app/";
const instagramUrl = import.meta.env.PUBLIC_INSTAGRAM_URL?.trim();
---

<footer class="site-footer">
  <div class="footer-top">
    <div class="footer-top-inner">
      <div class="footer-col footer-col--identity">
        <a href="/" class="footer-logo-link">
          <img
            src="/logo.png"
            alt="Paso Chile Hoy"
            width="64"
            height="64"
            class="footer-logo"
            loading="lazy"
            decoding="async"
          />
          <div class="footer-brand-text">
            <span class="footer-logo-name">Paso Chile Hoy</span>
            <span class="footer-brand-tagline">Pasos Argentina–Chile · datos oficiales</span>
          </div>
        </a>

        <hr class="footer-hr" />

        <div class="footer-dev-block">
          <p class="footer-dev-label">Diseñado y desarrollado por</p>
          <div class="footer-dev-row">
            <span class="footer-dev-name">Fernando Moya</span>
            <nav class="footer-dev-icons" aria-label="Enlaces de contacto de Fernando Moya">
              <a
                href={linkedinUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="footer-icon-link"
                title="Perfil profesional en LinkedIn"
                aria-label="LinkedIn — perfil de Fernando Moya"
              >
                <Icon name="lucide:linkedin" width="16" height="16" aria-hidden="true" />
                <span class="footer-icon-link__label">LinkedIn</span>
              </a>
              <a
                href={portfolioUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="footer-icon-link"
                title="Sitio web personal: proyectos y contacto"
                aria-label="Sitio web personal de Fernando Moya"
              >
                <Icon name="lucide:globe" width="16" height="16" aria-hidden="true" />
                <span class="footer-icon-link__label">Sitio web</span>
              </a>
              <a
                href={mailto}
                class="footer-icon-link"
                title={`Enviar correo electrónico a ${mail}`}
                aria-label={`Correo electrónico: ${mail}`}
              >
                <Icon name="lucide:mail" width="16" height="16" aria-hidden="true" />
                <span class="footer-icon-link__label">Correo</span>
              </a>
            </nav>
          </div>
          <p class="footer-dev-cta">Abierto a consultas y proyectos</p>
        </div>
      </div>

      <div class="footer-col footer-col--nav">
        <div class="footer-nav-group">
          <p class="footer-col-title">Pasos</p>
          <nav class="footer-nav-list" aria-label="Pasos fronterizos">
            <a href="/cristo-redentor" class="footer-link">Cristo Redentor</a>
            <a href="/pehuenche" class="footer-link">Pehuenche</a>
            <a href="/agua-negra" class="footer-link">Agua Negra</a>
          </nav>
        </div>
        <div class="footer-nav-group">
          <p class="footer-col-title">Legal</p>
          <nav class="footer-nav-list" aria-label="Legal y fuentes">
            <a href={official} target="_blank" rel="noopener noreferrer" class="footer-link">Fuente oficial</a>
            <a href="/legal" class="footer-link">Aviso legal</a>
            <a href={mailto} class="footer-link">Contacto</a>
          </nav>
        </div>
      </div>

      <div class="footer-col footer-col--social">
        <div class="footer-social-block">
          <p class="footer-col-title">Seguinos</p>
          <nav class="footer-nav-list" aria-label="Redes sociales">
            <a
              href={xUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="footer-link footer-link--with-icon"
              title="Cuenta oficial en X (antes Twitter)"
              aria-label="X — cuenta oficial @PasoCRMza"
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" class="footer-x-icon" aria-hidden="true">
                <path
                  d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
                ></path>
              </svg>
              <span class="footer-link__text">
                <span class="footer-link__label">X</span>
                <span class="footer-link__hint">@PasoCRMza · novedades del proyecto</span>
              </span>
            </a>
            {
              instagramUrl ? (
                <a
                  href={instagramUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="footer-link footer-link--with-icon"
                  title="Perfil de Instagram de Paso Chile Hoy"
                  aria-label="Instagram — Paso Chile Hoy"
                >
                  <Icon name="lucide:instagram" width="16" height="16" aria-hidden="true" />
                  <span class="footer-link__text">
                    <span class="footer-link__label">Instagram</span>
                    <span class="footer-link__hint">Red social del proyecto</span>
                  </span>
                </a>
              ) : null
            }
            <a
              href={mailto}
              class="footer-link footer-link--with-icon"
              title={`Enviar correo a ${mail}`}
              aria-label={`Correo de contacto: ${mail}`}
            >
              <Icon name="lucide:mail" width="16" height="16" aria-hidden="true" />
              <span class="footer-link__text">
                <span class="footer-link__label">Correo</span>
                <span class="footer-link__hint">{mail}</span>
              </span>
            </a>
          </nav>
        </div>

        <hr class="footer-hr footer-hr--in-col" />

        <div class="footer-project-block">
          <p class="footer-col-title">Proyecto</p>
          <div class="footer-project-version">
            <VersionBadge compact />
          </div>
          <nav class="footer-nav-list" aria-label="Proyecto">
            <a href={suggestionsHref} class="footer-link">Sugerencias</a>
          </nav>
        </div>
      </div>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="footer-bottom-inner">
      <p class="footer-legal-short">
        Servicio independiente. No afiliado al gobierno argentino ni chileno. Verificá siempre en la{" "}
        <a href={official} target="_blank" rel="noopener noreferrer">fuente oficial</a>.
      </p>
      <p class="footer-copy-line">
        © {year} · Paso Chile Hoy · Hecho en Mendoza 🏔️
      </p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 64px;
    border-top: 1px solid rgba(0, 0, 0, 0.06);
  }

  :root[data-theme="dark"] .site-footer {
    border-top-color: var(--color-border-subtle);
  }

  .footer-top {
    background: #f1f5f9;
    padding: 48px 0 44px;
  }

  :root[data-theme="dark"] .footer-top {
    background: var(--color-bg-secondary);
  }

  .footer-top-inner {
    max-width: 1100px;
    margin-inline: auto;
    padding-inline: 20px;
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.85fr) minmax(0, 1fr);
    gap: 48px 80px;
    align-items: start;
  }

  @media (max-width: 900px) {
    .footer-top-inner {
      gap: 40px 48px;
      grid-template-columns: 1fr 1fr;
    }

    .footer-col--identity {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 640px) {
    .footer-top-inner {
      grid-template-columns: 1fr;
      gap: 36px;
    }

    .footer-col--identity {
      grid-column: auto;
    }
  }

  .footer-logo-link {
    display: flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
    margin-bottom: 0;
  }

  .footer-logo {
    width: 64px;
    height: 64px;
    border-radius: 14px;
    object-fit: contain;
    flex-shrink: 0;
  }

  .footer-brand-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }

  .footer-logo-name {
    font-family: var(--font-display);
    font-size: 15px;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #0f172a;
  }

  :root[data-theme="dark"] .footer-logo-name {
    color: var(--color-text-primary);
  }

  .footer-brand-tagline {
    font-size: 12px;
    color: #64748b;
    line-height: 1.35;
  }

  :root[data-theme="dark"] .footer-brand-tagline {
    color: var(--color-text-muted);
  }

  .footer-hr {
    border: none;
    height: 1px;
    margin: 16px 0;
    background: currentColor;
    opacity: 0.2;
  }

  .footer-hr--in-col {
    margin: 20px 0;
  }

  .footer-dev-block {
    max-width: 320px;
  }

  .footer-dev-label {
    font-size: 12px;
    color: #64748b;
    margin: 0 0 6px;
    line-height: 1.4;
  }

  :root[data-theme="dark"] .footer-dev-label {
    color: var(--color-text-muted);
  }

  .footer-dev-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 10px 12px;
  }

  .footer-dev-name {
    font-size: 1rem;
    font-weight: 700;
    color: #1e293b;
    line-height: 1.2;
  }

  :root[data-theme="dark"] .footer-dev-name {
    color: var(--color-text-primary);
  }

  .footer-dev-icons {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 8px 14px;
  }

  .footer-icon-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: #64748b;
    transition: color 150ms ease;
    text-decoration: none;
    font-size: 12px;
    font-weight: 600;
    line-height: 1.2;
    border-radius: 6px;
    padding: 4px 2px;
    margin: -4px -2px;
  }

  .footer-icon-link__label {
    letter-spacing: 0.01em;
  }

  .footer-icon-link:hover {
    color: #2563eb;
  }

  :root[data-theme="dark"] .footer-icon-link {
    color: var(--color-text-muted);
  }

  :root[data-theme="dark"] .footer-icon-link:hover {
    color: #60a5fa;
  }

  .footer-dev-cta {
    font-size: 0.75rem;
    font-style: italic;
    color: #94a3b8;
    margin: 10px 0 0;
    line-height: 1.45;
  }

  :root[data-theme="dark"] .footer-dev-cta {
    color: var(--color-text-disabled);
  }

  .footer-col-title {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #2563eb;
    margin: 0 0 16px;
  }

  :root[data-theme="dark"] .footer-col-title {
    color: #5baeff;
  }

  .footer-nav-group + .footer-nav-group {
    margin-top: 16px;
  }

  .footer-nav-list {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .footer-link {
    font-size: 14px;
    font-weight: 500;
    color: #374151;
    text-decoration: none;
    transition: color 150ms ease;
  }

  .footer-link:hover {
    color: #2563eb;
  }

  :root[data-theme="dark"] .footer-link {
    color: var(--color-text-secondary);
  }

  :root[data-theme="dark"] .footer-link:hover {
    color: #60a5fa;
  }

  .footer-link--with-icon {
    display: inline-flex;
    align-items: flex-start;
    gap: 10px;
  }

  .footer-link__text {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 2px;
    min-width: 0;
  }

  .footer-link__label {
    font-size: 14px;
    font-weight: 600;
    line-height: 1.25;
  }

  .footer-link__hint {
    font-size: 12px;
    font-weight: 500;
    color: #64748b;
    line-height: 1.35;
    word-break: break-word;
  }

  :root[data-theme="dark"] .footer-link__hint {
    color: var(--color-text-muted);
  }

  .footer-link--with-icon > :first-child {
    flex-shrink: 0;
    margin-top: 2px;
  }

  .footer-project-version {
    margin-bottom: 12px;
  }

  .footer-bottom {
    background: #e8edf3;
    border-top: 1px solid rgba(0, 0, 0, 0.06);
    padding: 16px 0;
  }

  :root[data-theme="dark"] .footer-bottom {
    background: var(--color-bg-base);
    border-top-color: var(--color-border-subtle);
  }

  .footer-bottom-inner {
    max-width: 1100px;
    margin-inline: auto;
    padding-inline: 20px;
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16px 24px;
    flex-wrap: wrap;
  }

  .footer-legal-short {
    font-size: 11px;
    color: #64748b;
    margin: 0;
    line-height: 1.5;
    max-width: 560px;
    flex: 1 1 280px;
  }

  :root[data-theme="dark"] .footer-legal-short {
    color: var(--color-text-disabled);
  }

  .footer-legal-short a {
    color: #2563eb;
    text-decoration: none;
    transition: color 150ms ease;
  }

  .footer-legal-short a:hover {
    color: #1d4ed8;
  }

  .footer-copy-line {
    font-size: 0.72rem;
    color: #94a3b8;
    margin: 0;
    line-height: 1.5;
    white-space: nowrap;
  }

  :root[data-theme="dark"] .footer-copy-line {
    color: var(--color-text-muted);
  }

  @media (max-width: 640px) {
    .footer-bottom-inner {
      flex-direction: column;
    }

    .footer-copy-line {
      white-space: normal;
    }
  }
</style>

---
import VersionBadge from "@/components/VersionBadge.astro";

const official = "https://www.argentina.gob.ar/seguridad/pasosinternacionales";
---

<footer class="site-footer">
  <div class="footer-top">
    <div class="footer-top-inner">
      <div class="footer-brand-col">
        <a href="/" class="footer-logo-link">
          <img
            src="/logo.png"
            alt="Paso Chile Hoy"
            width="40"
            height="40"
            class="footer-logo-img"
            loading="lazy"
            decoding="async"
          />
          <div class="footer-brand-text">
            <span class="footer-logo-name">Paso Chile Hoy</span>
            <span class="footer-brand-tagline">Estado en tiempo real · Argentina–Chile</span>
          </div>
        </a>
        <p class="footer-tagline">
          Estado en tiempo real de los pasos internacionales entre Argentina y Chile. Gratis, sin publicidad,
          hecho en Mendoza.
        </p>
        <p class="footer-made-in">
          Desarrollado por <a href="mailto:fmoya97.fm@gmail.com" class="footer-dev-link">Fernando Moya</a>
        </p>
      </div>

      <div class="footer-links-col">
        <p class="footer-col-title">Pasos</p>
        <a href="/cristo-redentor" class="footer-link">Cristo Redentor</a>
        <a href="/pehuenche" class="footer-link">Pehuenche</a>
        <a href="/agua-negra" class="footer-link">Agua Negra</a>
      </div>

      <div class="footer-links-col">
        <p class="footer-col-title">Recursos</p>
        <a href={official} target="_blank" rel="noopener noreferrer" class="footer-link">Fuente oficial</a>
        <a href="/legal" class="footer-link">Aviso legal</a>
        <a href="mailto:fmoya97.fm@gmail.com" class="footer-link">Contacto</a>
      </div>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="footer-bottom-inner">
      <p class="footer-legal-short">
        Servicio independiente. No afiliado al gobierno argentino ni chileno. Verificá siempre en la{" "}
        <a href={official} target="_blank" rel="noopener noreferrer">fuente oficial</a>.
      </p>
      <div class="footer-bottom-right">
        <VersionBadge compact />
        <p class="footer-geo">32°S · Cordillera de los Andes</p>
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 64px;
    border-top: 1px solid var(--color-border-subtle);
  }

  .footer-top {
    background: var(--color-bg-secondary);
    padding: 48px 0 40px;
  }

  .footer-top-inner {
    max-width: 960px;
    margin-inline: auto;
    padding-inline: 20px;
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 48px;
  }

  @media (max-width: 640px) {
    .footer-top-inner {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }

  .footer-logo-link {
    display: flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
    margin-bottom: 16px;
  }

  .footer-logo-img {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    object-fit: contain;
    flex-shrink: 0;
  }

  .footer-brand-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }

  .footer-logo-name {
    font-family: var(--font-display);
    font-size: 15px;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-text-primary);
  }

  .footer-brand-tagline {
    font-size: 12px;
    color: var(--color-text-muted);
    line-height: 1.3;
  }

  .footer-tagline {
    font-size: 13px;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin: 0 0 12px;
    max-width: 280px;
  }

  .footer-made-in {
    font-size: 12px;
    color: var(--color-text-disabled);
    margin: 0;
  }

  .footer-dev-link {
    color: var(--brand);
    text-decoration: none;
  }

  .footer-col-title {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--brand);
    margin: 0 0 16px;
  }

  .footer-links-col {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .footer-link {
    font-size: 13px;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .footer-link:hover {
    color: var(--color-text-secondary);
  }

  .footer-bottom {
    background: var(--color-bg-base);
    border-top: 1px solid var(--color-border-subtle);
    padding: 16px 0;
  }

  .footer-bottom-inner {
    max-width: 960px;
    margin-inline: auto;
    padding-inline: 20px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
    padding-top: 4px;
  }

  .footer-bottom-right {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }

  .footer-legal-short {
    font-size: 11px;
    color: var(--color-text-disabled);
    margin: 0;
    line-height: 1.5;
    max-width: 560px;
  }

  .footer-legal-short a {
    color: var(--brand);
    text-decoration: none;
  }

  .footer-geo {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-disabled);
    margin: 0;
  }
</style>

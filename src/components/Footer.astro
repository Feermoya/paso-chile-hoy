---
import VersionBadge from "@/components/VersionBadge.astro";

const official = "https://www.argentina.gob.ar/seguridad/pasosinternacionales";
---

<footer class="site-footer mt-auto">
  <div class="footer-inner">
    <div class="footer-columns">
      <div class="footer-col-main">
        <div class="footer-brand">
          <img
            src="/logo.png"
            alt="Paso Chile Hoy"
            width="24"
            height="24"
            class="footer-logo-img"
            loading="lazy"
          />
          <span class="footer-brand-name">Paso Chile Hoy</span>
        </div>

        <p class="footer-legal">
          Servicio independiente de información pública. Los datos provienen de
          <a href={official} target="_blank" rel="noopener noreferrer">{official}</a>
          — Gendarmería Nacional, Vialidad Nacional, SMN. Procesados automáticamente con fines
          informativos. Este sitio no está afiliado a ningún organismo oficial. Verificá siempre en la
          fuente oficial antes de viajar.{" "}
          <a href="/legal" class="footer-legal-link">Aviso legal</a>
        </p>
      </div>

      <div class="footer-contact">
        <p class="footer-contact-label">Desarrollado por</p>
        <p class="footer-contact-name">Fernando Moya</p>
        <a
          href="mailto:fmoya97.fm@gmail.com"
          class="footer-contact-link"
          aria-label="Enviar mail a Fernando Moya"
        >
          fmoya97.fm@gmail.com
        </a>
      </div>
    </div>

    <div class="footer-bottom-row">
      <p class="footer-geo">32°S · 3200 m s.n.m. · Cordillera de los Andes</p>
      <VersionBadge />
    </div>
  </div>
</footer>

<style>
  .site-footer {
    width: 100%;
    margin-top: 48px;
    border-top: 1px solid var(--color-border-subtle);
    background: var(--color-bg-secondary);
  }

  .footer-inner {
    max-width: 960px;
    margin-inline: auto;
    padding: 28px 20px 32px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .footer-columns {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  @media (min-width: 768px) {
    .footer-columns {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 32px;
      align-items: start;
    }
  }

  .footer-brand {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 10px;
  }

  .footer-logo-img {
    width: 24px;
    height: 24px;
    flex-shrink: 0;
    display: block;
    opacity: 0.75;
  }

  .footer-brand-name {
    font-family: var(--font-display);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .footer-legal {
    font-size: 12px;
    line-height: 1.65;
    color: var(--color-text-muted);
    margin: 0;
    max-width: 680px;
  }

  .footer-legal a {
    color: var(--color-accent);
    text-decoration: none;
    word-break: break-all;
  }

  .footer-legal a:hover {
    text-decoration: underline;
  }

  .footer-legal-link {
    color: var(--color-text-muted);
    text-decoration: none;
    font-size: 11px;
  }

  .footer-legal-link:hover {
    text-decoration: underline;
  }

  .footer-contact {
    display: flex;
    flex-direction: column;
    gap: 3px;
    flex-shrink: 0;
  }

  .footer-contact-label {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin: 0;
  }

  .footer-contact-name {
    font-size: 13px;
    font-weight: 600;
    color: var(--color-text-secondary);
    margin: 0;
  }

  .footer-contact-link {
    font-size: 12px;
    color: var(--color-accent);
    text-decoration: none;
  }

  .footer-contact-link:hover {
    text-decoration: underline;
  }

  .footer-geo {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-disabled);
    margin: 0;
  }
</style>

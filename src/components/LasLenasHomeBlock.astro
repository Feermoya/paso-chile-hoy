---
import { Icon } from "astro-icon/components";
import type { LasLenasSnapshot } from "@/types/las-lenas";
import { formatRelativeTimeAgo } from "@/utils/formatRelativeTime";
import { getWeatherIcon, getWeatherIconColor } from "@/utils/weatherIcon";

export interface Props {
  snapshot: LasLenasSnapshot;
}

const { snapshot } = Astro.props;
const { place, current, forecast, warnings, forecastSource } = snapshot;

function fmtTimestampLine(iso: string | null): string {
  if (!iso?.trim()) return "";
  try {
    const d = new Date(iso);
    const datePart = new Intl.DateTimeFormat("es-AR", {
      day: "numeric",
      month: "short",
      year: "numeric",
      timeZone: "America/Argentina/Buenos_Aires",
    }).format(d);
    const timePart = new Intl.DateTimeFormat("es-AR", {
      hour: "2-digit",
      minute: "2-digit",
      timeZone: "America/Argentina/Buenos_Aires",
    }).format(d);
    return `${datePart} · ${timePart}`;
  } catch {
    return iso;
  }
}

function fmtForecastStrip(dateStr: string): { name: string; dateLine: string } {
  try {
    const d = new Date(`${dateStr}T12:00:00`);
    const name = new Intl.DateTimeFormat("es-AR", { weekday: "short" }).format(d);
    const dateLine = new Intl.DateTimeFormat("es-AR", { day: "numeric", month: "short" }).format(d);
    return { name, dateLine };
  } catch {
    return { name: dateStr, dateLine: "" };
  }
}

const updatedRel = formatRelativeTimeAgo(snapshot.updatedAt);
const updatedFooter = updatedRel ? `Actualizado ${updatedRel}` : "";

const stationRefShort =
  place.station && place.station.distanceKm != null
    ? `Ref: ${place.station.name} · ${place.station.distanceKm.toLocaleString("es-AR", { maximumFractionDigits: 1 })} km`
    : place.station
      ? `Ref: ${place.station.name}`
      : null;

const windLine =
  current?.wind.direction && current.wind.speedKmh != null
    ? `${current.wind.direction} · ${current.wind.speedKmh} km/h`
    : current?.wind.direction
      ? current.wind.direction
      : "—";

const visLine = current?.visibilityKm != null ? `${current.visibilityKm} km` : "—";
const humidityLine = current?.humidity != null ? `${current.humidity}%` : "—";

const nowIcon = getWeatherIcon(current?.description);
const nowIconColor = getWeatherIconColor(current?.description);
const conditionLabel = current?.description?.trim() || "Sin datos de condición";

const firstFcRange = forecast.find((d) => d.tempMinC != null && d.tempMaxC != null);
let tempRangePct: number | null = null;
let tempRangeMin: number | null = null;
let tempRangeMax: number | null = null;
if (
  current?.temperatureC != null &&
  firstFcRange?.tempMinC != null &&
  firstFcRange?.tempMaxC != null
) {
  const lo = firstFcRange.tempMinC;
  const hi = firstFcRange.tempMaxC;
  if (hi > lo) {
    tempRangeMin = lo;
    tempRangeMax = hi;
    const raw = ((current.temperatureC - lo) / (hi - lo)) * 100;
    tempRangePct = Math.min(95, Math.max(5, Math.round(raw)));
  }
}

const smnAlertsUrl = "https://www.smn.gob.ar/";
---

<section class="las-lenas-home" role="region" aria-label={`Clima en ${place.name}`}>
  <div class="las-lenas-hd">
    <div class="las-lenas-hd-left">
      <div class="las-lenas-route-row" role="group" aria-label="Rutas de acceso desde Mendoza Capital">
        <span class="las-lenas-route-pill las-lenas-route-pill--rn">RN 40</span>
        <span class="las-lenas-route-pill las-lenas-route-pill--rp">RP 222</span>
        <span class="las-lenas-route-sep" aria-hidden="true">·</span>
        <span class="las-lenas-route-distance">342 km desde Mendoza Capital</span>
      </div>
      <h2 class="las-lenas-place-title" id="las-lenas-title">Las Leñas</h2>
      <p class="las-lenas-access-note">
        Todo asfalto; en invierno hay que llevar cadenas.
      </p>
      <div class="las-lenas-place-meta">
        <span>Clima y acceso</span>
        <span class="las-lenas-meta-sep" aria-hidden="true">·</span>
        <span>Malargüe, Mendoza</span>
        <span class="las-lenas-meta-sep" aria-hidden="true">·</span>
        <span class="las-lenas-live-badge" aria-label="Datos en tiempo real">
          <span class="las-lenas-live-dot" aria-hidden="true"></span>
          En vivo
        </span>
      </div>
    </div>
  </div>

  {
    current && (
      <div class="las-lenas-main">
        <div class="las-lenas-temp-block">
          <div class="las-lenas-icon-temp">
            <span class="las-lenas-weather-icon-host" role="img" aria-label={conditionLabel}>
              <Icon
                name={nowIcon}
                class="las-lenas-weather-icon"
                width="44"
                height="44"
                style={`color: ${nowIconColor}`}
                aria-hidden="true"
              />
            </span>
            <div class="las-lenas-temp-value">
              {current.temperatureC != null ? (
                <>
                  <span class="las-lenas-temp-num">{current.temperatureC.toFixed(1)}</span>
                  <span class="las-lenas-temp-unit">°C</span>
                </>
              ) : (
                <span class="las-lenas-temp-num las-lenas-temp-num--na">—</span>
              )}
            </div>
          </div>
          {tempRangePct != null && tempRangeMin != null && tempRangeMax != null && (
            <div class="las-lenas-temp-range-bar" aria-hidden="true">
              <span class="las-lenas-tr-min">{tempRangeMin}°</span>
              <div class="las-lenas-tr-track">
                <div class="las-lenas-tr-fill" style={`width: ${tempRangePct}%`}>
                  <span class="las-lenas-tr-thumb"></span>
                </div>
              </div>
              <span class="las-lenas-tr-max">{tempRangeMax}°</span>
            </div>
          )}
          <p class="las-lenas-desc">{conditionLabel}</p>
          {current.observedAt && (
            <p class="las-lenas-ts">{fmtTimestampLine(current.observedAt)}</p>
          )}
        </div>

        <div class="las-lenas-divider-v" aria-hidden="true"></div>

        <div class="las-lenas-metrics">
          <div class="las-lenas-metric-row">
            <Icon name="lucide:wind" class="las-lenas-metric-ico" width="14" height="14" aria-hidden="true" />
            <span class="las-lenas-metric-lbl">Viento</span>
            <span class="las-lenas-metric-val">{windLine}</span>
          </div>
          <div class="las-lenas-metric-row">
            <Icon name="lucide:eye" class="las-lenas-metric-ico" width="14" height="14" aria-hidden="true" />
            <span class="las-lenas-metric-lbl">Visibilidad</span>
            <span class="las-lenas-metric-val">{visLine}</span>
          </div>
          <div class="las-lenas-metric-row">
            <Icon name="lucide:droplets" class="las-lenas-metric-ico" width="14" height="14" aria-hidden="true" />
            <span class="las-lenas-metric-lbl">Humedad</span>
            <span class="las-lenas-metric-val">{humidityLine}</span>
          </div>
        </div>
      </div>
    )
  }

  {
    forecast.length > 0 && (
      <details class="las-lenas-fc" id="las-lenas-pronostico">
        <summary class="las-lenas-fc-summary">
          <span class="las-lenas-fc-summary-row">
            <span class="las-lenas-fc-summary-main">
              <h3 class="las-lenas-fc-title">Próximos días</h3>
              <span class="las-lenas-fc-sub">
                <span class="las-lenas-fc-sub-line">Pronóstico por jornada</span>
                <span class="las-lenas-fc-cta">
                  <span class="las-lenas-fc-cta-more"> · Desplegar</span>
                  <span class="las-lenas-fc-cta-less"> · Contraer</span>
                </span>
              </span>
            </span>
            <Icon
              name="lucide:chevron-down"
              class="las-lenas-fc-chevron"
              width="20"
              height="20"
              aria-hidden="true"
            />
          </span>
        </summary>
        <div class="las-lenas-fc-body">
          <div class="las-lenas-fc-strip">
            {forecast.map((d, i) => {
              const { name, dateLine } = fmtForecastStrip(d.date);
              const fcIcon = getWeatherIcon(d.description);
              const fcColor = getWeatherIconColor(d.description);
              const desc = d.description?.trim() || "";
              return (
                <div class="las-lenas-fc-slot">
                  {i > 0 && <div class="las-lenas-fc-sep" aria-hidden="true"></div>}
                  <div class="las-lenas-fday">
                    <div class="las-lenas-fday-row">
                      <span class="las-lenas-fday-icon-host" role="img" aria-label={desc || "Pronóstico"}>
                        <Icon
                          name={fcIcon}
                          class="las-lenas-fday-icon"
                          width="32"
                          height="32"
                          style={`color: ${fcColor}`}
                          aria-hidden="true"
                        />
                      </span>
                      <div class="las-lenas-fday-content">
                        <div class="las-lenas-fday-head">
                          <span class="las-lenas-fday-name">{name}</span>
                          <span class="las-lenas-fday-dot" aria-hidden="true">
                            ·
                          </span>
                          <span class="las-lenas-fday-date">{dateLine}</span>
                        </div>
                        <div class="las-lenas-fday-temps">
                          {d.tempMinC != null && d.tempMaxC != null ? (
                            <>
                              <span class="las-lenas-fday-min">{d.tempMinC}°</span>
                              <span class="las-lenas-fday-slash" aria-hidden="true">
                                /
                              </span>
                              <span class="las-lenas-fday-max">{d.tempMaxC}°</span>
                            </>
                          ) : d.tempMaxC != null ? (
                            <span class="las-lenas-fday-max las-lenas-fday-max--solo">máx. {d.tempMaxC}°</span>
                          ) : (
                            <span class="las-lenas-fday-na">—</span>
                          )}
                        </div>
                        {desc && <p class="las-lenas-fday-desc">{desc}</p>}
                      </div>
                    </div>
                  </div>
                </div>
              );
            })}
          </div>
          {forecastSource === "wttr_in" && (
            <p class="las-lenas-fc-note">Pronóstico complementario para planificar la visita.</p>
          )}
        </div>
      </details>
    )
  }

  <div class="las-lenas-alert-row">
    <svg
      class="las-lenas-alert-ico"
      width="14"
      height="14"
      viewBox="0 0 24 24"
      fill="none"
      aria-hidden="true"
    >
      <path
        d="M12 2L1 21h22L12 2z"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linejoin="round"></path>
      <path d="M12 9v5M12 17v.01" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"></path>
    </svg>
    <span class="las-lenas-alert-lbl">Alertas SMN</span>
    {
      warnings.sourceUnavailable ? null : warnings.hasWarnings ? (
        <span class="las-lenas-alert-hint">Hay avisos publicados.</span>
      ) : (
        <span class="las-lenas-alert-hint">Sin resumen en esta vista.</span>
      )
    }
    <a href={smnAlertsUrl} target="_blank" rel="noopener noreferrer" class="las-lenas-alert-link">
      Ver alertas oficiales →
    </a>
  </div>

  <div class="las-lenas-foot">
    {stationRefShort && <span class="las-lenas-foot-src">{stationRefShort}</span>}
    {updatedFooter && <span class="las-lenas-foot-up">{updatedFooter}</span>}
  </div>
</section>

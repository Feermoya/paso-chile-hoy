---
import { Icon } from "astro-icon/components";
import PassDetailsInner from "@/components/PassDetailsInner.astro";
import type { PassView } from "@/types/pass-view";
import { passDetailsHasContent } from "@/utils/passViewGuards";

export interface Props {
  view: PassView;
  class?: string;
}

const { view, class: className } = Astro.props;
const has = passDetailsHasContent(view);
---

{
  has && (
    <div class:list={[className]}>
      <details class="pass-details-mobile group border-t border-[var(--color-border-subtle)] md:hidden">
        <summary
          class="flex min-h-12 cursor-pointer list-none items-center justify-between gap-3 py-3 text-sm font-medium text-[var(--color-text-secondary)]"
        >
          <span>Más información del paso</span>
          <Icon
            name="lucide:chevron-down"
            class="h-5 w-5 shrink-0 text-[var(--color-text-muted)] transition-transform duration-200 group-open:rotate-180"
            aria-hidden="true"
          />
        </summary>
        <div class="pb-6 pt-2">
          <PassDetailsInner view={view} />
        </div>
      </details>

      <section
        class="hidden border-t border-[var(--color-border-subtle)] pt-10 md:block md:pt-12"
        aria-labelledby="pass-details-heading-desktop"
      >
        <h2
          id="pass-details-heading-desktop"
          class="font-display text-lg font-semibold text-[var(--color-text-primary)] md:text-xl"
        >
          Datos del paso
        </h2>
        <div class="mt-8">
          <PassDetailsInner view={view} />
        </div>
      </section>
    </div>
  )
}

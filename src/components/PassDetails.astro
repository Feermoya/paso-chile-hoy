---
import { Icon } from "astro-icon/components";
import PassDetailsInner from "@/components/PassDetailsInner.astro";
import type { PassView } from "@/types/pass-view";
import { passDetailsHasContent } from "@/utils/passViewGuards";

export interface Props {
  view: PassView;
  class?: string;
  /** Si true, el horario ya está en StatusHero — no duplicar en este bloque. */
  hideScheduleInDetails?: boolean;
  /** Si true, el enlace oficial ya está en el hero — no duplicar. */
  hideOfficialLink?: boolean;
}

const { view, class: className, hideScheduleInDetails = false, hideOfficialLink = false } = Astro.props;
const has = passDetailsHasContent(view, {
  treatScheduleAsHidden: hideScheduleInDetails,
  treatOfficialLinkAsHidden: hideOfficialLink,
});
---

{
  has && (
    <div class:list={["pass-details-root", className]}>
      <details class="pass-details-panel group border-t border-[var(--color-border-subtle)]" data-pass-details>
        <summary
          class="pass-details-summary flex min-h-12 cursor-pointer list-none items-center justify-between gap-3 py-3 text-sm font-medium text-[var(--color-text-secondary)] md:hidden"
        >
          <span>Más información del paso</span>
          <Icon
            name="lucide:chevron-down"
            class="h-5 w-5 shrink-0 text-[var(--color-text-muted)] transition-transform duration-200 group-open:rotate-180"
            aria-hidden="true"
          />
        </summary>
        <h2
          id="pass-details-heading"
          class="hidden scroll-mt-24 font-display text-lg font-semibold text-[var(--color-text-primary)] md:mb-5 md:mt-6 md:block md:text-xl"
        >
          Datos del paso
        </h2>
        <div class="pass-details-content pb-6 pt-2 md:pt-0">
          <PassDetailsInner
            view={view}
            hideSchedule={hideScheduleInDetails}
            hideOfficialLink={hideOfficialLink}
          />
        </div>
      </details>
    </div>
  )
}

<script>
  import { initPassDetailsPanels } from "@/scripts/pass-details-panel.client.ts";

  initPassDetailsPanels();
  document.addEventListener("astro:page-load", initPassDetailsPanels);
</script>

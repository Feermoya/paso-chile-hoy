---
import AlertTicker from "@/components/AlertTicker.astro";
import CookieBanner from "@/components/CookieBanner.astro";
import Footer from "@/components/Footer.astro";
import VersionBadge from "@/components/VersionBadge.astro";
import {
  SITE_FAVICON,
  SITE_NAME,
  WEB_SITE_SCHEMA_DESCRIPTION,
  schemaWebsiteId,
} from "@/utils/seo";
import "@/styles/global.css";

export interface Props {
  title: string;
  description: string;
  /** Open Graph / redes; por defecto igual que `title`. */
  ogTitle?: string;
  ogDescription?: string;
  /** URL absoluta; por defecto `DEFAULT_OG_IMAGE` del sitio. */
  ogImage?: string;
  /** Texto alternativo de la imagen en previews (Twitter y accesibilidad). */
  ogImageAlt?: string;
  canonical?: string;
  /** Por defecto `summary_large_image` (coherente con og-image 1200×630). */
  twitterCard?: "summary" | "summary_large_image";
  noindex?: boolean;
  structuredData?: Record<string, unknown>;
  /** Solo en página de paso; si no se pasa, no se muestra el badge de altitud. */
  headerAltitudeM?: number | null;
  /** Ej. Mendoza · AR / San Juan · AR; si no se pasa, no se muestra región bajo la marca (home, legal). */
  headerRegionLabel?: string | null;
  /** Meta geo.region (ej. AR-M, AR-J). */
  geoRegionCode?: string;
  geoPlacename?: string;
  /** Meta geo.position: "lat;lng" */
  geoPosition?: string;
}

function baseUrl(): string {
  const env = import.meta.env.PUBLIC_SITE_URL?.trim();
  if (env) return env.replace(/\/$/, "");
  const site = import.meta.env.SITE?.trim();
  if (site) return site.replace(/\/$/, "");
  return "https://pasochilehoy.com";
}

const siteUrl = baseUrl();

const {
  title,
  description,
  ogTitle,
  ogDescription,
  ogImage: ogImageProp,
  ogImageAlt: ogImageAltProp,
  canonical: canonicalProp,
  twitterCard = "summary_large_image",
  noindex = false,
  structuredData,
  headerAltitudeM,
  headerRegionLabel,
  geoRegionCode = "AR-M",
  geoPlacename = "Mendoza, Argentina",
  geoPosition = "-32.8211;-69.9232",
} = Astro.props;

const canonical = canonicalProp ?? `${siteUrl}/`;
const resolvedOgTitle = ogTitle ?? title;
const resolvedOgDesc = ogDescription ?? description;
const ogImageFinal = ogImageProp ?? `${siteUrl}/og-image.png`;
const ogImageAltResolved =
  ogImageAltProp ?? `${SITE_NAME} — Estado de pasos internacionales Argentina–Chile`;

const organizationId = `${siteUrl}#organization`;
const defaultLdGraph: Record<string, unknown> = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": organizationId,
      name: SITE_NAME,
      url: `${siteUrl}/`,
      email: "fmoya97.fm@gmail.com",
      founder: {
        "@type": "Person",
        name: "Fernando Moya",
      },
    },
    {
      "@type": "WebSite",
      "@id": schemaWebsiteId(),
      name: SITE_NAME,
      alternateName: ["Paso Chile Hoy", "pasochilehoy.com", "Paso a Chile hoy", "paso a Chile Mendoza"],
      url: `${siteUrl}/`,
      description: WEB_SITE_SCHEMA_DESCRIPTION,
      inLanguage: "es-AR",
      publisher: { "@id": organizationId },
    },
  ],
};

const showHeaderRegion = Boolean(headerRegionLabel?.trim());
const showHeaderAltitude =
  typeof headerAltitudeM === "number" && Number.isFinite(headerAltitudeM);
const altitudeLabel = showHeaderAltitude
  ? `Altitud del paso: ${headerAltitudeM} metros sobre el nivel del mar`
  : "";

const icbmContent = geoPosition.includes(";")
  ? geoPosition
      .split(";")
      .map((s) => s.trim())
      .join(", ")
  : geoPosition;
---

<!doctype html>
<html lang="es-AR" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, viewport-fit=cover"
    />
    <meta name="theme-color" content="#f8f9fb" id="pch-theme-color" />
    <script is:inline>
      (function () {
        var theme = "light";
        try {
          var t = localStorage.getItem("pch-theme");
          theme = t === "dark" ? "dark" : "light";
        } catch (e) {
          theme = "light";
        }
        document.documentElement.setAttribute("data-theme", theme);
        try {
          var mc = document.getElementById("pch-theme-color");
          if (mc) {
            mc.setAttribute("content", theme === "light" ? "#f8f9fb" : "#0A0C10");
          }
        } catch (e2) {
          /* ignore */
        }
      })();
    </script>

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex ? (
      <meta name="robots" content="noindex, nofollow" />
    ) : (
      <meta
        name="robots"
        content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1"
      />
    )}

    <meta name="geo.region" content={geoRegionCode} />
    <meta name="geo.placename" content={geoPlacename} />
    <meta name="geo.position" content={geoPosition} />
    <meta name="ICBM" content={icbmContent} />

    <meta http-equiv="content-language" content="es-AR" />
    <link rel="alternate" hreflang="es-AR" href={canonical} />
    <link rel="alternate" hreflang="es" href={canonical} />
    <link rel="alternate" hreflang="x-default" href={canonical} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={resolvedOgTitle} />
    <meta property="og:description" content={resolvedOgDesc} />
    <meta property="og:image" content={ogImageFinal} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImageAltResolved} />
    <meta property="og:locale" content="es_AR" />
    <meta property="og:locale:alternate" content="en_US" />

    <meta name="twitter:card" content={twitterCard} />
    <meta name="twitter:title" content={resolvedOgTitle} />
    <meta name="twitter:description" content={resolvedOgDesc} />
    <meta name="twitter:image" content={ogImageFinal} />
    <meta name="twitter:image:alt" content={ogImageAltResolved} />

    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="Paso Chile" />
    <link rel="manifest" href="/manifest.json" />

    <link rel="icon" type="image/x-icon" href={SITE_FAVICON.ico} />
    <link rel="icon" type="image/png" href={SITE_FAVICON.png16} sizes="16x16" />
    <link rel="icon" type="image/png" href={SITE_FAVICON.png32} sizes="32x32" />
    <link rel="apple-touch-icon" href={SITE_FAVICON.appleTouch} />
    <link rel="apple-touch-startup-image" href={SITE_FAVICON.appleTouch} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,400&family=JetBrains+Mono:wght@400;500&family=Sora:wght@300;400;600;700;800&display=swap"
      rel="stylesheet"
    />

    <script is:inline type="application/ld+json" set:html={JSON.stringify(defaultLdGraph)} />
    {structuredData && (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />
    )}
  </head>
  <body class="min-h-dvh bg-page">
    <div class="relative z-[1] flex min-h-dvh flex-col">
      <a
        href="#contenido-principal"
        class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded-[var(--radius-md)] focus:bg-surface-raised focus:px-4 focus:py-2 focus:text-ink focus:outline-none focus:ring-2 focus:ring-accent/40 focus:ring-offset-2 focus:ring-offset-page"
      >
        Ir al contenido
      </a>
      <header class="header-app site-header">
        <div class="header-inner">
          <a href="/" class="header-logo-link" aria-label="Inicio — todos los pasos">
            <span class="header-brand-name">PASO CHILE HOY</span>
            {
              showHeaderRegion && (
                <>
                  <span class="header-location-sep" aria-hidden="true">
                    ·
                  </span>
                  <span class="header-location">{headerRegionLabel}</span>
                </>
              )
            }
          </a>

          <div class="header-actions">
            <button
              id="theme-toggle"
              class="theme-toggle-btn"
              type="button"
              aria-label="Cambiar tema"
              title="Modo claro / oscuro"
            >
              <svg
                id="theme-icon-sun"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <circle cx="12" cy="12" r="5"></circle>
                <line x1="12" y1="1" x2="12" y2="3"></line>
                <line x1="12" y1="21" x2="12" y2="23"></line>
                <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
                <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
                <line x1="1" y1="12" x2="3" y2="12"></line>
                <line x1="21" y1="12" x2="23" y2="12"></line>
                <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
                <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
              </svg>
              <svg
                id="theme-icon-moon"
                class="theme-toggle-icon-moon"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
              </svg>
            </button>
            <VersionBadge />
            {
              showHeaderAltitude && (
                <div class="header-altitude header-altitude--desktop" aria-label={altitudeLabel}>
                  <span class="header-altitude-number">{headerAltitudeM}</span>
                  <span class="header-altitude-unit">m</span>
                </div>
              )
            }
          </div>
        </div>
      </header>
      <div class="ticker-wrapper">
        <AlertTicker />
      </div>
      <main id="contenido-principal" class="min-w-0 flex-1 pb-4 pt-1 md:pt-4">
        <slot />
      </main>
      <slot name="before-footer" />
      <Footer />
    </div>
    <CookieBanner />

    <div id="pwa-banner" class="pwa-banner" hidden aria-live="polite">
      <div class="pwa-banner-inner">
        <img src="/logo.png" alt="" width="36" height="36" class="pwa-banner-logo" />
        <div id="pwa-panel-chrome" class="pwa-banner-panel" hidden>
          <div class="pwa-banner-text">
            <strong>Instalá la app</strong>
            <span>Accedé más rápido al estado de los pasos.</span>
          </div>
          <div class="pwa-banner-actions">
            <button id="pwa-install-btn" class="pwa-btn pwa-btn--primary" type="button">
              Instalar
            </button>
            <button id="pwa-dismiss-btn" class="pwa-btn pwa-btn--ghost pwa-btn--banner-text" type="button">
              Ahora no
            </button>
          </div>
        </div>
        <div id="pwa-panel-ios" class="pwa-banner-panel" hidden>
          <div class="pwa-banner-text">
            <strong>Agregar a inicio</strong>
            <span
              >En iPhone, abrí Compartir y elegí &quot;Añadir a pantalla de inicio&quot;.</span
            >
          </div>
          <div class="pwa-banner-actions pwa-banner-actions--stack">
            <button id="pwa-ios-ok" class="pwa-btn pwa-btn--primary" type="button">Entendido</button>
            <button id="pwa-ios-dismiss" class="pwa-btn pwa-btn--ghost pwa-btn--banner-text" type="button">
              Cerrar
            </button>
          </div>
        </div>
      </div>
    </div>

    <script is:inline>
      function updateHeaderHeight() {
        const header = document.querySelector(".site-header");
        if (header) {
          document.documentElement.style.setProperty(
            "--header-height",
            header.offsetHeight + "px",
          );
        }
      }
      updateHeaderHeight();
      window.addEventListener("resize", updateHeaderHeight);
      window.addEventListener("load", updateHeaderHeight);
      document.addEventListener("astro:page-load", updateHeaderHeight);
    </script>
    <script is:inline>
      (function () {
        if ("serviceWorker" in navigator) {
          window.addEventListener("load", function () {
            navigator.serviceWorker
              .register("/sw.js")
              .then(function (reg) {
                console.log("[PWA] SW registrado:", reg.scope);
              })
              .catch(function (err) {
                console.warn("[PWA] SW:", err);
              });
          });
        }

        var deferredPrompt = null;

        function isStandalone() {
          return (
            window.matchMedia("(display-mode: standalone)").matches ||
            window.navigator.standalone === true
          );
        }

        /** iPhone / iPad / iPod; incluye iPadOS con UA de escritorio. En iOS ningún navegador expone instalación programática. */
        function isIos() {
          return (
            /iPad|iPhone|iPod/.test(navigator.userAgent) ||
            (navigator.platform === "MacIntel" && navigator.maxTouchPoints > 1)
          );
        }

        /** Hay evento guardado para abrir el diálogo nativo (Chrome / Edge / etc.). */
        function supportsInstallPrompt() {
          return deferredPrompt !== null;
        }

        function hideBanner() {
          var banner = document.getElementById("pwa-banner");
          var chromePanel = document.getElementById("pwa-panel-chrome");
          var iosPanel = document.getElementById("pwa-panel-ios");
          if (!banner) return;
          banner.classList.remove("pwa-banner--visible");
          setTimeout(function () {
            banner.setAttribute("hidden", "");
            if (chromePanel) chromePanel.setAttribute("hidden", "");
            if (iosPanel) iosPanel.setAttribute("hidden", "");
          }, 400);
        }

        function showChromePanel() {
          if (localStorage.getItem("pwa-dismissed") === "true") return;
          if (isStandalone()) return;
          if (!supportsInstallPrompt()) return;
          var banner = document.getElementById("pwa-banner");
          var chromePanel = document.getElementById("pwa-panel-chrome");
          var iosPanel = document.getElementById("pwa-panel-ios");
          if (!banner || !chromePanel || !iosPanel) return;
          iosPanel.setAttribute("hidden", "");
          chromePanel.removeAttribute("hidden");
          banner.removeAttribute("hidden");
          requestAnimationFrame(function () {
            banner.classList.add("pwa-banner--visible");
          });
        }

        function showIosPanel() {
          if (localStorage.getItem("pwa-dismissed") === "true") return;
          if (isStandalone()) return;
          if (!isIos()) return;
          if (supportsInstallPrompt()) return;
          var banner = document.getElementById("pwa-banner");
          var chromePanel = document.getElementById("pwa-panel-chrome");
          var iosPanel = document.getElementById("pwa-panel-ios");
          if (!banner || !chromePanel || !iosPanel) return;
          chromePanel.setAttribute("hidden", "");
          iosPanel.removeAttribute("hidden");
          banner.removeAttribute("hidden");
          requestAnimationFrame(function () {
            banner.classList.add("pwa-banner--visible");
          });
        }

        window.addEventListener("beforeinstallprompt", function (e) {
          e.preventDefault();
          deferredPrompt = e;
          showChromePanel();
        });

        window.addEventListener("appinstalled", function () {
          deferredPrompt = null;
          hideBanner();
        });

        setTimeout(function () {
          showIosPanel();
        }, 3000);

        document.addEventListener("click", function (e) {
          var t = e.target;
          if (!(t && t.closest)) return;

          if (t.closest("#pwa-install-btn")) {
            if (deferredPrompt) {
              deferredPrompt.prompt();
              deferredPrompt.userChoice
                .then(function () {
                  deferredPrompt = null;
                  hideBanner();
                })
                .catch(function () {
                  deferredPrompt = null;
                });
            }
            return;
          }

          if (t.closest("#pwa-dismiss-btn")) {
            localStorage.setItem("pwa-dismissed", "true");
            hideBanner();
            return;
          }

          if (t.closest("#pwa-ios-dismiss")) {
            localStorage.setItem("pwa-dismissed", "true");
            hideBanner();
            return;
          }

          if (t.closest("#pwa-ios-ok")) {
            hideBanner();
          }
        });
      })();
    </script>
    <script>
      (function () {
        const root = document.documentElement;
        const toggle = document.getElementById("theme-toggle");

        function applyTheme(theme: string) {
          const next = theme === "light" ? "light" : "dark";
          root.setAttribute("data-theme", next);
          try {
            localStorage.setItem("pch-theme", next);
          } catch (e) {
            /* ignore */
          }
          const mc = document.getElementById("pch-theme-color");
          if (mc) {
            mc.setAttribute("content", next === "light" ? "#f8f9fb" : "#0A0C10");
          }
        }

        toggle?.addEventListener("click", function () {
          const cur = root.getAttribute("data-theme") || "light";
          applyTheme(cur === "dark" ? "light" : "dark");
        });

        document.addEventListener("astro:page-load", function () {
          const saved = (function () {
            try {
              return localStorage.getItem("pch-theme");
            } catch (e) {
              return null;
            }
          })();
          applyTheme(saved === "dark" ? "dark" : "light");
        });
      })();
    </script>
    <script>
      (function () {
        let startY = 0;
        let pullArmed = false;
        const indicator = document.createElement("div");
        indicator.className = "pull-refresh-indicator";
        indicator.setAttribute("aria-hidden", "true");
        indicator.innerHTML =
          '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 4v6h6M23 20v-6h-6"/><path d="M20.49 9A9 9 0 0 0 5.64 5.64L1 10M23 14l-4.64 4.36A9 9 0 0 1 3.51 15"/></svg>';
        document.body.appendChild(indicator);

        document.addEventListener(
          "touchstart",
          (e) => {
            startY = e.touches[0].clientY;
            pullArmed = false;
          },
          { passive: true },
        );

        document.addEventListener(
          "touchmove",
          (e) => {
            if (window.scrollY === 0 && e.touches[0].clientY - startY > 60) {
              indicator.classList.add("visible");
              pullArmed = true;
            }
          },
          { passive: true },
        );

        document.addEventListener("touchend", () => {
          if (pullArmed && indicator.classList.contains("visible")) {
            if ("vibrate" in navigator) navigator.vibrate(40);
            indicator.classList.remove("visible");
            setTimeout(() => window.location.reload(), 300);
          } else {
            indicator.classList.remove("visible");
          }
          pullArmed = false;
        });

        function bindForecastHaptics() {
          document.querySelectorAll(".forecast-section details.fcard").forEach((card) => {
            card.addEventListener(
              "touchstart",
              () => {
                if ("vibrate" in navigator) navigator.vibrate(30);
              },
              { passive: true },
            );
          });
        }

        bindForecastHaptics();
        document.addEventListener("astro:page-load", bindForecastHaptics);
      })();
    </script>
  </body>
</html>

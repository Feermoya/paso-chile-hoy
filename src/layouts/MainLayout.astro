---
import FirebaseAnalytics from "@/components/FirebaseAnalytics.astro";
import Footer from "@/components/Footer.astro";
import "@/styles/global.css";

export interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
  /** Altitud mostrada en el badge del header (m s.n.m.). */
  headerAltitudeM?: number;
}

const siteName = "Paso Chile Hoy";
const defaultDescription =
  "Paso Cristo Redentor / Los Libertadores: clima, alertas y datos públicos de Argentina.gob.ar. Estado resumido inferido — verificá siempre la fuente oficial.";

const {
  title = siteName,
  description = defaultDescription,
  canonicalPath = "/",
  headerAltitudeM = 3200,
} = Astro.props;
const pageTitle = title === siteName ? siteName : `${title} · ${siteName}`;
const canonical = Astro.site ? new URL(canonicalPath, Astro.site).href : null;
const altitudeLabel = `Altitud del paso: ${headerAltitudeM} metros sobre el nivel del mar`;
---

<!doctype html>
<html lang="es-AR">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, viewport-fit=cover"
    />
    <meta name="theme-color" content="#0A0C10" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="Paso Chile Hoy" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,400&family=JetBrains+Mono:wght@400;500&family=Sora:wght@300;400;600;700&display=swap"
      rel="stylesheet"
    />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    {canonical && <link rel="canonical" href={canonical} />}
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    {canonical && <meta property="og:url" content={canonical} />}
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
  </head>
  <body class="min-h-dvh bg-page">
    <div class="relative z-[1] flex min-h-dvh flex-col">
      <a
        href="#contenido-principal"
        class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded-[var(--radius-md)] focus:bg-surface-raised focus:px-4 focus:py-2 focus:text-ink focus:outline-none focus:ring-2 focus:ring-accent/40 focus:ring-offset-2 focus:ring-offset-page"
      >
        Ir al contenido
      </a>
      <header class="header-app">
        <div class="header-inner">
          <a href="/" class="header-logo-link" aria-label="Inicio — todos los pasos">
            <span class="header-logomark">
              <svg
                width="28"
                height="20"
                viewBox="0 0 28 20"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
                aria-hidden="true"
                class="header-logomark-svg"
              >
                <polyline
                  points="0,18 5,10 10,18"
                  stroke="var(--color-text-muted)"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  fill="none"
                  opacity="0.6"></polyline>
                <polyline
                  points="7,18 14,6 21,18"
                  stroke="var(--color-accent)"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  fill="none"
                  opacity="0.85"></polyline>
                <polyline
                  points="17,18 24,1 28,10"
                  stroke="var(--color-copper)"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  fill="none"></polyline>
                <line
                  x1="0"
                  y1="18"
                  x2="28"
                  y2="18"
                  stroke="var(--color-border-default)"
                  stroke-width="1"
                  stroke-linecap="round"
                  opacity="0.4"></line>
              </svg>
            </span>

            <span class="header-brand">
              <span class="header-name">Paso Chile Hoy</span>
              <span class="header-location">
                <span class="header-location-dot" aria-hidden="true"></span>
                Mendoza · AR
              </span>
            </span>
          </a>

          <div class="header-altitude" aria-label={altitudeLabel}>
            <span class="header-altitude-number">{headerAltitudeM}</span>
            <span class="header-altitude-unit">m</span>
          </div>
        </div>
      </header>
      <main id="contenido-principal" class="min-w-0 flex-1 pb-4 pt-2 md:pt-4">
        <slot />
      </main>
      <Footer />
    </div>
    <FirebaseAnalytics />
  </body>
</html>

---
import FirebaseAnalytics from "@/components/FirebaseAnalytics.astro";
import Footer from "@/components/Footer.astro";
import "@/styles/global.css";

export interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
  headerAltitudeM?: number;
  ogTitle?: string;
  ogDescription?: string;
  /** URL absoluta de la imagen OG (1200×630 recomendado). */
  ogImage?: string;
}

const siteName = "Paso Chile Hoy";
const defaultDescription =
  "Estado en tiempo real del Paso Cristo Redentor y pasos internacionales Mendoza–Chile. Datos públicos de Argentina.gob.ar — verificá siempre la fuente oficial.";

const {
  title = siteName,
  description = defaultDescription,
  canonicalPath = "/",
  headerAltitudeM = 3200,
  ogTitle,
  ogDescription,
  ogImage: ogImageProp,
} = Astro.props;
const pageTitle = title === siteName ? siteName : `${title} · ${siteName}`;
const canonical = Astro.site ? new URL(canonicalPath, Astro.site).href : Astro.url.href;
const ogTitleFinal = ogTitle ?? pageTitle;
const ogDescriptionFinal = ogDescription ?? description;
const ogImageDefault = Astro.site
  ? new URL("/og-default.png", Astro.site).href
  : "https://pasochilehoy.com/og-default.png";
const ogImageFinal = ogImageProp ?? ogImageDefault;
const altitudeLabel = `Altitud del paso: ${headerAltitudeM} metros sobre el nivel del mar`;
---

<!doctype html>
<html lang="es-AR">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, viewport-fit=cover"
    />
    <meta name="theme-color" content="#0A0C10" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="Paso Chile" />
    <link rel="manifest" href="/manifest.json" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,400&family=JetBrains+Mono:wght@400;500&family=Sora:wght@300;400;600;700&display=swap"
      rel="stylesheet"
    />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={ogTitleFinal} />
    <meta property="og:description" content={ogDescriptionFinal} />
    <meta property="og:image" content={ogImageFinal} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="es_AR" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitleFinal} />
    <meta name="twitter:description" content={ogDescriptionFinal} />
    <meta name="twitter:image" content={ogImageFinal} />
  </head>
  <body class="min-h-dvh bg-page">
    <div class="relative z-[1] flex min-h-dvh flex-col">
      <a
        href="#contenido-principal"
        class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded-[var(--radius-md)] focus:bg-surface-raised focus:px-4 focus:py-2 focus:text-ink focus:outline-none focus:ring-2 focus:ring-accent/40 focus:ring-offset-2 focus:ring-offset-page"
      >
        Ir al contenido
      </a>
      <header class="header-app">
        <div class="header-inner">
          <a href="/" class="header-logo-link" aria-label="Inicio — todos los pasos">
            <span class="header-logomark">
              <svg
                width="28"
                height="24"
                viewBox="0 0 48 40"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
                aria-hidden="true"
                class="header-logomark-svg"
              >
                <ellipse cx="40" cy="8" rx="7" ry="7" fill="#F5C842" opacity="0.12"></ellipse>
                <ellipse cx="40" cy="8" rx="4" ry="4" fill="#F5C842" opacity="0.9"></ellipse>
                <polygon points="0,36 10,16 20,36" fill="#2A3A52"></polygon>
                <polygon points="6,36 10,16 14,36" fill="#1A2840"></polygon>
                <polygon points="10,36 22,6 34,36" fill="#3D6B9A"></polygon>
                <polygon points="22,6 34,36 28,36" fill="#2A5080"></polygon>
                <polygon points="22,6 20,11 24,11" fill="rgba(255,255,255,0.85)"></polygon>
                <polygon points="27,36 38,3 48,18" fill="#C07830"></polygon>
                <polygon points="38,3 48,18 48,36 44,36" fill="#8A5220"></polygon>
                <polygon points="38,3 35,9 41,9" fill="rgba(255,255,255,0.9)"></polygon>
                <line
                  x1="0"
                  y1="36"
                  x2="48"
                  y2="36"
                  stroke="rgba(255,255,255,0.07)"
                  stroke-width="0.75"></line>
              </svg>
            </span>

            <span class="header-brand">
              <span class="header-name">Paso Chile Hoy</span>
              <span class="header-location">
                <span class="header-location-dot" aria-hidden="true"></span>
                Mendoza · AR
              </span>
            </span>
          </a>

          <div class="header-altitude" aria-label={altitudeLabel}>
            <span class="header-altitude-number">{headerAltitudeM}</span>
            <span class="header-altitude-unit">m</span>
          </div>
        </div>
      </header>
      <main id="contenido-principal" class="min-w-0 flex-1 pb-4 pt-2 md:pt-4">
        <slot />
      </main>
      <Footer />
    </div>
    <FirebaseAnalytics />
    <script>
      (function () {
        let startY = 0;
        let pullArmed = false;
        const indicator = document.createElement("div");
        indicator.className = "pull-refresh-indicator";
        indicator.setAttribute("aria-hidden", "true");
        indicator.innerHTML =
          '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 4v6h6M23 20v-6h-6"/><path d="M20.49 9A9 9 0 0 0 5.64 5.64L1 10M23 14l-4.64 4.36A9 9 0 0 1 3.51 15"/></svg>';
        document.body.appendChild(indicator);

        document.addEventListener(
          "touchstart",
          (e) => {
            startY = e.touches[0].clientY;
            pullArmed = false;
          },
          { passive: true },
        );

        document.addEventListener(
          "touchmove",
          (e) => {
            if (window.scrollY === 0 && e.touches[0].clientY - startY > 60) {
              indicator.classList.add("visible");
              pullArmed = true;
            }
          },
          { passive: true },
        );

        document.addEventListener("touchend", () => {
          if (pullArmed && indicator.classList.contains("visible")) {
            if ("vibrate" in navigator) navigator.vibrate(40);
            indicator.classList.remove("visible");
            setTimeout(() => window.location.reload(), 300);
          } else {
            indicator.classList.remove("visible");
          }
          pullArmed = false;
        });

        function bindForecastHaptics() {
          document.querySelectorAll(".forecast-card").forEach((card) => {
            card.addEventListener(
              "touchstart",
              () => {
                if ("vibrate" in navigator) navigator.vibrate(30);
              },
              { passive: true },
            );
          });
        }

        bindForecastHaptics();
        document.addEventListener("astro:page-load", bindForecastHaptics);
      })();
    </script>
  </body>
</html>

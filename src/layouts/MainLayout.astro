---
import AlertTicker from "@/components/AlertTicker.astro";
import CookieBanner from "@/components/CookieBanner.astro";
import Footer from "@/components/Footer.astro";
import VersionBadge from "@/components/VersionBadge.astro";
import { SITE_FAVICON, SITE_NAME } from "@/utils/seo";
import "@/styles/global.css";

export interface Props {
  title: string;
  description: string;
  /** Open Graph / redes; por defecto igual que `title`. */
  ogTitle?: string;
  ogDescription?: string;
  /** URL absoluta; por defecto `DEFAULT_OG_IMAGE` del sitio. */
  ogImage?: string;
  /** Texto alternativo de la imagen en previews (Twitter y accesibilidad). */
  ogImageAlt?: string;
  canonical?: string;
  /** Por defecto `summary_large_image` (coherente con og-image 1200×630). */
  twitterCard?: "summary" | "summary_large_image";
  noindex?: boolean;
  structuredData?: Record<string, unknown>;
  /** Solo en página de paso; si no se pasa, no se muestra el badge de altitud. */
  headerAltitudeM?: number | null;
  /** Ej. Mendoza · AR / San Juan · AR; si no se pasa, no se muestra región bajo la marca (home, legal). */
  headerRegionLabel?: string | null;
  /** Meta geo.region (ej. AR-M, AR-J). */
  geoRegionCode?: string;
  geoPlacename?: string;
  /** Meta geo.position: "lat;lng" */
  geoPosition?: string;
}

function baseUrl(): string {
  const env = import.meta.env.PUBLIC_SITE_URL?.trim();
  if (env) return env.replace(/\/$/, "");
  const site = import.meta.env.SITE?.trim();
  if (site) return site.replace(/\/$/, "");
  return "https://pasochilehoy.com";
}

const siteUrl = baseUrl();

const {
  title,
  description,
  ogTitle,
  ogDescription,
  ogImage: ogImageProp,
  ogImageAlt: ogImageAltProp,
  canonical: canonicalProp,
  twitterCard = "summary_large_image",
  noindex = false,
  structuredData,
  headerAltitudeM,
  headerRegionLabel,
  geoRegionCode = "AR-M",
  geoPlacename = "Mendoza, Argentina",
  geoPosition = "-32.8211;-69.9232",
} = Astro.props;

const canonical = canonicalProp ?? `${siteUrl}/`;
const resolvedOgTitle = ogTitle ?? title;
const resolvedOgDesc = ogDescription ?? description;
const ogImageFinal = ogImageProp ?? `${siteUrl}/og-image.png`;
const ogImageAltResolved =
  ogImageAltProp ?? `${SITE_NAME} — Estado de pasos internacionales Argentina–Chile`;

const websiteSchema: Record<string, unknown> = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: SITE_NAME,
  url: `${siteUrl}/`,
  description:
    "Estado en tiempo real del Cristo Redentor, Pehuenche, Agua Negra y pasos internacionales Argentina–Chile.",
  inLanguage: "es-AR",
  publisher: {
    "@type": "Person",
    name: "Fernando Moya",
    email: "fmoya97.fm@gmail.com",
  },
  potentialAction: {
    "@type": "SearchAction",
    target: `${siteUrl}/?q={search_term_string}`,
    "query-input": "required name=search_term_string",
  },
};

const showHeaderRegion = Boolean(headerRegionLabel?.trim());
const showHeaderAltitude =
  typeof headerAltitudeM === "number" && Number.isFinite(headerAltitudeM);
const altitudeLabel = showHeaderAltitude
  ? `Altitud del paso: ${headerAltitudeM} metros sobre el nivel del mar`
  : "";

const icbmContent = geoPosition.includes(";")
  ? geoPosition
      .split(";")
      .map((s) => s.trim())
      .join(", ")
  : geoPosition;
---

<!doctype html>
<html lang="es-AR">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, viewport-fit=cover"
    />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex ? (
      <meta name="robots" content="noindex, nofollow" />
    ) : (
      <meta
        name="robots"
        content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1"
      />
    )}

    <meta name="geo.region" content={geoRegionCode} />
    <meta name="geo.placename" content={geoPlacename} />
    <meta name="geo.position" content={geoPosition} />
    <meta name="ICBM" content={icbmContent} />

    <meta http-equiv="content-language" content="es-AR" />
    <link rel="alternate" hreflang="es-AR" href={canonical} />
    <link rel="alternate" hreflang="es" href={canonical} />
    <link rel="alternate" hreflang="x-default" href={`${siteUrl}/`} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={resolvedOgTitle} />
    <meta property="og:description" content={resolvedOgDesc} />
    <meta property="og:image" content={ogImageFinal} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImageAltResolved} />
    <meta property="og:locale" content="es_AR" />

    <meta name="twitter:card" content={twitterCard} />
    <meta name="twitter:title" content={resolvedOgTitle} />
    <meta name="twitter:description" content={resolvedOgDesc} />
    <meta name="twitter:image" content={ogImageFinal} />
    <meta name="twitter:image:alt" content={ogImageAltResolved} />

    <meta name="theme-color" content="#0A0C10" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="Paso Chile" />
    <link rel="manifest" href="/manifest.json" />

    <link rel="icon" type="image/x-icon" href={SITE_FAVICON.ico} />
    <link rel="icon" type="image/png" href={SITE_FAVICON.png16} sizes="16x16" />
    <link rel="icon" type="image/png" href={SITE_FAVICON.png32} sizes="32x32" />
    <link rel="apple-touch-icon" href={SITE_FAVICON.appleTouch} />
    <link rel="apple-touch-startup-image" href={SITE_FAVICON.appleTouch} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,400&family=JetBrains+Mono:wght@400;500&family=Sora:wght@300;400;600;700;800&display=swap"
      rel="stylesheet"
    />

    <script is:inline type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
    {structuredData && (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />
    )}
  </head>
  <body class="min-h-dvh bg-page">
    <div class="relative z-[1] flex min-h-dvh flex-col">
      <a
        href="#contenido-principal"
        class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded-[var(--radius-md)] focus:bg-surface-raised focus:px-4 focus:py-2 focus:text-ink focus:outline-none focus:ring-2 focus:ring-accent/40 focus:ring-offset-2 focus:ring-offset-page"
      >
        Ir al contenido
      </a>
      <header class="header-app site-header">
        <div class="header-inner">
          <a href="/" class="header-logo-link" aria-label="Inicio — todos los pasos">
            <span class="header-brand-name">PASO CHILE HOY</span>
            {
              showHeaderRegion && (
                <>
                  <span class="header-location-sep" aria-hidden="true">
                    ·
                  </span>
                  <span class="header-location">{headerRegionLabel}</span>
                </>
              )
            }
          </a>

          <div class="header-actions">
            <VersionBadge />
            {
              showHeaderAltitude && (
                <div class="header-altitude header-altitude--desktop" aria-label={altitudeLabel}>
                  <span class="header-altitude-number">{headerAltitudeM}</span>
                  <span class="header-altitude-unit">m</span>
                </div>
              )
            }
          </div>
        </div>
      </header>
      <div class="ticker-wrapper">
        <AlertTicker />
      </div>
      <main id="contenido-principal" class="min-w-0 flex-1 pb-4 pt-1 md:pt-4">
        <slot />
      </main>
      <slot name="before-footer" />
      <Footer />
    </div>
    <CookieBanner />
    <script is:inline>
      function updateHeaderHeight() {
        const header = document.querySelector(".site-header");
        if (header) {
          document.documentElement.style.setProperty(
            "--header-height",
            header.offsetHeight + "px",
          );
        }
      }
      updateHeaderHeight();
      window.addEventListener("resize", updateHeaderHeight);
      window.addEventListener("load", updateHeaderHeight);
      document.addEventListener("astro:page-load", updateHeaderHeight);
    </script>
    <script is:inline>
      if ("serviceWorker" in navigator) {
        window.addEventListener("load", () => {
          navigator.serviceWorker
            .register("/sw.js")
            .then(() => {})
            .catch(() => {});
        });
      }
    </script>
    <script>
      (function () {
        let startY = 0;
        let pullArmed = false;
        const indicator = document.createElement("div");
        indicator.className = "pull-refresh-indicator";
        indicator.setAttribute("aria-hidden", "true");
        indicator.innerHTML =
          '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 4v6h6M23 20v-6h-6"/><path d="M20.49 9A9 9 0 0 0 5.64 5.64L1 10M23 14l-4.64 4.36A9 9 0 0 1 3.51 15"/></svg>';
        document.body.appendChild(indicator);

        document.addEventListener(
          "touchstart",
          (e) => {
            startY = e.touches[0].clientY;
            pullArmed = false;
          },
          { passive: true },
        );

        document.addEventListener(
          "touchmove",
          (e) => {
            if (window.scrollY === 0 && e.touches[0].clientY - startY > 60) {
              indicator.classList.add("visible");
              pullArmed = true;
            }
          },
          { passive: true },
        );

        document.addEventListener("touchend", () => {
          if (pullArmed && indicator.classList.contains("visible")) {
            if ("vibrate" in navigator) navigator.vibrate(40);
            indicator.classList.remove("visible");
            setTimeout(() => window.location.reload(), 300);
          } else {
            indicator.classList.remove("visible");
          }
          pullArmed = false;
        });

        function bindForecastHaptics() {
          document.querySelectorAll(".forecast-section details.fcard").forEach((card) => {
            card.addEventListener(
              "touchstart",
              () => {
                if ("vibrate" in navigator) navigator.vibrate(30);
              },
              { passive: true },
            );
          });
        }

        bindForecastHaptics();
        document.addEventListener("astro:page-load", bindForecastHaptics);
      })();
    </script>
  </body>
</html>
